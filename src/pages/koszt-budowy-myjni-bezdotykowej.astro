		.related-grid-premium {
			grid-template-columns: 1fr !important;
			gap: 12px !important;
		}

		.related-card-premium {
			min-height: 92px !important;
			padding: 20px !important;
			border-radius: 22px !important;
		}

		.related-card-premium .related-card-label {
			font-size: 1.12rem !important;
			line-height: 1.12 !important;
		}

		.related-card-premium .related-card-arrow {
			width: 48px !important;
			height: 48px !important;
			min-width: 48px !important;
			min-height: 48px !important;
			font-size: 1.1rem !important;
		}
	}

</style>

<script is:inline>
	const buildCarousels = document.querySelectorAll('[data-build-carousel]');

	buildCarousels.forEach((carousel) => {
		const track = carousel.querySelector('[data-build-track]');
		const prev = carousel.querySelector('[data-build-prev]');
		const next = carousel.querySelector('[data-build-next]');

		if (!track || !prev || !next) return;

		const getStep = () => {
			const firstCard = track.querySelector('.build-slide');
			if (!firstCard) return 360;
			const styles = window.getComputedStyle(track);
			const gap = parseFloat(styles.columnGap || styles.gap || '18');
			return firstCard.getBoundingClientRect().width + gap;
		};

		prev.addEventListener('click', () => {
			track.scrollBy({ left: -getStep(), behavior: 'smooth' });
		});

		next.addEventListener('click', () => {
			track.scrollBy({ left: getStep(), behavior: 'smooth' });
		});
	});
</script>
