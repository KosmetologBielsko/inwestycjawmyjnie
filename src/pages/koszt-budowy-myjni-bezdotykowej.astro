			min-height: auto;
			padding: 24px;
			border-radius: 28px;
		}

		.layer-card h3,
		.works-card h3 {
			margin-top: 30px;
		}

		.build-row {
			grid-template-columns: 1fr;
			gap: 14px;
		}

		.build-row b {
			justify-self: start;
			white-space: normal;
		}

		.build-carousel {
			padding: 24px;
			border-radius: 34px;
		}

		.build-carousel-head {
			display: grid;
		}

		.build-carousel-nav {
			justify-content: center;
		}

		.build-carousel-track {
			grid-auto-columns: 86vw;
			margin-left: -14px;
			margin-right: -14px;
			padding-left: 14px;
			padding-right: 14px;
		}

		.build-slide {
			min-height: 280px;
		}

		.pzt-panel,
		.analysis-cta {
			padding: 28px;
			border-radius: 34px;
		}

		.analysis-cta .build-button-green {
			width: 100%;
		}
	}

