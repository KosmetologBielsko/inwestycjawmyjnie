---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/koszt-budowy-myjni-bezdotykowej/',
	title: 'Koszt budowy myjni bezdotykowej — projekt, PZT i roboty budowlane',
	description:
		'Koszt budowy myjni bezdotykowej to nie tylko cena technologii. Sprawdź projekt, formalności, PZT, przyłącza, roboty ziemne, kostkę, krawężniki, separatory i rezerwę budżetową.'
};

const technologyRows = [
	{
		stations: '2 stanowiska',
		amount: '500 000 zł netto',
		note: 'orientacyjna wartość technologiczna do wstępnej kalkulacji inwestora'
	},
	{
		stations: '3 stanowiska',
		amount: '600 000 zł netto',
		note: 'częsty wariant pierwszej samodzielnej inwestycji myjniowej'
	},
	{
		stations: '4 stanowiska',
		amount: '850 000 zł netto',
		note: 'większy potencjał, ale też większe znaczenie układu działki'
	},
	{
		stations: '5 stanowisk',
		amount: '1 100 000 zł netto',
		note: 'wariant dla mocniejszej lokalizacji i dobrze zaprojektowanej komunikacji'
	},
	{
		stations: '6 stanowisk',
		amount: '1 300 000 zł netto',
		note: 'większa skala, która wymaga dokładniejszej analizy ruchu i budżetu'
	}
];

const budgetLayers = [
	{
		number: '01',
		title: 'Cena technologii',
		text: 'Kontener albo moduł, technologia mycia, stanowiska, automatyka, programy, konstrukcja, posadzka, urządzenia i zakres producenta.'
	},
	{
		number: '02',
		title: 'Projekt i formalności',
		text: 'Analiza działki, PZT, dokumentacja do pozwolenia, branże, uzgodnienia, operat wodnoprawny, zjazd i prowadzenie procesu.'
	},
	{
		number: '03',
		title: 'Prace budowlane',
		text: 'Roboty ziemne, niwelacja, podbudowy, kostka, krawężniki, przyłącza, odwodnienie, separatory, osadniki, porządkowanie terenu.'
	}
];

const projectScope = [
	['Analiza działki', 'sprawdzenie podstawowych warunków lokalizacji, MPZP albo WZ, możliwości obsługi komunikacyjnej i ograniczeń formalnych'],
	['Koncepcja inwestycji', 'ustalenie liczby stanowisk, położenia kontenera albo modułu, strefy mokrej, strefy suchej i komunikacji samochodów'],
	['PZT', 'plan zagospodarowania terenu z układem myjni, urządzeń SPA, przyłączy, odwodnienia, separatorów, krawężników i nawierzchni'],
	['Branże i media', 'koordynacja wody, kanalizacji, deszczówki, prądu, gazu, teletechniki, separatora, osadników i przyłączy'],
	['Zjazd i pas drogowy', 'weryfikacja wjazdu, wyjazdu, ewentualnego nowego zjazdu albo przebudowy istniejącego zjazdu z drogi'],
	['Operat wodnoprawny', 'przygotowanie albo koordynacja operatu, jeżeli sposób odprowadzenia wód, ścieków lub urządzenia wodne tego wymagają'],
	['Pozwolenie na budowę', 'kompletacja dokumentacji, wnioski, korekty po uwagach urzędu i prowadzenie inwestora przez procedurę'],
	['Materiał do kosztorysu', 'dane pozwalające określić m² nawierzchni, mb krawężników, zakres robót ziemnych, przyłącza i elementy infrastruktury']
];

const pztCards = [
	{
		title: 'Strefa mokra',
		text: 'Stanowiska mycia, odwodnienie, posadzka, spadki, odpływy, kontener albo moduł techniczny, zasilanie technologii i układ pracy samochodów.'
	},
	{
		title: 'Strefa sucha SPA',
		text: 'Odkurzacze, dyspensery, pranie dywaników, ozonator, rozmieniarka, nalewak płynu i miejsce, w którym klient kończy usługę po myciu.'
	},
	{
		title: 'Komunikacja i kolejka',
		text: 'Wjazd, wyjazd, promienie skrętu, miejsce na oczekiwanie, ruch SUV-ów, busów i kierowców o różnym doświadczeniu.'
	},
	{
		title: 'Infrastruktura budowlana',
		text: 'Krawężniki, kostka, podbudowa, geokrata, utwardzenia, separator, osadniki, deszczówka, przyłącza, studnie i roboty ziemne.'
	}
];

const worksCards = [
	['01', 'Roboty ziemne', 'Niwelacja, wykopy, zasypki, stabilizacja, wymiana gruntu, przygotowanie podbudowy i prace koparką zależne od warunków działki.'],
	['02', 'Rozbiórki i porządki', 'Usunięcie starego asfaltu, płyt, kostki, krawężników, fundamentów, wywóz gruzu, uporządkowanie terenu i przygotowanie placu.'],
	['03', 'Podbudowy i utwardzenia', 'Kruszywo, warstwy nośne, zagęszczenie, stabilizacja, geokrata albo inne rozwiązania zależne od gruntu i obciążeń.'],
	['04', 'Nawierzchnie', 'Kostka brukowa, płyty, obrzeża, krawężniki, strefy manewrowe, dojazdy, place oczekiwania i strefa urządzeń dodatkowych.'],
	['05', 'Media i przyłącza', 'Prąd, woda, kanalizacja, gaz, teletechnika, monitoring, oświetlenie i ewentualne przebudowy infrastruktury na działce.'],
	['06', 'Odwodnienie i separacja', 'Kanalizacja technologiczna, deszczówka, separator, osadniki, studnie, spadki i rozwiązania wymagane przez projekt oraz warunki lokalne.'],
	['07', 'Zjazd i droga', 'Nowy zjazd, przebudowa istniejącego, pas drogowy, widoczność, oznakowanie, promienie skrętu i bezpieczne włączenie do ruchu.'],
	['08', 'Urządzenia dodatkowe', 'Przygotowanie fundamentów, przewodów, zasilania i nawierzchni pod odkurzacze, dyspensery, pranie dywaników i inne elementy SPA.']
];

const unitCosts = [
	['Kostka betonowa z ułożeniem', 'ok. 130–200 zł/m²', 'zależnie od kostki, regionu, wzoru, podbudowy i trudności prac'],
	['Nawierzchnia z mocniejszą podbudową', 'ok. 180–300+ zł/m²', 'przy myjni trzeba myśleć o obciążeniach, wodzie, soli, ruchu i spadkach'],
	['Sama robocizna układania kostki', 'ok. 50–100 zł/m² netto', 'widełki orientacyjne, bez materiałów i prac dodatkowych'],
	['Podbudowa', 'ok. 30–80 zł/m²', 'grubość i warstwy zależą od gruntu, projektu i obciążeń'],
	['Krawężniki i obrzeża', 'ok. 35–95 zł/mb', 'zależnie od typu: obrzeże, krawężnik najazdowy, drogowy albo oporowy'],
	['Geokrata / nawierzchnie przepuszczalne', 'indywidualnie', 'czasem pomocne w wybranych strefach, ale nie zawsze właściwe dla ruchu na myjni'],
	['Minikoparka z operatorem', 'ok. 140–250 zł/h', 'zależnie od maszyny, regionu, dojazdu i zakresu robót'],
	['Minikoparka bez operatora', 'ok. 400–750 zł/doba', 'zależnie od tonażu, okresu najmu i warunków wypożyczalni'],
	['Rozbiórki, wywóz, niwelacja', 'indywidualnie', 'często pomijane na starcie, a potrafią mocno zmienić budżet'],
	['Separator, osadniki, kanalizacja', 'indywidualnie', 'koszt zależy od projektu, odbiornika, warunków wodno-kanalizacyjnych i zakresu robót'],
	['Przyłącza: prąd, woda, kanalizacja, gaz', 'indywidualnie', 'największe różnice między działkami i jeden z głównych powodów rozbieżności budżetu'],
	['Projekt i formalności', 'ok. 30 000 zł netto', 'założenie robocze dla pełniejszego zakresu z prowadzeniem do pozwolenia i operatem']
];

const hiddenCosts = [
	{
		kicker: 'Zjazd',
		title: 'Działka ma drogę, ale nie zawsze ma dobry wjazd',
		text: 'Nowy zjazd, przebudowa istniejącego albo warunki zarządcy drogi mogą zmienić koszt, termin i układ całej inwestycji.'
	},
	{
		kicker: 'Deszczówka',
		title: 'Woda opadowa musi mieć gdzie odpłynąć',
		text: 'Retencja, kanalizacja deszczowa, spadki, odwodnienie i sposób odprowadzenia wód potrafią mocno wpłynąć na zakres robót.'
	},
	{
		kicker: 'Grunt',
		title: 'Na mapie wygląda prosto, w terenie bywa inaczej',
		text: 'Różnice wysokości, słaba nośność, stara nawierzchnia, korzenie albo ukryte instalacje mogą podnieść koszt przygotowania placu.'
	},
	{
		kicker: 'SPA',
		title: 'Urządzenia dodatkowe też wymagają przygotowania',
		text: 'Odkurzacze, dyspensery, pranie dywaników i inne urządzenia potrzebują miejsca, zasilania, fundamentów, nawierzchni i komunikacji.'
	}
];

const overlookedItems = [
	'koszt projektu i uzgodnień',
	'PZT i projekty branżowe',
	'operat wodnoprawny',
	'uzgodnienie zjazdu albo przebudowy wjazdu',
	'warunki przyłączenia prądu',
	'doprowadzenie wody i kanalizacji',
	'odprowadzenie deszczówki',
	'separator i osadniki',
	'roboty ziemne i niwelacja',
	'rozbiórka starej nawierzchni',
	'wywóz gruzu albo ziemi',
	'krawężniki, obrzeża, kostka i utwardzenia',
	'oświetlenie, monitoring, internet i oznakowanie',
	'przygotowanie pod urządzenia SPA',
	'miejsce na kolejkę i komunikację samochodów',
	'rezerwa budżetowa na elementy ujawnione po PZT'
];

const faqItems = [
	{
		question: 'Czy cena myjni jest tym samym co koszt budowy myjni?',
		answer:
			'Nie. Cena myjni albo technologii jest tylko częścią inwestycji. Do pełnego budżetu trzeba doliczyć projekt, formalności, PZT, przyłącza, prace ziemne, utwardzenia, odwodnienie, separatory, krawężniki, nawierzchnie, zjazd i rezerwę.'
	},
	{
		question: 'Ile kosztuje projekt myjni bezdotykowej?',
		answer:
			'W 2026 roku do wstępnej kalkulacji można przyjąć około 30 000 zł netto dla pełniejszego zakresu projektowego z prowadzeniem inwestora do pozwolenia na budowę oraz operatem wodnoprawnym. Ostateczna cena zależy od działki, zakresu pracowni, uzgodnień i wymagań urzędu.'
	},
	{
		question: 'Dlaczego PZT jest tak ważny przy kosztach budowy?',
		answer:
			'PZT pokazuje realny układ inwestycji: stanowiska, kontener albo moduł, strefę mokrą, strefę suchą SPA, wjazd, wyjazd, odwodnienie, przyłącza, separatory, krawężniki, kostkę i zakres utwardzeń. Dopiero po PZT można konkretniej liczyć roboty budowlane.'
	},
	{
		question: 'Jakie prace budowlane trzeba doliczyć do myjni?',
		answer:
			'Najczęściej trzeba uwzględnić roboty ziemne, rozbiórki, niwelację, podbudowy, kostkę, krawężniki, odwodnienie, kanalizację, separator, osadniki, przyłącza, zjazd, przygotowanie strefy SPA, oświetlenie i uporządkowanie terenu.'
	},
	{
		question: 'Czy koszt budowy można policzyć bez PZT?',
		answer:
			'Można wykonać tylko bardzo wstępne założenia. Bez PZT inwestor nie wie dokładnie, ile m² nawierzchni trzeba wykonać, ile mb krawężników, jak prowadzić media, gdzie umieścić separator i jak rozwiązać komunikację na działce.'
	},
	{
		question: 'Czy prace budowlane są podobne na każdej działce?',
		answer:
			'Nie. Dwie myjnie o podobnej liczbie stanowisk mogą mieć bardzo różny koszt budowy, jeżeli jedna działka ma media, dobry zjazd i płaski teren, a druga wymaga niwelacji, przyłączy, odwodnienia i przebudowy wjazdu.'
	},
	{
		question: 'Jaką rezerwę budżetową warto przyjąć?',
		answer:
			'Rezerwa powinna zależeć od stopnia rozpoznania działki. Im mniej wiadomo o gruncie, mediach, odwodnieniu i zjeździe, tym ostrożniej trzeba planować budżet. W praktyce rezerwa chroni inwestora przed kosztami ujawnionymi dopiero po projekcie albo w trakcie prac.'
	},
	{
		question: 'Co inwestor najczęściej pomija w kosztach budowy?',
		answer:
			'Najczęściej pomijane są: projekt, PZT, operat wodnoprawny, zjazd, przyłącza, deszczówka, separator, osadniki, krawężniki, rozbiórki, wywóz materiału, oświetlenie, monitoring, internet, strefa SPA i rezerwa na nieprzewidziane prace.'
	}
];

const relatedLinks = [
	['Ile kosztuje myjnia?', '/ile-kosztuje-myjnia-bezdotykowa/'],
	['Ile zarabia myjnia?', '/ile-zarabia-myjnia-bezdotykowa/'],
	['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Porównanie ofert', '/jak-porownac-oferty-myjni-bezdotykowej/'],
	['Budowa krok po kroku', '/budowa-myjni-bezdotykowej-krok-po-kroku/'],
	['Błędy inwestora', '/najczestsze-bledy-przy-budowie-myjni/']
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};

const breadcrumbs = [
	{
		name: 'Strona główna',
		path: '/'
	},
	{
		name: 'Poradnik inwestora',
		path: '/poradnik/'
	},
	{
		name: 'Koszt budowy myjni',
		path: page.canonicalPath
	}
];

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: page.title,
	description: page.description,
	url: `https://inwestycjawmyjnie.pl${page.canonicalPath}`,
	inLanguage: 'pl-PL',
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': `https://inwestycjawmyjnie.pl${page.canonicalPath}`
	},
	author: {
		'@type': 'Organization',
		name: 'inwestycjawmyjnie.pl',
		url: 'https://inwestycjawmyjnie.pl'
	},
	publisher: {
		'@type': 'Organization',
		name: 'inwestycjawmyjnie.pl',
		url: 'https://inwestycjawmyjnie.pl'
	}
};

---

<Layout
	title={page.title}
	description={page.description}
	canonicalPath={page.canonicalPath}
	ogType="article"
	breadcrumbs={breadcrumbs}
	structuredData={[faqSchema, articleSchema]}
>
	<Header />

	<main class="build-page">
		<section class="build-hero" aria-labelledby="page-title">
			<div class="container build-hero-grid">
				<div class="build-hero-copy">
					<p class="eyebrow"><span></span>Koszt budowy</p>

					<h1 id="page-title">
						Koszt budowy myjni bezdotykowej — co trzeba doliczyć
						<strong>poza ceną technologii?</strong>
					</h1>

					<p class="build-lead">
						Cena producenta to dopiero część budżetu. Pełny koszt budowy obejmuje
						projekt, formalności, PZT, przyłącza, roboty ziemne, odwodnienie,
						separatory, krawężniki, nawierzchnie, strefę SPA i rezerwę na elementy
						wynikające z konkretnej działki.
					</p>

					<div class="build-actions">
						<a class="build-button-green" href="/bezplatne-porownanie-ofert-myjni/">
							Bezpłatna analiza i porównanie ofert
							<span aria-hidden="true">→</span>
						</a>
						<a class="build-button-light" href="#pzt">
							Zobacz rolę PZT
							<span aria-hidden="true">↓</span>
						</a>
					</div>

					<div class="build-chips" aria-label="Najważniejsze tematy strony">
						<span>projekt</span>
						<span>PZT</span>
						<span>przyłącza</span>
						<span>roboty ziemne</span>
						<span>nawierzchnie</span>
						<span>rezerwa</span>
					</div>
				</div>

				<aside class="build-hero-panel build-hero-graphic-panel" aria-label="Grafika hero: Koszt budowy myjni">
					<picture>
						<source media="(max-width: 760px)" srcset="/images/koszt-budowy-budzet-inwestora.webp" />
						<source media="(max-width: 1180px)" srcset="/images/koszt-budowy-budzet-inwestora.webp" />
						<img
							src="/images/koszt-budowy-budzet-inwestora.webp"
							alt="Koszt budowy myjni bezdotykowej: projekt, PZT, przyłącza i roboty budowlane."
							loading="eager"
							decoding="async"
						/>
					</picture>
				</aside>
			</div>
		</section>

		<section class="build-section" aria-labelledby="layers-title">
			<div class="container">
				<div class="build-split">
					<div>
						<p class="eyebrow"><span></span>Pełny budżet</p>
						<h2 id="layers-title">
							Koszt budowy składa się z <strong>trzech dużych warstw</strong>
						</h2>
					</div>
					<p>
						Inwestor najczęściej zna cenę myjni, ale nie zna jeszcze kosztu działki
						jako placu budowy. A to właśnie działka, media, zjazd i PZT decydują,
						ile trzeba doliczyć poza samą technologią.
					</p>
				</div>

				<div class="layer-grid">
					{budgetLayers.map((card) => (
						<article class="layer-card">
							<span>{card.number}</span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="build-section" aria-labelledby="technology-title">
			<div class="container">
				<div class="build-split">
					<div>
						<p class="eyebrow"><span></span>Część technologiczna</p>
						<h2 id="technology-title">
							Orientacyjne ceny myjni w 2026 roku <strong>to punkt startowy</strong>
						</h2>
					</div>
					<p>
						Poniższe kwoty są wartościami kalkulacyjnymi netto. Ostateczna cena może
						się różnić w zależności od producenta, zakresu, technologii, posadzki,
						konstrukcji, urządzeń dodatkowych i indywidualnej konfiguracji.
					</p>
				</div>

				<div class="build-table-panel">
					{technologyRows.map((row) => (
						<article class="build-row">
							<div>
								<strong>{row.stations}</strong>
								<p>{row.note}</p>
							</div>
							<b>{row.amount}</b>
						</article>
					))}
				</div>

				<p class="build-disclaimer">
					To nie jest pełny koszt budowy. Do tych wartości trzeba doliczyć projekt,
					formalności, przygotowanie terenu, przyłącza, odwodnienie, nawierzchnie,
					zjazd, separatory, strefę urządzeń dodatkowych i rezerwę budżetową.
				</p>
			</div>
		</section>

		<section class="build-section build-text-section" aria-labelledby="project-title">
			<div class="container build-article-grid">
				<div class="build-sticky-title">
					<p class="eyebrow"><span></span>Projekt i formalności</p>
					<h2 id="project-title">
						Projekt nie jest dodatkiem. To etap, który <strong>porządkuje budżet</strong>
					</h2>

					<div class="build-side-note" aria-label="Ważne przed decyzją">
						<p>Przed kosztorysem</p>
						<h3>Najpierw sprawdź działkę, PZT i zakres robót.</h3>

						<div class="build-side-note-list">
						<span><b>01</b> projekt i formalności</span>
						<span><b>02</b> przyłącza, odwodnienie i zjazd</span>
						<span><b>03</b> roboty ziemne, nawierzchnie i rezerwa</span>
						</div>

						<a href="/bezplatne-porownanie-ofert-myjni/">
							Bezpłatna analiza i porównanie ofert
							<span aria-hidden="true">→</span>
						</a>
					</div>
				</div>

				<div class="build-article-copy build-article-card">
					<p>
						Koszt projektowy przy budowie myjni bezdotykowej nie powinien być
						traktowany jako drobny wydatek. To etap, który porządkuje działkę,
						układ stanowisk, media, zjazd, odwodnienie, separację, strefę mokrą,
						strefę suchą, przyłącza i dokumenty potrzebne do dalszego procesu.
					</p>

					<p>
						W 2026 roku do wstępnej kalkulacji można przyjąć, że pełniejszy zakres
