		background:
			linear-gradient(145deg, rgba(255, 255, 255, 0.98), rgba(248, 250, 253, 0.96)),
			radial-gradient(circle at 92% 8%, rgba(18, 104, 255, 0.055), transparent 36%);
		border: 1px solid rgba(8, 16, 32, 0.08);
		box-shadow: 0 24px 74px rgba(8, 16, 32, 0.075), inset 0 1px 0 rgba(255, 255, 255, 0.86);
	}

	.build-article-card::before {
		content: '';
		position: absolute;
		right: -90px;
		top: -110px;
		width: 230px;
		height: 230px;
		border-radius: 54% 46% 42% 58% / 44% 58% 42% 56%;
		background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(226, 236, 249, 0.6));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.94), inset 0 -18px 34px rgba(8, 16, 32, 0.035), 0 22px 54px rgba(8, 16, 32, 0.055);
		opacity: 0.62;
		pointer-events: none;
	}

	.build-article-card > * {
		position: relative;
		z-index: 1;
	}

	.build-quote {
		padding: 28px;
		border-radius: 32px;
		background: #fff;
		border: 1px solid rgba(8, 16, 32, 0.08);
		box-shadow: 0 18px 52px rgba(8, 16, 32, 0.06);
	}

	.build-quote strong {
		display: block;
		font-size: clamp(1.35rem, 2vw, 2rem);
		font-weight: 950;
		letter-spacing: -0.055em;
	}

	.build-quote span {
		display: block;
		margin-top: 10px;
		color: #667085;
		font-weight: 560;
		line-height: 1.6;
	}

	.scope-card {
		min-height: 240px;
	}

	.pzt-section {
		padding-top: 0;
	}

	.pzt-panel,
	.analysis-cta {
		padding: clamp(34px, 5vw, 58px);
		border-radius: 48px;
		background:
			radial-gradient(circle at 12% 18%, rgba(18, 104, 255, 0.24), transparent 34%),
			radial-gradient(circle at 88% 8%, rgba(114, 240, 105, 0.2), transparent 30%),
			linear-gradient(135deg, #05070d 0%, #101723 48%, #05070d 100%);
		border: 1px solid rgba(255, 255, 255, 0.12);
		box-shadow: 0 34px 100px rgba(8, 16, 32, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.12);
		color: #fff;
	}

	.pzt-panel h2,
	.analysis-cta h2 {
		color: #fff;
	}

	.pzt-panel > div > p,
	.analysis-cta p {
		max-width: 940px;
		margin-top: 22px;
		color: rgba(255, 255, 255, 0.74);
	}

	.pzt-panel h2 strong,
	.analysis-cta h2 strong {
		background: linear-gradient(90deg, #72f069 0%, #43f2a2 28%, #4fa3ff 68%, #9ed7ff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.pzt-grid {
		margin-top: 34px;
	}

	.pzt-grid article {
		padding: 24px;
		border-radius: 28px;
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.14);
	}

	.pzt-grid h3 {
		margin: 0;
		color: #fff;
		font-size: 1.34rem;
		font-weight: 950;
		letter-spacing: -0.055em;
		line-height: 1.04;
	}

	.pzt-grid p {
		margin: 14px 0 0;
		color: rgba(255, 255, 255, 0.74);
		font-weight: 560;
		line-height: 1.6;
	}

	.works-card {
		min-height: 310px;
	}

	.unit-table {
		display: grid;
		gap: 12px;
		padding: clamp(18px, 3vw, 30px);
		border-radius: 42px;
		background: linear-gradient(145deg, #ffffff, #f8f9fb);
		border: 1px solid rgba(8, 16, 32, 0.08);
		box-shadow: 0 24px 74px rgba(8, 16, 32, 0.075);
	}

	.unit-row {
		display: grid;
		grid-template-columns: minmax(240px, 0.8fr) minmax(170px, 0.35fr) minmax(0, 1fr);
		gap: 18px;
		align-items: center;
		padding: 18px;
		border-radius: 24px;
		background: #fff;
		border: 1px solid rgba(8, 16, 32, 0.07);
	}

	.unit-row strong {
		color: var(--ink);
		font-size: 1.06rem;
		font-weight: 950;
		letter-spacing: -0.04em;
	}

	.unit-row b {
		color: #06110a;
		font-size: 1rem;
		font-weight: 950;
	}

	.unit-row p {
		margin: 0;
		color: #667085;
		font-size: 0.96rem;
		font-weight: 560;
		line-height: 1.52;
	}

	.build-carousel {
		overflow: hidden;
		padding: clamp(30px, 4vw, 48px);
		border-radius: 48px;
		background:
			radial-gradient(circle at 12% 20%, rgba(18, 104, 255, 0.22), transparent 34%),
			radial-gradient(circle at 88% 10%, rgba(114, 240, 105, 0.2), transparent 30%),
			linear-gradient(145deg, #05070d, #121a29 60%, #05070d);
		box-shadow: 0 34px 100px rgba(8, 16, 32, 0.2);
		color: #fff;
	}

	.build-carousel-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 28px;
	}

	.build-carousel-head h2 {
		max-width: 900px;
		margin: 0;
		font-size: clamp(2.3rem, 4vw, 4.6rem);
		font-weight: 950;
		letter-spacing: -0.075em;
		line-height: 0.96;
	}

	.build-carousel-head h2 strong {
		background: linear-gradient(90deg, #72f069 0%, #43f2a2 28%, #4fa3ff 68%, #9ed7ff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.build-carousel-nav {
		display: flex;
		gap: 12px;
	}

	.build-carousel-nav button {
		width: 54px;
		height: 54px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.1);
		color: #fff;
		font-weight: 950;
		font-size: 1.1rem;
		cursor: pointer;
	}

	.build-carousel-track {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: minmax(420px, 520px);
		gap: 18px;
		overflow-x: auto;
		overflow-y: hidden;
		scroll-snap-type: x mandatory;
		scroll-behavior: smooth;
		padding-bottom: 8px;
		scrollbar-width: none;
	}

	.build-carousel-track::-webkit-scrollbar {
		display: none;
	}

	.build-slide {
		scroll-snap-align: start;
		min-height: 300px;
		padding: 28px;
		border-radius: 30px;
		background:
			radial-gradient(circle at 86% 12%, rgba(114, 240, 105, 0.16), transparent 32%),
			linear-gradient(145deg, rgba(255, 255, 255, 0.12), rgba(255, 255, 255, 0.06));
		border: 1px solid rgba(255, 255, 255, 0.16);
	}

	.build-slide span {
		display: block;
		color: #72f069;
		font-size: 0.8rem;
		font-weight: 950;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.build-slide h3 {
		margin: 56px 0 0;
		font-size: 2rem;
		font-weight: 950;
		letter-spacing: -0.065em;
		line-height: 1.02;
	}

	.build-slide p {
		margin: 14px 0 0;
		color: rgba(255, 255, 255, 0.74);
		font-weight: 560;
		line-height: 1.6;
	}

	.overlooked-section {
		background: #f8f9fb;
	}

	.overlooked-grid {
		align-items: start;
	}

	.overlooked-grid > div > p {
		margin-top: 22px;
	}

	.overlooked-list {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 12px;
		margin: 0;
		padding: 28px;
		border-radius: 38px;
		background: #fff;
		border: 1px solid rgba(8, 16, 32, 0.08);
		box-shadow: 0 22px 64px rgba(8, 16, 32, 0.07);
		list-style: none;
	}

	.overlooked-list li {
		display: flex;
		gap: 10px;
		color: #344054;
		font-weight: 650;
		line-height: 1.5;
	}

	.overlooked-list li::before {
		content: '';
		width: 9px;
		height: 9px;
		margin-top: 8px;
		border-radius: 999px;
		background: #72f069;
		box-shadow: 0 0 0 5px rgba(114, 240, 105, 0.12);
		flex: 0 0 auto;
	}

	.analysis-cta {
		display: grid;
		grid-template-columns: minmax(0, 1fr) auto;
		gap: 32px;
		align-items: end;
	}

	.build-faq-list {
		display: grid;
		gap: 14px;
	}

	.build-faq-item {
		border-radius: 24px;
		border: 1px solid rgba(8, 16, 32, 0.08);
		background: #fff;
		box-shadow: 0 18px 52px rgba(8, 16, 32, 0.06);
		overflow: hidden;
	}

	.build-faq-item summary {
		display: flex;
		justify-content: space-between;
		gap: 18px;
		padding: 22px 24px;
		cursor: pointer;
		font-size: 1.1rem;
		font-weight: 900;
		letter-spacing: -0.035em;
		list-style: none;
	}

	.build-faq-item summary::-webkit-details-marker {
		display: none;
	}

	.build-faq-item summary::after {
		content: '+';
		display: grid;
		place-items: center;
		width: 34px;
		height: 34px;
		border-radius: 999px;
		background: #f4f6f9;
		flex: 0 0 auto;
	}

	.build-faq-item[open] summary::after {
		content: '−';
		background: var(--ink);
		color: #fff;
	}

	.build-faq-item p {
		margin: 0;
		padding: 0 24px 24px;
		color: #667085;
		font-weight: 560;
		line-height: 1.68;
	}

	.related-section h2 {
		max-width: 900px;
	}

	.related-grid {
		margin-top: 32px;
	}

	.related-card {
		min-height: 150px;
		display: flex;
		align-items: flex-end;
		justify-content: space-between;
		gap: 20px;
		color: var(--ink);
		font-size: 1.16rem;
		font-weight: 900;
		letter-spacing: -0.04em;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.related-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 26px 72px rgba(8, 16, 32, 0.1);
	}

	.related-card span {
		display: grid;
		place-items: center;
		width: 42px;
		height: 42px;
		border-radius: 999px;
		background: var(--ink);
		color: #fff;
		flex: 0 0 auto;
	}

	@media (max-width: 1420px) {
		.scope-grid,
		.works-grid {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 1180px) {
		.build-hero-grid,
		.build-split,
		.build-article-grid,
		.overlooked-grid,
		.analysis-cta {
			grid-template-columns: 1fr;
		}

