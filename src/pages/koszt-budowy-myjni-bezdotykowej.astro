---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	"filename": "koszt-budowy-myjni-bezdotykowej.astro",
	"canonicalPath": "/ile-kosztuje-myjnia-bezdotykowa/",
	"title": "Koszt budowy myjni bezdotykowej — co policzyć przed inwestycją?",
	"description": "Koszt budowy myjni bezdotykowej rozpisany praktycznie: działka, projekt, budowa, technologia, media, urządzenia dodatkowe i rezerwa.",
	"eyebrow": "Budżet inwestora",
	"hero": {
		"before": "Koszt budowy myjni to nie tylko",
		"strong": "cena urządzeń.",
		"lead": "Ta strona porządkuje elementy budżetu, które inwestor powinien policzyć przed porównywaniem ofert i wyborem technologii myjni.",
		"statA": "budowa",
		"statB": "technologia",
		"statC": "rezerwa"
	},
	"quick": [
		"działka",
		"projekt",
		"budowa",
		"technologia",
		"uruchomienie",
		"rezerwa"
	],
	"cardsTitle": "Co wpisać do budżetu inwestycji?",
	"cardsLead": "Najbezpieczniej traktować koszt jako sumę kilku bloków, a nie jedną pozycję ofertową.",
	"cards": [
		[
			"01",
			"Teren i przygotowanie",
			"Niwelacja, prace ziemne, utwardzenia, odwodnienie, drogi manewrowe i przygotowanie miejsca pod stanowiska."
		],
		[
			"02",
			"Dokumentacja",
			"Projekt, uzgodnienia, formalności, analiza warunków, kontakt z projektantem i przygotowanie procesu."
		],
		[
			"03",
			"Stanowiska i konstrukcja",
			"Ilość stanowisk, dach, słupy, zabudowa, oświetlenie, podbitka, grafika i estetyka obiektu."
		],
		[
			"04",
			"Technologia i automatyka",
			"Pompy, programy, płatności, sterowanie, ogrzewanie, zabezpieczenia i rozwiązania wpływające na eksploatację."
		],
		[
			"05",
			"Urządzenia dodatkowe",
			"Odkurzacze, rozmieniarki, dyspensery, pranie dywaników, ozonator i inne elementy zwiększające koszyk klienta."
		],
		[
			"06",
			"Rezerwa i doposażenie",
			"Budżet na zmiany, doposażenie, korekty i elementy, które pojawiają się dopiero po analizie technicznej."
		]
	],
	"galleryTitle": "Budżet lepiej planować etapami",
	"gallery": [
		[
			"Etap 1",
			"Czy działka w ogóle nadaje się pod myjnię i jaki układ jest realny?"
		],
		[
			"Etap 2",
			"Jaki standard obiektu ma sens dla tej lokalizacji i potencjału ruchu?"
		],
		[
			"Etap 3",
			"Co dokładnie obejmuje oferta producenta, a co zostaje po stronie inwestora?"
		],
		[
			"Etap 4",
			"Jaka rezerwa zabezpiecza inwestora przed zmianami w trakcie budowy?"
		]
	],
	"analysisTitle": "Masz działkę i chcesz uporządkować koszt?",
	"analysisText": "Prześlij lokalizację. Wstępnie można sprawdzić, jakie elementy budżetu będą najważniejsze w konkretnym miejscu.",
	"faq": [
		[
			"Czy ta strona dubluje temat ceny myjni?",
			"Nie. Traktuje koszt szerzej: jako budowę całego obiektu, a nie tylko zakup technologii."
		],
		[
			"Czy liczba stanowisk najmocniej wpływa na koszt?",
			"Jest ważna, ale koszt mocno zależy też od działki, mediów, robót budowlanych, standardu i zakresu oferty."
		],
		[
			"Czy urządzenia dodatkowe warto planować od razu?",
			"Tak, bo wpływają na układ działki, instalacje, przychody dodatkowe i docelowy model działania obiektu."
		],
		[
			"Kiedy porównywać producentów?",
			"Po wstępnej analizie działki i budżetu, żeby porównywać realne rozwiązania, a nie przypadkowe konfiguracje."
		]
	]
};

const relatedLinks = [
	[
		"Koszt budowy myjni",
		"/ile-kosztuje-myjnia-bezdotykowa/"
	],
	[
		"Opłacalność myjni",
		"/ile-zarabia-myjnia-bezdotykowa/"
	],
	[
		"Działka pod myjnię",
		"/dzialka-pod-myjnie-bezdotykowa/"
	],
	[
		"Porównanie ofert",
		"/jak-porownac-oferty-myjni-bezdotykowej/"
	],
	[
		"Budowa krok po kroku",
		"/budowa-myjni-bezdotykowej-krok-po-kroku/"
	],
	[
		"Błędy inwestora",
		"/najczestsze-bledy-przy-budowie-myjni/"
	]
];

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "Czy ta strona dubluje temat ceny myjni?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Nie. Traktuje koszt szerzej: jako budowę całego obiektu, a nie tylko zakup technologii."
			}
		},
		{
			"@type": "Question",
			"name": "Czy liczba stanowisk najmocniej wpływa na koszt?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Jest ważna, ale koszt mocno zależy też od działki, mediów, robót budowlanych, standardu i zakresu oferty."
			}
		},
		{
			"@type": "Question",
			"name": "Czy urządzenia dodatkowe warto planować od razu?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Tak, bo wpływają na układ działki, instalacje, przychody dodatkowe i docelowy model działania obiektu."
			}
		},
		{
			"@type": "Question",
			"name": "Kiedy porównywać producentów?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Po wstępnej analizie działki i budżetu, żeby porównywać realne rozwiązania, a nie przypadkowe konfiguracje."
			}
		}
	]
};
---

<Layout title={page.title} description={page.description} canonicalPath={page.canonicalPath}>
	<Header />

	<main class="guide-page">
		<section class="guide-hero" aria-labelledby="page-title">
			<div class="container guide-hero-grid">
				<div>
					<p class="eyebrow">
						<span></span>
						{page.eyebrow}
					</p>

					<h1 id="page-title">
						{page.hero.before}
						<strong>{page.hero.strong}</strong>
					</h1>

					<p class="guide-lead">{page.hero.lead}</p>

					<div class="guide-actions">
						<a class="guide-button-green" href="/#kontakt">
							Prześlij lokalizację
							<span aria-hidden="true">→</span>
						</a>
						<a class="guide-button-light" href="/poradnik/">
							Wróć do poradnika
							<span aria-hidden="true">→</span>
						</a>
					</div>

					<div class="guide-chips" aria-label="Najważniejsze tematy strony">
						{page.quick.map((item) => <span>{item}</span>)}
					</div>
				</div>

				<aside class="guide-visual" aria-label="Grafika do uzupełnienia">
					<div class="guide-visual-card">
						<div class="guide-stat"><strong>{page.hero.statA}</strong><span>01</span></div>
						<div class="guide-stat"><strong>{page.hero.statB}</strong><span>02</span></div>
						<div class="guide-stat"><strong>{page.hero.statC}</strong><span>03</span></div>
					</div>
					<div class="guide-placeholder">
						Miejsce na mocną grafikę podstrony — docelowo wstawimy WebP dopasowany do tematu.
					</div>
				</aside>
			</div>
		</section>

		<section class="guide-section" aria-labelledby="cards-title">
			<div class="container">
				<div class="guide-split">
					<div>
						<p class="eyebrow">
							<span></span>
							Analiza inwestora
						</p>
						<h2 id="cards-title">Co wpisać do <strong>budżetu inwestycji?</strong></h2>
					</div>
					<p>{page.cardsLead}</p>
				</div>

				<div class="guide-grid">
					{page.cards.map((card) => (
						<article class="guide-card">
							<span class="guide-number">{card[0]}</span>
							<h3>{card[1]}</h3>
							<p>{card[2]}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="guide-section" aria-labelledby="gallery-title">
			<div class="container">
				<div class="guide-carousel-shell" data-subpage-carousel>
					<div class="guide-carousel-head">
						<h2 id="gallery-title">{page.galleryTitle}</h2>
						<div class="guide-carousel-nav" aria-label="Nawigacja sekcji">
							<button class="guide-carousel-arrow" type="button" data-subpage-prev aria-label="Poprzedni element">←</button>
							<button class="guide-carousel-arrow" type="button" data-subpage-next aria-label="Następny element">→</button>
						</div>
					</div>

					<div class="guide-carousel-track" data-subpage-track>
						{page.gallery.map((slide) => (
							<article class="guide-slide">
								<strong>{slide[0]}</strong>
								<h3>{slide[0]}</h3>
								<p>{slide[1]}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="guide-section" aria-labelledby="analysis-title">
			<div class="container">
				<div class="guide-analysis">
					<div class="guide-analysis-grid">
						<div>
							<p class="eyebrow light"><span></span>Analiza lokalizacji</p>
							<h2 id="analysis-title">Masz działkę i chcesz <strong>uporządkować koszt?</strong></h2>
							<p>{page.analysisText}</p>
						</div>
						<a class="guide-button-green" href="/#kontakt">
							Prześlij lokalizację
							<span aria-hidden="true">→</span>
						</a>
					</div>
				</div>
			</div>
		</section>

		<section class="guide-section guide-faq" aria-labelledby="faq-title">
			<div class="container">
				<div class="guide-split">
					<div>
						<p class="eyebrow"><span></span>FAQ</p>
						<h2 id="faq-title">Najczęstsze pytania <strong>inwestora</strong></h2>
					</div>
					<p>Krótko i konkretnie — pytania, które pomagają lepiej przygotować decyzję przed rozmową z projektantem, doradcą albo dostawcą.</p>
				</div>

				<div class="guide-faq-list">
					{page.faq.map((item, index) => (
						<details class="guide-faq-item" open={index === 0}>
							<summary>{item[0]}</summary>
							<p>{item[1]}</p>
						</details>
					))}
				</div>
			</div>
		</section>

		<section class="guide-section guide-related" aria-labelledby="related-title">
			<div class="container">
				<p class="eyebrow"><span></span>Dalej w poradniku</p>
				<h2 id="related-title">Powiązane tematy <strong>dla inwestora</strong></h2>
				<div class="guide-related-grid">
					{relatedLinks.map((link) => (
						<a class="guide-related-card" href={link[1]}>{link[0]} →</a>
					))}
				</div>
			</div>
		</section>
	</main>

	<Footer />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>

<style>
	.guide-page {
		background: #fff;
	}

	.guide-hero {
		position: relative;
		overflow: hidden;
		padding: clamp(84px, 8vw, 132px) 0 clamp(64px, 7vw, 104px);
		background:
			radial-gradient(circle at 78% 14%, rgba(18, 104, 255, 0.08), transparent 32%),
			radial-gradient(circle at 16% 26%, rgba(114, 240, 105, 0.1), transparent 28%),
			linear-gradient(180deg, #ffffff 0%, #f8f9fb 100%);
	}

	.guide-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(360px, 0.72fr);
		gap: clamp(34px, 5vw, 70px);
		align-items: center;
	}

	.guide-hero h1,
	.guide-split h2,
	.guide-analysis h2,
	.guide-faq h2,
	.guide-related h2 {
		margin: 0;
		color: var(--ink);
		font-weight: 950;
		letter-spacing: -0.078em;
		line-height: 0.94;
	}

	.guide-hero h1 {
		max-width: 940px;
		font-size: clamp(3.35rem, 6.8vw, 7.05rem);
	}

	.guide-hero h1 strong,
	.guide-split h2 strong,
	.guide-analysis h2 strong,
	.guide-faq h2 strong,
	.guide-related h2 strong {
		background: linear-gradient(90deg, #0756d8 0%, #1268ff 38%, #4fa3ff 72%, #9ed7ff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		font-weight: inherit;
	}

	.guide-lead {
		max-width: 760px;
		margin: 28px 0 0;
		color: #667085;
		font-size: clamp(1.04rem, 1.35vw, 1.28rem);
		font-weight: 560;
		line-height: 1.68;
		letter-spacing: -0.012em;
	}

	.guide-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.guide-button-green,
	.guide-button-light {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		min-height: 58px;
		padding: 0 24px;
		border-radius: 999px;
		font-weight: 950;
		letter-spacing: -0.03em;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
	}

	.guide-button-green {
		color: #06110a;
		background: linear-gradient(90deg, #7cff4a 0%, #51f05e 45%, #28dc73 100%);
		border: 1px solid rgba(114, 240, 105, 0.34);
		box-shadow: 0 18px 44px rgba(76, 244, 89, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.56);
	}

	.guide-button-light {
		color: var(--ink);
		background: rgba(255, 255, 255, 0.88);
		border: 1px solid rgba(8, 16, 32, 0.1);
		box-shadow: 0 12px 34px rgba(8, 16, 32, 0.06);
	}

	.guide-button-green:hover,
	.guide-button-light:hover {
		transform: translateY(-2px);
	}

	.guide-visual {
		position: relative;
		min-height: 520px;
		padding: 28px;
		border-radius: 46px;
		background:
			radial-gradient(circle at 68% 24%, rgba(18, 104, 255, 0.24), transparent 30%),
			radial-gradient(circle at 28% 78%, rgba(114, 240, 105, 0.22), transparent 30%),
			linear-gradient(145deg, #05070d, #121a29 58%, #05070d);
		border: 1px solid rgba(255, 255, 255, 0.12);
		box-shadow: 0 34px 96px rgba(8, 16, 32, 0.22);
		overflow: hidden;
	}

	.guide-visual::before {
		content: '';
		position: absolute;
		inset: 42px;
		border-radius: 34px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px),
			linear-gradient(180deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
		background-size: 48px 48px;
		mask-image: linear-gradient(180deg, black, transparent 88%);
	}

	.guide-visual-card {
		position: relative;
		z-index: 1;
		display: grid;
		gap: 16px;
	}

	.guide-stat {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 18px;
		min-height: 92px;
		padding: 18px;
		border-radius: 26px;
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.14);
		backdrop-filter: blur(16px);
		color: rgba(255, 255, 255, 0.86);
	}

	.guide-stat strong {
		font-size: 0.8rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
	}

	.guide-stat span {
		color: #72f069;
		font-size: 1.45rem;
		font-weight: 950;
		letter-spacing: -0.06em;
	}

	.guide-placeholder {
		position: absolute;
		left: 28px;
		right: 28px;
		bottom: 28px;
		z-index: 1;
		padding: 20px;
		border-radius: 28px;
		background: rgba(255, 255, 255, 0.09);
		border: 1px dashed rgba(255, 255, 255, 0.22);
		color: rgba(255, 255, 255, 0.76);
		font-weight: 650;
		line-height: 1.5;
	}

	.guide-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 26px;
	}

	.guide-chips span {
		display: inline-flex;
		align-items: center;
		min-height: 38px;
		padding: 8px 14px;
		border: 1px solid rgba(8, 16, 32, 0.09);
		border-radius: 999px;
		background: #fff;
		color: #344054;
		font-size: 0.9rem;
		font-weight: 820;
		box-shadow: 0 10px 26px rgba(8, 16, 32, 0.045);
	}

	.guide-section {
		padding: clamp(72px, 7vw, 110px) 0;
	}

	.guide-split {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(300px, 0.48fr);
		gap: clamp(28px, 4vw, 52px);
		align-items: end;
		margin-bottom: 40px;
	}

	.guide-split h2,
	.guide-analysis h2,
	.guide-faq h2,
	.guide-related h2 {
		font-size: clamp(2.55rem, 4.6vw, 5.1rem);
	}

	.guide-split p {
		margin: 0;
		color: #667085;
		font-size: clamp(1rem, 1.2vw, 1.14rem);
		font-weight: 560;
		line-height: 1.66;
	}

	.guide-grid {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 20px;
	}

	.guide-card {
		position: relative;
		min-height: 300px;
		padding: 28px;
		border-radius: 34px;
		border: 1px solid rgba(8, 16, 32, 0.08);
		background: linear-gradient(145deg, #ffffff, #f8f9fb);
		box-shadow: 0 22px 64px rgba(8, 16, 32, 0.07), inset 0 1px 0 rgba(255, 255, 255, 0.86);
		overflow: hidden;
	}

	.guide-card::before {
		content: '';
		position: absolute;
		right: -80px;
		top: -90px;
		width: 210px;
		height: 230px;
		border-radius: 54% 46% 42% 58% / 44% 58% 42% 56%;
		background: linear-gradient(145deg, rgba(255, 255, 255, 0.96), rgba(226, 236, 249, 0.58));
		box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.94), inset 0 -18px 34px rgba(8, 16, 32, 0.035), 0 22px 54px rgba(8, 16, 32, 0.055);
	}

	.guide-number {
		position: relative;
		z-index: 1;
		display: block;
		color: rgba(8, 16, 32, 0.12);
		font-size: clamp(4.2rem, 5.2vw, 6.6rem);
		font-weight: 950;
		letter-spacing: -0.09em;
		line-height: 0.82;
	}

	.guide-card h3 {
		position: relative;
		z-index: 1;
		margin: 44px 0 0;
		color: var(--ink);
		font-size: clamp(1.45rem, 2vw, 2rem);
		font-weight: 950;
		letter-spacing: -0.06em;
		line-height: 1.02;
	}

	.guide-card p {
		position: relative;
		z-index: 1;
		margin: 14px 0 0;
		color: #667085;
		font-weight: 560;
		line-height: 1.6;
	}

	.guide-carousel-shell {
		position: relative;
		overflow: hidden;
		padding: clamp(28px, 4vw, 44px);
		border-radius: 42px;
		background: linear-gradient(145deg, #05070d, #121a29 62%, #05070d);
		box-shadow: 0 34px 100px rgba(8, 16, 32, 0.2);
	}

	.guide-carousel-head {
		display: flex;
		align-items: end;
		justify-content: space-between;
		gap: 24px;
		margin-bottom: 24px;
		color: #fff;
	}

	.guide-carousel-head h2 {
		max-width: 720px;
		margin: 0;
		font-size: clamp(2.1rem, 3.8vw, 4.3rem);
		font-weight: 950;
		letter-spacing: -0.075em;
		line-height: 0.96;
	}

	.guide-carousel-nav {
		display: flex;
		gap: 12px;
	}

	.guide-carousel-arrow {
		width: 52px;
		height: 52px;
		border-radius: 999px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		background: rgba(255, 255, 255, 0.1);
		color: #fff;
		font-weight: 950;
		font-size: 1.1rem;
		cursor: pointer;
	}

	.guide-carousel-track {
		display: grid;
		grid-auto-flow: column;
		grid-auto-columns: minmax(420px, 520px);
		gap: 18px;
		overflow-x: auto;
		overflow-y: hidden;
		scroll-snap-type: x mandatory;
		scroll-behavior: smooth;
		padding-bottom: 8px;
