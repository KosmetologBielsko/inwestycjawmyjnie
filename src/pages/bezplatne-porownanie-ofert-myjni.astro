---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/bezplatne-porownanie-ofert-myjni/',
	title: 'Bezpłatna analiza działki i porównanie ofert myjni bezdotykowej',
	description:
		'Bezpłatna analiza działki i porównanie ofert myjni bezdotykowej w jednym formularzu. Sprawdź lokalizację, założenia inwestycji, zakres, technologię, cenę, serwis i dokumentację.'
};

const comparisonCards = [
	{
		number: '01',
		title: 'Cena i zakres',
		text: 'Porównujemy, co realnie obejmuje oferta: technologię, kontener lub moduł, posadzkę, konstrukcję, montaż, dokumentację, szkolenie i serwis.'
	},
	{
		number: '02',
		title: 'Technologia i jakość',
		text: 'Patrzymy na elementy, które wpływają na pracę myjni przez lata: pompy, zawory, automatykę, dozowanie, uzdatnianie wody i zabezpieczenia zimowe.'
	},
	{
		number: '03',
		title: 'Koszty eksploatacji',
		text: 'Najtańsza cena zakupu nie zawsze oznacza najniższy koszt prowadzenia. Ważne są media, serwis, części, chemia i czas przestoju.'
	},
	{
		number: '04',
		title: 'Dopasowanie do inwestora',
		text: 'Inna oferta ma sens dla inwestora z własną działką, inna dla dzierżawy, finansowania leasingiem, kilku lokalizacji albo pierwszej małej inwestycji.'
	}
];

const processSteps = [
	['01', 'Opisujesz działkę i założenia', 'Podajesz lokalizację, status działki, media, liczbę stanowisk, budżet, finansowanie i oczekiwany zakres myjni.'],
	['02', 'Porządkujemy temat inwestycji', 'Na podstawie formularza łatwiej przygotować porównywalne zapytanie ofertowe dla polskich dostawców myjni.'],
	['03', 'Łatwiej porównujesz odpowiedzi', 'Dzięki uporządkowanym założeniom szybciej zobaczysz różnice w cenie, zakresie, technologii, serwisie i kosztach po uruchomieniu.']
];

const faqItems = [
	{
		question: 'Czy analiza działki i porównanie ofert jest bezpłatne?',
		answer:
			'Tak. Wstępna analiza lokalizacji, uporządkowanie zapytania i porównanie zakresu ofert jest bezpłatne. Chodzi o sprawdzenie, czy działka, budżet i proponowane rozwiązanie tworzą realny kierunek inwestycji.'
	},
	{
		question: 'Czy muszę mieć już działkę albo ofertę od producenta?',
		answer:
			'Nie. Możesz mieć działkę, link do mapy, numer działki, konkretną ofertę, kilka ofert albo dopiero wstępny plan inwestycji. W każdym przypadku warto uporządkować dane przed rozmową z producentami.'
	},
	{
		question: 'Czy porównanie dotyczy tylko ceny?',
		answer:
			'Nie. Sama cena jest tylko jednym z elementów. Ważny jest zakres, technologia, posadzka, dokumentacja, warunki umowy, gwarancja, serwis, części, chemia i koszty eksploatacji.'
	},
	{
		question: 'Czy możecie pomóc pozyskać oferty od polskich dostawców?',
		answer:
			'Tak. Po wypełnieniu formularza możemy pomóc uporządkować założenia inwestycji i przygotować porównywalne zapytanie do polskich dostawców myjni. Dzięki temu inwestor nie porównuje przypadkowych cen, tylko bardziej doprecyzowany zakres.'
	}
];

const relatedLinks = [
	['Koszt budowy myjni', '/ile-kosztuje-myjnia-bezdotykowa/'],
	['Ile zarabia myjnia?', '/ile-zarabia-myjnia-bezdotykowa/'],
	['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Budowa krok po kroku', '/budowa-myjni-bezdotykowej-krok-po-kroku/'],
	['Błędy inwestora', '/najczestsze-bledy-przy-budowie-myjni/'],
	['Poradnik inwestora', '/poradnik/']
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};
---

<Layout title={page.title} description={page.description} canonicalPath={page.canonicalPath}>
	<Header />

	<main class="lead-page lead-compare-page">
		<section class="lead-hero" aria-labelledby="page-title">
			<div class="container lead-hero-grid">
				<div class="lead-hero-copy">
					<p class="eyebrow"><span></span>Bezpłatna analiza i porównanie ofert myjni</p>
					<h1 id="page-title">
						Sprawdź działkę i porównaj oferty myjni <strong>w jednym formularzu.</strong>
					</h1>
										<p class="lead-main-text">
						Wypełnij formularz, a pomożemy bezpłatnie uporządkować założenia inwestycji
						i przygotować temat do pozyskania porównywalnych ofert od polskich dostawców
						myjni. Dzięki temu szybciej zobaczysz, co realnie jest w cenie, czego brakuje
						w zakresie i które rozwiązanie pasuje do Twojej działki, budżetu oraz modelu inwestycji.
					</p>
					<div class="lead-hero-actions">
											<a class="lead-button-green" href="#formularz">Wypełnij formularz i porównaj oferty <span aria-hidden="true">↓</span></a>
						<a class="lead-button-light" href="/jak-porownac-oferty-myjni-bezdotykowej/">Jak porównywać oferty? <span aria-hidden="true">→</span></a>
					</div>
										<div class="lead-tags" aria-label="Najważniejsze elementy porównania">
						<span>działka</span>
						<span>media</span>
						<span>oferty</span>
						<span>finansowanie</span>
					</div>

																				<aside class="lead-side-summary" aria-label="Dlaczego warto wypełnić formularz">
						<div class="lead-side-summary-card lead-side-summary-main">
							<p>Porównanie ofert</p>
							<h2>Zainwestuj w myjnię w Polsce z lepiej uporządkowanymi założeniami.</h2>
							<span>
								Wypełnij formularz, a pomożemy bezpłatnie uporządkować lokalizację, budżet,
								media, liczbę stanowisk i zakres technologii. Dzięki temu łatwiej pozyskać
								doprecyzowane, porównywalne oferty od polskich dostawców myjni.
							</span>
						</div>

						<div class="lead-side-checklist">
							<div>
								<b>01</b>
								<span>100% online — bez spotkania na start i bez zobowiązań</span>
							</div>

							<div>
								<b>02</b>
								<span>Porządkujemy dane działki, budżetu, mediów i liczby stanowisk</span>
							</div>

							<div>
								<b>03</b>
								<span>Pomagamy przygotować zapytanie, które dostawca może realnie wycenić</span>
							</div>

							<div>
								<b>04</b>
								<span>Ułatwiamy porównanie ofert pod kątem zakresu, technologii i serwisu</span>
							</div>
						</div>

						<div class="lead-side-summary-card">
							<p>Dlaczego to ważne?</p>
							<h2>Przypadkowe oferty często nie są porównywalne.</h2>
							<span>
								Jeden dostawca może wycenić samą technologię, drugi technologię z kontenerem,
								trzeci inny zakres posadzki, dokumentacji, montażu albo serwisu. Formularz
								pomaga uporządkować dane tak, żeby porównanie było uczciwsze i bardziej czytelne.
							</span>
						</div>

						<div class="lead-side-checklist">
							<div>
								<b>05</b>
								<span>Sprawdzisz, co realnie jest w cenie, a czego może brakować</span>
							</div>

							<div>
								<b>06</b>
								<span>Łatwiej dopasujesz wariant myjni do działki i modelu finansowania</span>
							</div>

							<div>
								<b>07</b>
								<span>Zobaczysz różnice między ceną zakupu a kosztem prowadzenia obiektu</span>
							</div>

							<div>
								<b>08</b>
								<span>Możesz dołączyć ofertę, screen, link do pliku albo opis planowanej inwestycji</span>
							</div>
						</div>

						<div class="lead-side-summary-card lead-side-summary-main">
							<p>Dla inwestora</p>
							<h2>Praktyczny poradnik i formularz porównania ofert myjni.</h2>
							<span>
								To miejsce dla osób, które chcą zbudować myjnię bezdotykową w Polsce i nie chcą
								opierać decyzji wyłącznie na pierwszej cenie z PDF-a. Najpierw porządkujemy
								założenia, potem łatwiej rozmawiać o realnych ofertach.
							</span>
						</div>

						<div class="lead-side-links">
							<p>Warto przeczytać</p>

							<a href="/dzialka-pod-myjnie-bezdotykowa/">
								Działka pod myjnię
								<span aria-hidden="true">→</span>
							</a>

							<a href="/jak-porownac-oferty-myjni-bezdotykowej/">
								Jak porównać oferty?
								<span aria-hidden="true">→</span>
							</a>

							<a href="/koszt-budowy-myjni-bezdotykowej/">
								Koszt budowy myjni
								<span aria-hidden="true">→</span>
							</a>
						</div>
					</aside>
				</div>

				<aside class="lead-form-card" id="formularz" aria-label="Formularz analizy działki i porównania ofert">
					<div class="lead-form-head">
						<p>Formularz</p>
						<h2>Bezpłatna analiza i porównanie ofert myjni</h2>
						<span>
							Podaj dane kontaktowe, lokalizację, status działki, media i założenia myjni.
							Na tej podstawie pomożemy bezpłatnie uporządkować inwestycję i przygotować
							porównywalne zapytanie do polskich dostawców myjni.
						</span>
					</div>

					<p class="required-form-note">
						100% online. Bez zobowiązań. Wszystkie pola formularza są wymagane poza polem
						opisu oraz opcjonalnym załącznikiem. Możesz dodać plik PDF, JPG, PNG, WEBP,
						DOCX albo XLSX do 4 MB.
					</p>

					<p class="required-fields-legend">
						<span>*</span> Pola i zgody oznaczone gwiazdką są obowiązkowe, żeby wysłać formularz.
					</p>

					<form
						class="smart-form"
						data-lead-form
						method="post"
						action="/api/wyslij-analize"
						enctype="multipart/form-data"
					>
						<input type="hidden" name="typ_zapytania" value="Bezpłatna analiza działki i porównanie ofert myjni" />
						<input type="hidden" name="administrator_danych" value="BPHM Sp. z o.o., ul. Norberta Barlickiego 5, 43-300 Bielsko-Biała, KRS 0001247373, NIP 5472260567, REGON 544990435" />
						<input type="hidden" name="email_administratora" value="analiza@inwestycjawmyjnie.pl" />
						<input type="hidden" name="cel_przekazania_danych" value="Bezpłatna analiza zgłoszenia, uporządkowanie założeń inwestycji i przygotowanie porównywalnego zapytania do polskich dostawców myjni" />

						<div class="form-section-title full">
							<span>01</span>
							<strong>Dane kontaktowe</strong>
						</div>

						<label>
							Imię i nazwisko
							<input type="text" name="name" placeholder="Twoje imię i nazwisko" autocomplete="name" required />
						</label>

						<label>
							Telefon
							<input type="tel" name="phone" placeholder="Numer telefonu" autocomplete="tel" required />
						</label>

						<label>
							E-mail
							<input type="email" name="email" placeholder="Twój adres e-mail" autocomplete="email" required />
						</label>

						<label>
							Forma działalności
							<select name="business_form" required>
								<option value="">Wybierz</option>
								<option>Działalność gospodarcza</option>
								<option>Spółka z o.o.</option>
								<option>Spółka cywilna</option>
								<option>Osoba prywatna przed założeniem działalności</option>
								<option>Inna forma</option>
							</select>
						</label>

						<div class="form-section-title full">
							<span>02</span>
							<strong>Lokalizacja inwestycji</strong>
						</div>

						<label>
							Województwo inwestycji
							<select name="voivodeship" required>
								<option value="">Wybierz województwo</option>
								<option>dolnośląskie</option>
								<option>kujawsko-pomorskie</option>
								<option>lubelskie</option>
								<option>lubuskie</option>
								<option>łódzkie</option>
								<option>małopolskie</option>
								<option>mazowieckie</option>
								<option>opolskie</option>
								<option>podkarpackie</option>
								<option>podlaskie</option>
								<option>pomorskie</option>
								<option>śląskie</option>
								<option>świętokrzyskie</option>
								<option>warmińsko-mazurskie</option>
								<option>wielkopolskie</option>
								<option>zachodniopomorskie</option>
							</select>
						</label>

						<label>
							Powiat
							<input type="text" name="county" placeholder="Np. głubczycki" required />
						</label>

						<label>
							Gmina
							<input type="text" name="municipality" placeholder="Np. Branice" required />
						</label>

						<label>
							Miasto / miejscowość
							<input type="text" name="city" placeholder="Gdzie planujesz inwestycję?" required />
						</label>

						<label>
							Kod pocztowy inwestycji
							<input type="text" name="postal_code" placeholder="Np. 48-140" inputmode="numeric" required />
						</label>

						<label>
							Status posiadania działki
							<select name="plot_status" required>
								<option value="">Wybierz</option>
								<option>Własność</option>
								<option>Dzierżawa</option>
								<option>Umowa przedwstępna / w trakcie zakupu</option>
								<option>Jeszcze szukam działki</option>
								<option>Nie wiem / do ustalenia</option>
							</select>
						</label>

						<fieldset class="compare-options media-options full" data-required-group="media">
							<legend>Media na działce albo w pobliżu</legend>
							<label><input type="checkbox" name="media_water" /> Woda</label>
							<label><input type="checkbox" name="media_gas" /> Gaz</label>
							<label><input type="checkbox" name="media_power" /> Prąd</label>
							<label><input type="checkbox" name="media_sewage" /> Kanalizacja</label>
							<label><input type="checkbox" name="media_rainwater" /> Deszczówka / odwodnienie</label>
							<label><input type="checkbox" name="media_none" /> Brak / do sprawdzenia</label>
						</fieldset>

						<div class="form-section-title full">
							<span>03</span>
							<strong>Założenia myjni i finansowanie</strong>
						</div>

						<label>
							Typ myjni
							<select name="wash_type" required>
								<option value="">Wybierz typ</option>
								<option>Bezdotykowa kontenerowa</option>
								<option>Bezdotykowa modułowa</option>
								<option>Bezdotykowa — nie wiem, chcę porównać</option>
								<option>Myjnia z dodatkową strefą SPA</option>
								<option>Inny wariant / do ustalenia</option>
							</select>
						</label>

						<label>
							Liczba stanowisk
							<select name="stations" required>
								<option value="">Wybierz</option>
								<option>Nie wiem / do ustalenia</option>
								<option>2 stanowiska</option>
								<option>3 stanowiska</option>
								<option>4 stanowiska</option>
								<option>5 stanowisk</option>
								<option>6 stanowisk</option>
							</select>
						</label>

						<label>
							Stanowisko niezadaszone BUS/TIR do 3,5 t
							<select name="open_bay" required>
								<option value="">Wybierz</option>
								<option>Tak</option>
								<option>Nie</option>
								<option>Do ustalenia</option>
							</select>
						</label>

						<label>
							Budżet orientacyjny
							<select name="budget" required>
								<option value="">Wybierz zakres</option>
								<option>do 500 tys. zł netto</option>
								<option>500–700 tys. zł netto</option>
								<option>700 tys.–1 mln zł netto</option>
								<option>1–1,5 mln zł netto</option>
								<option>powyżej 1,5 mln zł netto</option>
								<option>Nie wiem / chcę policzyć</option>
							</select>
						</label>

						<label>
							Akceptacja przybliżonych kosztów
							<select name="cost_acceptance" required>
								<option value="">Wybierz</option>
								<option>Tak — znam orientacyjne koszty inwestycji</option>
								<option>Nie — potrzebuję wyjaśnienia kosztów</option>
								<option>Częściowo — mam wstępny budżet</option>
							</select>
						</label>

						<label>
							Finansowanie
							<select name="financing" required>
								<option value="">Wybierz</option>
								<option>Środki własne</option>
								<option>Leasing</option>
								<option>Kredyt</option>
								<option>Gotówka + kredyt / leasing</option>
								<option>Około 60% gotówka + finansowanie</option>
								<option>Jeszcze nie wiem</option>
							</select>
						</label>

						<fieldset class="compare-options full" data-required-group="compare">
							<legend>Co chcesz sprawdzić?</legend>
							<label><input type="checkbox" name="compare_price" /> Cena i zakres oferty</label>
							<label><input type="checkbox" name="compare_technology" /> Technologia myjni</label>
							<label><input type="checkbox" name="compare_service" /> Serwis i gwarancja</label>
							<label><input type="checkbox" name="compare_contract" /> Dokumentacja i umowa</label>
						</fieldset>

						<label class="full">
	Link do oferty / link do mapy / opis inwestycji
	<textarea name="message" rows="5" placeholder="Wklej link do oferty, link do mapy, numer działki, opisz planowaną myjnię albo napisz, czego oczekujesz od producenta..."></textarea>
</label>

<label class="full file-upload-field">
	<span class="file-label-row">
		Załącz ofertę lub plik  pomocniczy
		<em>opcjonalnie</em>
	</span>

	<input
		type="file"
		name="offer_file"
		accept=".pdf,.jpg,.jpeg,.png,.webp,.docx,.xlsx,application/pdf,image/jpeg,image/png,image/webp,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet"
		data-offer-file
	/>

	<small>
		Dozwolone formaty: PDF, JPG, PNG, WEBP, DOCX, XLSX. Maksymalnie 4 MB.
		Jeżeli plik jest większy, wklej link do Dysku Google, OneDrive albo Dropbox w polu opisu.
	</small>
</label>

						<div class="form-consents full">
							<label class="checkbox-label">
								<input type="checkbox" name="contact_consent" required />
								<span>
									<strong>Wymagane.</strong>
									Zlecam bezpłatną analizę zgłoszenia i wyrażam zgodę na kontakt telefoniczny
									lub e-mailowy w sprawie inwestycji, działki, porównania ofert oraz dalszej
									obsługi zapytania.
								</span>
							</label>

							<label class="checkbox-label">
								<input type="checkbox" name="supplier_transfer_consent" required />
								<span>
									<strong>Wymagane.</strong>
									Rozumiem i akceptuję, że moje dane kontaktowe oraz informacje podane w formularzu
									mogą zostać przekazane wybranym dostawcom, producentom lub partnerom technologicznym
									myjni w celu przygotowania dopasowanej oferty, kontaktu handlowego i porównania
									rozwiązań dla mojej inwestycji.
								</span>
							</label>

							<label class="checkbox-label">
								<input type="checkbox" name="privacy_consent" required />
								<span>
									<strong>Wymagane.</strong>
									Oświadczam, że zapoznałem się z
									<a href="/polityka-prywatnosci/" target="_blank" rel="noopener noreferrer">Polityką prywatności i RODO</a>,
									<a href="/polityka-cookies/" target="_blank" rel="noopener noreferrer">Polityką cookies</a>
									oraz
									<a href="/zasady-korzystania/" target="_blank" rel="noopener noreferrer">Zasadami korzystania z formularza</a>.
									Wiem, że administratorem danych jest BPHM Sp. z o.o. i że mogę żądać dostępu
									do danych, sprostowania, usunięcia, ograniczenia przetwarzania oraz wycofania
									zgody w zakresie, w jakim przetwarzanie odbywa się na podstawie zgody.
								</span>
							</label>

							<label class="checkbox-label">
								<input type="checkbox" name="marketing_consent" />
								<span>
									<strong>Opcjonalnie.</strong>
