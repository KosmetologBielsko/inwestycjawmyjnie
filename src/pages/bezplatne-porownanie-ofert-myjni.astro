	<script>
		const formElement = document.querySelector('[data-lead-form]');
		const formStatusElement = document.querySelector('[data-form-status]');
		const fileInputElement = document.querySelector('[data-offer-file]');

		const allowedFileExtensions = ['pdf', 'jpg', 'jpeg', 'png', 'webp', 'docx', 'xlsx'];
		const maxFileSize = 4 * 1024 * 1024;

		function setFormStatus(message, type = '') {
			if (!(formStatusElement instanceof HTMLElement)) return;

			formStatusElement.textContent = message;
			formStatusElement.classList.remove('is-success', 'is-error');

			if (type) {
				formStatusElement.classList.add(type);
			}
		}

		if (formElement instanceof HTMLFormElement) {
			formElement.addEventListener('submit', async (event) => {
				event.preventDefault();

				const submitButton = formElement.querySelector('button[type="submit"]');
				const requiredGroups = formElement.querySelectorAll('[data-required-group]');
				let groupValid = true;
				let firstInvalidGroup = null;

				if (fileInputElement instanceof HTMLInputElement && fileInputElement.files && fileInputElement.files.length > 0) {
					const selectedFile = fileInputElement.files[0];
					const fileName = selectedFile.name.toLowerCase();
					const fileExtension = fileName.includes('.') ? fileName.split('.').pop() : '';

					if (!fileExtension || !allowedFileExtensions.includes(fileExtension)) {
						setFormStatus('Załącznik ma niedozwolony format. Dodaj plik PDF, JPG, PNG, WEBP, DOCX albo XLSX.', 'is-error');
						fileInputElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
						return;
					}

					if (selectedFile.size > maxFileSize) {
						setFormStatus('Załącznik jest za duży. Maksymalny rozmiar pliku to 4 MB. Przy większym pliku wklej link w polu opisu.', 'is-error');
						fileInputElement.scrollIntoView({ behavior: 'smooth', block: 'center' });
						return;
					}
				}

				requiredGroups.forEach((group) => {
					const checked = group.querySelector('input[type="checkbox"]:checked');
					group.classList.toggle('is-invalid', !checked);

					if (!checked) {
						groupValid = false;

						if (firstInvalidGroup === null) {
							firstInvalidGroup = group;
						}
					}
				});

				if (!groupValid) {
					setFormStatus('Zaznacz przynajmniej jedną opcję w sekcji media oraz jedną opcję w sekcji, co chcesz sprawdzić.', 'is-error');

					if (firstInvalidGroup instanceof HTMLElement) {
						firstInvalidGroup.scrollIntoView({ behavior: 'smooth', block: 'center' });
					}

					return;
				}

				const requiredConsentInputs = formElement.querySelectorAll('.form-consents input[required]');
				const consentRequiredNote = formElement.querySelector('[data-consent-required-note]');
				let requiredConsentsValid = true;

				requiredConsentInputs.forEach((input) => {
					if (input instanceof HTMLInputElement && !input.checked) {
						requiredConsentsValid = false;
					}
				});

				if (!requiredConsentsValid) {
					if (consentRequiredNote instanceof HTMLElement) {
						consentRequiredNote.classList.add('is-visible');
					}

					setFormStatus('Aby wysłać formularz, zaznacz wszystkie wymagane zgody.', 'is-error');

					const firstRequiredConsent = formElement.querySelector('.form-consents input[required]:not(:checked)');

					if (firstRequiredConsent instanceof HTMLElement) {
						firstRequiredConsent.scrollIntoView({ behavior: 'smooth', block: 'center' });
						firstRequiredConsent.focus();
					}

					return;
				}

				if (consentRequiredNote instanceof HTMLElement) {
					consentRequiredNote.classList.remove('is-visible');
				}

				if (!formElement.checkValidity()) {
					formElement.reportValidity();
					setFormStatus('Uzupełnij wymagane pola i zaznacz wymagane zgody.', 'is-error');
					return;
				}

				const formData = new FormData(formElement);
				formData.append('page_url', window.location.href);
				formData.append('sent_at', new Date().toISOString());

				try {
					if (submitButton instanceof HTMLButtonElement) {
						submitButton.disabled = true;
						submitButton.dataset.originalText = submitButton.innerHTML;
						submitButton.innerHTML = 'Wysyłanie formularza...';
					}

					setFormStatus('Wysyłamy formularz na analiza@inwestycjawmyjnie.pl...', '');

					const response = await fetch(formElement.action || '/api/wyslij-analize', {
						method: 'POST',
						body: formData
					});

					const result = await response.json().catch(() => ({
						message: 'Nie udało się odczytać odpowiedzi serwera.'
					}));

					if (!response.ok || !result.ok) {
						throw new Error(result.message || 'Nie udało się wysłać formularza.');
					}

					formElement.reset();
					setFormStatus(result.message || 'Dziękujemy. Formularz został wysłany.', 'is-success');
				} catch (error) {
					setFormStatus(
						error instanceof Error
							? error.message
							: 'Nie udało się wysłać formularza. Spróbuj ponownie albo napisz na analiza@inwestycjawmyjnie.pl.',
						'is-error'
					);
				} finally {
					if (submitButton instanceof HTMLButtonElement) {
						submitButton.disabled = false;
						submitButton.innerHTML =
							submitButton.dataset.originalText ||
							'Wyślij i rozpocznij bezpłatne porównanie <span aria-hidden="true">→</span>';
					}
				}
			});
		}
	</script>

