<script is:inline>
	const mistakeCarousels = document.querySelectorAll('[data-mistake-carousel]');

	mistakeCarousels.forEach((carousel) => {
		const track = carousel.querySelector('[data-mistake-track]');
		const prev = carousel.querySelector('[data-mistake-prev]');
		const next = carousel.querySelector('[data-mistake-next]');

		if (!track || !prev || !next) return;

		const getStep = () => {
			const firstCard = track.querySelector('.mistake-slide');
			if (!firstCard) return 360;
			const styles = window.getComputedStyle(track);
			const gap = parseFloat(styles.columnGap || styles.gap || '18');
			return firstCard.getBoundingClientRect().width + gap;
		};

		prev.addEventListener('click', () => {
			track.scrollBy({ left: -getStep(), behavior: 'smooth' });
		});

		next.addEventListener('click', () => {
			track.scrollBy({ left: getStep(), behavior: 'smooth' });
		});
	});
</script>
