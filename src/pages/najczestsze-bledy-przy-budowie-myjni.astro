---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/najczestsze-bledy-przy-budowie-myjni/',
	title: 'Najczęstsze błędy przy budowie myjni bezdotykowej',
	description:
		'Najczęstsze błędy przy budowie myjni bezdotykowej: działka bez analizy, porównywanie tylko ceny, zła liczba stanowisk, brak rezerwy, media, wjazd, umowa, dokumentacja i serwis.'
};

const heroChips = [
	'działka',
	'cena',
	'stanowiska',
	'budżet',
	'PZT',
	'serwis'
];

const mistakeCards = [
	{
		number: '01',
		title: 'Wybór działki bez analizy',
		text: 'Działka może wyglądać atrakcyjnie, ale mieć problemy formalne, techniczne albo ekonomiczne: brak możliwości budowy myjni, brak mediów, kolizje sieci, trudny zjazd, sąsiedztwo albo zbyt słaby potencjał ruchu.'
	},
	{
		number: '02',
		title: 'Porównywanie tylko ceny',
		text: 'Zbieranie wielu ofert bez analizy potrzeb tworzy chaos. Najniższa cena może przysłonić realne ryzyka: słabszą technologię, gorszy serwis, uboższą dokumentację i wyższe koszty późniejszej eksploatacji.'
	},
	{
		number: '03',
		title: 'Zła liczba stanowisk',
		text: 'Za mała myjnia w mocnej lokalizacji tworzy kolejki i blokuje przychód. Za duża myjnia w słabej lokalizacji podnosi koszt inwestycji bez odpowiedniego obrotu.'
	},
	{
		number: '04',
		title: 'Brak rezerwy budżetowej',
		text: 'Brak zapasu pieniędzy prowadzi do pochopnych oszczędności na technologii, programach, projekcie albo wykończeniu. Zimą wyższe koszty i słabszy sezon mogą dodatkowo obciążyć inwestora.'
	},
	{
		number: '05',
		title: 'Niedoszacowanie mediów',
		text: 'Woda, ścieki, prąd, gaz, deszczówka, przyłącza, moc elektryczna, separator i odprowadzenie wód potrafią zmienić budżet oraz przyszłą rentowność myjni.'
	},
	{
		number: '06',
		title: 'Zły wjazd i wyjazd',
		text: 'Niewygodna komunikacja odstrasza kierowców. Brak dobrego PZT powoduje problemy z kolejką, zawracaniem, ruchem SUV-ów, busów i aut prowadzonych przez mniej doświadczonych kierowców.'
	},
	{
		number: '07',
		title: 'Brak analizy konkurencji',
		text: 'Konkurencja nie zawsze jest zła. Może pokazywać zapotrzebowanie, ale trzeba sprawdzić standard, lokalizację, kolejki, ceny, opinie i pytania, które warto zadać własnemu dostawcy.'
	},
	{
		number: '08',
		title: 'Słaba umowa',
		text: 'Rozmowa z handlowcem to jedno, a zapisy umowy to drugie. Trzeba sprawdzić zakres, terminy, płatności, odbiory, odpowiedzialność, gwarancję i możliwość finansowania.'
	},
	{
		number: '09',
		title: 'Brak projektu technicznego',
		text: 'Minimum dokumentacji może wystarczyć do startu procedury, ale nie zawsze porządkuje instalacje, konstrukcję i późniejsze odbiory. Pełniejszy projekt techniczny jest realną wartością inwestycji.'
	},
	{
		number: '10',
		title: 'Brak myślenia o serwisie',
		text: 'Serwis jest jednym z najważniejszych elementów po sprzedaży. W pierwszych latach inwestor uczy się myjni, obsługi i reakcji na problemy. Dobry serwis daje bezpieczeństwo i skraca przestoje.'
	}
];

const riskSlides = [
	{
		kicker: 'Działka',
		title: 'Tani grunt może być najdroższym błędem',
		text: 'Brak MPZP, niepewna WZ, kolizje sieci, brak mediów albo problem ze zjazdem mogą zatrzymać inwestycję jeszcze przed budową.'
	},
	{
		kicker: 'Oferta',
		title: 'Niska cena nie oznacza niskiego kosztu',
		text: 'Różnica w zakupie może wrócić w eksploatacji: mediach, serwisie, awariach, dokumentacji, częściach i przestojach.'
	},
	{
		kicker: 'Przepustowość',
		title: 'Kolejka potrafi zabrać przychód',
		text: 'Myjnia pracuje falami. Jeżeli liczba stanowisk i układ ruchu nie pasują do lokalizacji, kierowcy mogą odjeżdżać do konkurencji.'
	},
	{
		kicker: 'Serwis',
		title: 'Myjnia zarabia tylko wtedy, kiedy pracuje',
		text: 'Długi czas reakcji, brak części albo trudny dostęp do technologii może być droższy niż różnica między ofertami.'
	}
];

const landRisks = [
	['Formalne', 'Brak właściwego przeznaczenia terenu, problem z MPZP, niepewna WZ, ograniczenia planistyczne, sąsiedztwo lub zapisy uniemożliwiające budowę myjni.'],
	['Techniczne', 'Brak wody, kanalizacji, prądu, gazu, deszczówki, problem z mocą przyłączeniową, kolizje typu światłowód, gazociąg, sieci podziemne, tory albo pas drogowy.'],
	['Ekonomiczne', 'Słaby ruch, brak widoczności, mało mieszkańców w promieniu oddziaływania, zły dojazd, niska siła zakupowa albo brak naturalnych generatorów ruchu.']
];

const stationCards = [
	{
		title: 'Za mało stanowisk',
		text: 'W mocnej lokalizacji zbyt mała liczba stanowisk powoduje kolejki, zatory i utratę klientów. Kierowca często wybiera obiekt, na którym nie musi czekać.'
	},
	{
		title: 'Za dużo stanowisk',
		text: 'W słabszej lokalizacji zbyt duży obiekt podnosi koszt budowy, serwisu, ogrzewania i utrzymania, ale nie zawsze zwiększa proporcjonalnie przychód.'
	},
	{
		title: 'Zły układ stanowisk',
		text: 'Liczy się nie tylko liczba stanowisk, ale też przepustowość, czas mycia, dostęp do programów, kolejka, promienie skrętu, strefa sucha i wygodny wyjazd.'
	}
];

const budgetItems = [
	['Rezerwa inwestycyjna', 'Projekt, media, przyłącza, roboty ziemne, zjazd, separator, deszczówka i nieprzewidziane kolizje wymagają zapasu budżetu.'],
	['Sezonowość', 'Zima, koszt ogrzewania, słabsze okresy i zmienność pogody mogą wpływać na przepływy finansowe szczególnie na początku działalności.'],
	['Technologia', 'Oszczędzanie na technologii może obniżyć koszt zakupu, ale zwiększyć koszt użytkowania: wodę, ścieki, energię, chemię, awaryjność i czas serwisu.'],
	['Finansowanie', 'Leasing, kredyt, harmonogram płatności i wkład własny trzeba zestawić z rezerwą operacyjną, a nie tylko z ceną zakupu myjni.']
];

const serviceCards = [
	{
		title: 'Serwis jako bezpieczeństwo biznesu',
		text: 'W pierwszych latach inwestor uczy się technologii, chemii, ustawień, programów i reakcji na zgłoszenia klientów. Dobry serwisant jest wtedy realnym wsparciem, a nie dodatkiem do gwarancji.'
	},
	{
		title: 'Czas reakcji i dostęp do części',
		text: 'Przestój stanowiska oznacza utratę przychodu. Dlatego trzeba sprawdzić czas reakcji, dostępność części, akcesoriów, chemii, procedurę zgłoszeń i zasady obsługi pogwarancyjnej.'
	},
	{
		title: 'Ergonomia technologii',
		text: 'Tańszy wariant może być droższy w serwisie, jeśli każda naprawa wymaga rozbierania modułów albo długiego dojścia do pomp, zaworów, sterowania i dozowania.'
	}
];

const checklistGroups = [
	{
		title: 'Przed zakupem działki',
		items: [
			'czy działka ma MPZP albo realną szansę na WZ?',
			'czy teren dopuszcza funkcję usługową i myjnię samochodową?',
			'czy są media i możliwość odprowadzenia ścieków oraz deszczówki?',
			'czy zjazd, wjazd i wyjazd są możliwe oraz wygodne?',
			'czy nie ma kolizji z sieciami, torami, gazem, światłowodem albo pasem drogowym?'
		]
	},
	{
		title: 'Przed wyborem producenta',
		items: [
			'czy oferta pokazuje zakres, a nie tylko cenę?',
			'czy producent pomaga ocenić lokalizację i liczbę stanowisk?',
			'czy technologia wpływa na oszczędność wody, ścieków, energii i chemii?',
			'czy serwis, części i gwarancja są jasno opisane?',
			'czy dokumentacja obejmuje więcej niż minimum do pozwolenia na budowę?'
		]
	},
	{
		title: 'Przed podpisaniem umowy',
		items: [
			'czy zapisy umowy potwierdzają rozmowy handlowe?',
			'czy są jasne terminy, etapy płatności, odbiory i odpowiedzialność?',
			'czy możliwe jest finansowanie, leasing albo umowa trójstronna?',
			'czy inwestor zna warunki gwarancji i wyłączenia?',
			'czy wiadomo, kto odpowiada za problemy po montażu?'
		]
	}
];

const faqItems = [
	{
		question: 'Jaki jest najczęstszy błąd przy budowie myjni bezdotykowej?',
		answer:
			'Najczęściej problem zaczyna się od decyzji bez analizy: zakup działki bez sprawdzenia MPZP/WZ, mediów, zjazdu, kolizji, konkurencji i realnego potencjału ekonomicznego lokalizacji.'
	},
	{
		question: 'Czy najtańsza oferta na myjnię jest dobrym wyborem?',
		answer:
			'Nie zawsze. Najtańsza oferta może mieć mniejszy zakres, słabszą technologię, trudniejszy serwis, mniej dokumentacji albo wyższe koszty eksploatacji po uruchomieniu.'
	},
	{
		question: 'Dlaczego liczba stanowisk jest tak ważna?',
		answer:
			'Liczba stanowisk musi pasować do lokalizacji, ruchu, działki i przepustowości. Za mała myjnia tworzy kolejki, a za duża może zwiększyć koszt bez odpowiedniego przychodu.'
	},
	{
		question: 'Dlaczego potrzebna jest rezerwa budżetowa?',
		answer:
			'Budowa myjni zależy od działki, mediów, robót ziemnych, przyłączy, dokumentacji i sezonowości. Rezerwa chroni przed pochopnymi oszczędnościami oraz problemami w pierwszych miesiącach pracy.'
	},
	{
		question: 'Czy konkurencja w okolicy jest problemem?',
		answer:
			'Nie zawsze. Konkurencja może potwierdzać zapotrzebowanie na usługę, ale trzeba sprawdzić jej standard, lokalizację, kolejki, opinie, ceny i to, czy nowa myjnia może dać klientowi lepszą wygodę.'
	},
	{
		question: 'Co sprawdzić w umowie z producentem?',
		answer:
			'Trzeba sprawdzić zakres, terminy, harmonogram płatności, warunki odbioru, odpowiedzialność, gwarancję, serwis, części, szkolenie i to, czy ustalenia z rozmów handlowych są wpisane w dokumenty.'
	},
	{
		question: 'Dlaczego serwis jest tak ważny po zakupie myjni?',
		answer:
			'Myjnia zarabia wtedy, kiedy pracuje. Dobry serwis skraca przestoje, pomaga inwestorowi uczyć się obsługi, wspiera w awariach i daje poczucie, że inwestor nie zostaje sam po uruchomieniu obiektu.'
	},
	{
		question: 'Czy projekt techniczny jest potrzebny?',
		answer:
			'Projekt techniczny porządkuje instalacje, konstrukcję i rozwiązania branżowe. Jego brak może utrudniać rozliczanie prac, odbiory oraz późniejsze uporządkowanie dokumentacji inwestycji.'
	}
];

const relatedLinks = [
	['Koszt budowy myjni', '/koszt-budowy-myjni-bezdotykowej/'],
	['Ile kosztuje myjnia?', '/ile-kosztuje-myjnia-bezdotykowa/'],
	['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Jak porównać oferty?', '/jak-porownac-oferty-myjni-bezdotykowej/'],
	['Budowa krok po kroku', '/budowa-myjni-bezdotykowej-krok-po-kroku/'],
	['Poradnik inwestora', '/poradnik/']
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};

const breadcrumbs = [
	{
		name: 'Strona główna',
		path: '/'
	},
	{
		name: 'Poradnik inwestora',
		path: '/poradnik/'
	},
	{
		name: 'Błędy przy budowie myjni',
		path: page.canonicalPath
	}
];

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: page.title,
	description: page.description,
	url: `https://inwestycjawmyjnie.pl${page.canonicalPath}`,
	inLanguage: 'pl-PL',
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': `https://inwestycjawmyjnie.pl${page.canonicalPath}`
	},
	author: {
		'@type': 'Organization',
		name: 'inwestycjawmyjnie.pl',
		url: 'https://inwestycjawmyjnie.pl'
	},
	publisher: {
		'@type': 'Organization',
		name: 'inwestycjawmyjnie.pl',
		url: 'https://inwestycjawmyjnie.pl'
	}
};

---

<Layout
	title={page.title}
	description={page.description}
	canonicalPath={page.canonicalPath}
	ogType="article"
	breadcrumbs={breadcrumbs}
	structuredData={[faqSchema, articleSchema]}
>
	<Header />

	<main class="mistake-page">
		<section class="mistake-hero" aria-labelledby="page-title">
			<div class="container mistake-hero-grid">
				<div class="mistake-hero-copy">
					<p class="eyebrow">
						<span></span>
						Błędy inwestora
					</p>

					<h1 id="page-title">
						Najczęstsze błędy przy budowie myjni, które mogą kosztować
						<strong>więcej niż sama różnica w ofercie</strong>
					</h1>

					<p class="mistake-lead">
						Największe problemy nie zaczynają się na budowie. Zaczynają się wcześniej:
						przy wyborze działki, porównywaniu ofert, braku rezerwy, złej liczbie stanowisk,
						słabej umowie i niedocenieniu serwisu.
					</p>

					<div class="mistake-actions">
						<a class="mistake-button-green" href="/bezplatne-porownanie-ofert-myjni/">
							Bezpłatna analiza i porównanie ofert
							<span aria-hidden="true">→</span>
						</a>
						<a class="mistake-button-light" href="#lista-bledow">
							Zobacz 10 błędów
							<span aria-hidden="true">↓</span>
						</a>
					</div>

					<div class="mistake-chips" aria-label="Najważniejsze tematy strony">
						{heroChips.map((item) => <span>{item}</span>)}
					</div>
				</div>

				<aside class="mistake-hero-panel mistake-hero-graphic-panel" aria-label="Grafika hero: Błędy przy budowie myjni">
					<picture>
						<source media="(max-width: 760px)" srcset="/images/ryzyko-bledy-inwestora.webp" />
						<source media="(max-width: 1180px)" srcset="/images/ryzyko-bledy-inwestora.webp" />
						<img
							src="/images/ryzyko-bledy-inwestora.webp"
							alt="Najczęstsze błędy przy budowie myjni bezdotykowej: działka, cena, umowa i serwis."
							loading="eager"
							decoding="async"
						/>
					</picture>
				</aside>
			</div>
		</section>

		<section class="mistake-section" id="lista-bledow" aria-labelledby="mistakes-title">
			<div class="container">
				<div class="mistake-split">
					<div>
						<p class="eyebrow"><span></span>Lista kontrolna</p>
						<h2 id="mistakes-title">
							10 błędów, które najczęściej psują <strong>budżet, czas i wynik inwestycji</strong>
						</h2>
					</div>
					<p>
						Nie każdy błąd widać od razu. Część pojawia się dopiero po zakupie działki,
						podpisaniu umowy, rozpoczęciu robót albo w pierwszym sezonie pracy myjni.
					</p>
				</div>

				<div class="mistake-card-grid">
					{mistakeCards.map((card) => (
						<article class="mistake-card">
							<span>{card.number}</span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="mistake-section mistake-text-section" aria-labelledby="land-title">
			<div class="container mistake-article-grid">
				<div class="mistake-sticky-title">
					<p class="eyebrow"><span></span>Błąd numer jeden</p>
					<h2 id="land-title">
						Działka bez analizy może stać się <strong>problemem, a nie aktywem</strong>
					</h2>

					<div class="mistake-side-note" aria-label="Ważne przed decyzją">
						<p>Przed decyzją</p>
						<h3>Najdroższe błędy zwykle powstają przed budową.</h3>

						<div class="mistake-side-note-list">
						<span><b>01</b> działka bez analizy</span>
						<span><b>02</b> porównywanie wyłącznie ceny</span>
						<span><b>03</b> brak rezerwy, PZT i kontroli umowy</span>
						</div>

						<a href="/bezplatne-porownanie-ofert-myjni/">
							Bezpłatna analiza i porównanie ofert
							<span aria-hidden="true">→</span>
						</a>
					</div>
				</div>

				<div class="mistake-article-copy mistake-article-card">
					<p>
						Największym ryzykiem jest zakup albo dzierżawa działki bez sprawdzenia,
						czy można na niej formalnie i technicznie wybudować myjnię samochodową.
						Działka może wyglądać dobrze, ale mieć ograniczenia w planie, niepewną WZ,
						brak mediów, problem ze zjazdem albo kolizję z siecią podziemną.
					</p>

					<p>
						Nie wystarczy, że na działce fizycznie zmieści się obiekt. Trzeba sprawdzić
						MPZP albo możliwość uzyskania WZ, sąsiedztwo, dostęp do wody, ścieków,
						prądu, gazu, deszczówki, lokalizację zjazdu, pas drogowy, sieci, światłowód,
						gazociąg, tory kolejowe i wszystkie elementy, które mogą zatrzymać projekt.
					</p>

					<p>
						Druga część analizy jest ekonomiczna. Nawet działka możliwa formalnie może
						nie mieć odpowiedniego potencjału: ruchu, widoczności, mieszkańców, aut,
						generatorów ruchu albo wygody dla kierowcy. Bez specjalisty taka działka
						może stać się kosztownym problemem.
					</p>

					<div class="mistake-quote">
						<strong>Najpierw analiza działki. Dopiero potem zakup, dzierżawa i projekt.</strong>
						<span>To prostsze, tańsze i bezpieczniejsze niż ratowanie źle wybranej lokalizacji.</span>
					</div>
				</div>
			</div>
		</section>

		<section class="mistake-section" aria-labelledby="risk-title">
			<div class="container">
				<div class="mistake-carousel" data-mistake-carousel>
					<div class="mistake-carousel-head">
						<div>
							<p class="eyebrow light"><span></span>Ukryte ryzyka</p>
							<h2 id="risk-title">
								Niektóre błędy wychodzą dopiero <strong>po podpisaniu umowy</strong>
							</h2>
						</div>
						<div class="mistake-carousel-nav" aria-label="Nawigacja slajdera">
							<button type="button" data-mistake-prev aria-label="Poprzedni element">←</button>
							<button type="button" data-mistake-next aria-label="Następny element">→</button>
						</div>
					</div>

					<div class="mistake-carousel-track" data-mistake-track>
						{riskSlides.map((slide) => (
							<article class="mistake-slide">
								<span>{slide.kicker}</span>
								<h3>{slide.title}</h3>
								<p>{slide.text}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="mistake-section" aria-labelledby="three-risks-title">
			<div class="container">
				<div class="mistake-split">
					<div>
						<p class="eyebrow"><span></span>Działka</p>
						<h2 id="three-risks-title">
							Działkę trzeba sprawdzić <strong>w trzech obszarach</strong>
						</h2>
					</div>
