---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/mapa-strony/',
	title: 'Mapa strony — inwestycjawmyjnie.pl',
	description:
		'Mapa strony inwestycjawmyjnie.pl: poradnik inwestora, koszt budowy myjni, opłacalność, działka, porównanie ofert, dokumenty i formularz analizy.'
};

const mainLinks = [
	['Strona główna', '/'],
	['Poradnik inwestora', '/poradnik/'],
	['Bezpłatna analiza i porównanie ofert', '/bezplatne-porownanie-ofert-myjni/']
];

const guideLinks = [
	['Ile kosztuje myjnia bezdotykowa?', '/ile-kosztuje-myjnia-bezdotykowa/'],
	['Koszt budowy myjni bezdotykowej', '/koszt-budowy-myjni-bezdotykowej/'],
	['Ile zarabia myjnia bezdotykowa?', '/ile-zarabia-myjnia-bezdotykowa/'],
	['Działka pod myjnię bezdotykową', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Jak porównać oferty myjni?', '/jak-porownac-oferty-myjni-bezdotykowej/'],
	['Budowa myjni krok po kroku', '/budowa-myjni-bezdotykowej-krok-po-kroku/'],
	['Najczęstsze błędy przy budowie myjni', '/najczestsze-bledy-przy-budowie-myjni/']
];

const documentLinks = [
	['Polityka prywatności i RODO', '/polityka-prywatnosci/'],
	['Polityka cookies', '/polityka-cookies/'],
	['Zasady korzystania', '/zasady-korzystania/']
];
---

<Layout
	title={page.title}
	description={page.description}
	canonicalPath={page.canonicalPath}
>
	<Header />

	<main class="sitemap-page">
		<section class="sitemap-hero">
			<div class="container">
				<p class="eyebrow"><span></span>Mapa strony</p>
				<h1>Wszystkie najważniejsze strony <strong>inwestycjawmyjnie.pl</strong></h1>
				<p>
					Zebraliśmy w jednym miejscu poradniki, dokumenty oraz formularz bezpłatnej analizy
					i porównania ofert myjni bezdotykowej.
				</p>
			</div>
		</section>

		<section class="sitemap-section">
			<div class="container sitemap-grid">
				<div class="sitemap-card sitemap-card-main">
					<p>Start</p>
					<h2>Najważniejsze strony</h2>

					<div class="sitemap-links">
						{mainLinks.map((link) => (
							<a href={link[1]}>
								<span>{link[0]}</span>
								<b aria-hidden="true">→</b>
							</a>
						))}
					</div>
				</div>

				<div class="sitemap-card">
					<p>Poradnik</p>
					<h2>Tematy inwestora</h2>

					<div class="sitemap-links">
						{guideLinks.map((link) => (
							<a href={link[1]}>
								<span>{link[0]}</span>
								<b aria-hidden="true">→</b>
							</a>
						))}
					</div>
				</div>

				<div class="sitemap-card">
					<p>Dokumenty</p>
					<h2>Informacje formalne</h2>

					<div class="sitemap-links">
						{documentLinks.map((link) => (
							<a href={link[1]}>
								<span>{link[0]}</span>
								<b aria-hidden="true">→</b>
							</a>
						))}
					</div>
				</div>
			</div>
		</section>
	</main>

	<Footer />
</Layout>

<style>
	.sitemap-page {
		background: #ffffff;
		overflow: hidden;
	}

	.sitemap-hero {
		padding: clamp(58px, 5vw, 86px) 0 clamp(34px, 4vw, 54px);
		background:
			radial-gradient(circle at 82% 12%, rgba(18, 104, 255, 0.06), transparent 30%),
			radial-gradient(circle at 18% 28%, rgba(114, 240, 105, 0.08), transparent 28%),
			linear-gradient(180deg, #ffffff 0%, #f8f9fb 100%);
	}

	.sitemap-hero .container {
		max-width: 1240px;
	}

	.sitemap-hero h1 {
		max-width: 980px;
		margin: 0;
		color: var(--ink);
		font-size: clamp(2.45rem, 4.7vw, 5.15rem);
		font-weight: 950;
		line-height: 0.96;
		letter-spacing: -0.074em;
	}

	.sitemap-hero h1 strong {
		background: linear-gradient(90deg, #0756d8 0%, #1268ff 42%, #4fa3ff 76%, #9ed7ff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		font-weight: inherit;
	}

	.sitemap-hero p:not(.eyebrow) {
		max-width: 680px;
		margin: 18px 0 0;
		color: #667085;
		font-size: clamp(0.98rem, 1.1vw, 1.1rem);
		font-weight: 570;
		line-height: 1.62;
		letter-spacing: -0.012em;
	}

	.sitemap-section {
		padding: clamp(42px, 5vw, 72px) 0 clamp(58px, 6vw, 92px);
	}

	.sitemap-grid {
		display: grid;
		grid-template-columns: minmax(280px, 0.48fr) minmax(0, 1fr);
		gap: 18px;
		align-items: start;
	}

	.sitemap-card {
		padding: clamp(20px, 2.4vw, 28px);
		border-radius: 30px;
		background:
			radial-gradient(circle at 100% 0%, rgba(114, 240, 105, 0.09), transparent 32%),
			radial-gradient(circle at 0% 0%, rgba(18, 104, 255, 0.055), transparent 32%),
			linear-gradient(145deg, #ffffff, #f8fafc);
		border: 1px solid rgba(8, 16, 32, 0.065);
		box-shadow: 0 18px 50px rgba(8, 16, 32, 0.045);
	}

	.sitemap-card-main {
		position: sticky;
		top: 112px;
	}

	.sitemap-card p {
		margin: 0;
		color: #1268ff;
		font-size: 0.68rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.sitemap-card h2 {
		margin: 9px 0 0;
		color: var(--ink);
		font-size: clamp(1.55rem, 2.25vw, 2.45rem);
		font-weight: 950;
		line-height: 1;
		letter-spacing: -0.06em;
	}

	.sitemap-links {
		display: grid;
		gap: 9px;
		margin-top: 20px;
	}

	.sitemap-links a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 14px;
		min-height: 48px;
		padding: 11px 12px 11px 14px;
		border-radius: 15px;
		background: rgba(255, 255, 255, 0.86);
		border: 1px solid rgba(8, 16, 32, 0.055);
		color: #081020;
		font-size: 0.88rem;
		font-weight: 850;
		letter-spacing: -0.024em;
		line-height: 1.2;
		text-decoration: none;
		box-shadow: 0 10px 26px rgba(8, 16, 32, 0.035);
		transition:
			transform 0.2s ease,
			color 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease;
	}

	.sitemap-links a:hover {
		transform: translateY(-1px);
		color: #1268ff;
		border-color: rgba(18, 104, 255, 0.14);
		box-shadow: 0 14px 34px rgba(8, 16, 32, 0.055);
	}

	.sitemap-links b {
		display: grid;
		place-items: center;
		width: 28px;
		height: 28px;
		min-width: 28px;
		min-height: 28px;
		border-radius: 999px;
		background: #72f069;
		color: #081020;
		font-size: 0.86rem;
		font-weight: 950;
		flex: 0 0 auto;
		box-shadow: 0 0 18px rgba(114, 240, 105, 0.24);
	}

	@media (max-width: 980px) {
		.sitemap-grid {
			grid-template-columns: 1fr;
		}

		.sitemap-card-main {
			position: relative;
			top: auto;
		}
	}

	@media (max-width: 760px) {
		.sitemap-hero {
			padding-top: 52px;
		}

		.sitemap-hero h1 {
			font-size: clamp(2.05rem, 10vw, 3.05rem);
			line-height: 0.98;
			letter-spacing: -0.07em;
		}

		.sitemap-hero p:not(.eyebrow) {
			font-size: 0.96rem;
		}

		.sitemap-section {
			padding-top: 34px;
		}

		.sitemap-card {
			border-radius: 24px;
			padding: 20px;
		}

		.sitemap-card h2 {
			font-size: clamp(1.45rem, 7vw, 2.05rem);
		}

		.sitemap-links a {
			min-height: 46px;
			font-size: 0.84rem;
		}
	}
    /* FINAL FIX — mapa strony: bezpieczna szerokość i brak uciekania poza ekran */
.sitemap-hero .container,
.sitemap-section .container {
	width: min(1180px, calc(100% - 40px)) !important;
	max-width: 1180px !important;
	margin-inline: auto !important;
	padding-inline: 0 !important;
}

.sitemap-grid {
	grid-template-columns: minmax(300px, 0.42fr) minmax(0, 0.88fr) !important;
	gap: 22px !important;
}

.sitemap-card-main {
	position: relative !important;
	top: auto !important;
}

.sitemap-card {
	box-shadow: 0 16px 44px rgba(8, 16, 32, 0.045) !important;
}

.sitemap-card h2 {
	font-size: clamp(1.55rem, 2vw, 2.2rem) !important;
}

.sitemap-links a {
	min-height: 46px !important;
	padding: 10px 12px !important;
	font-size: 0.86rem !important;
}

.sitemap-links b {
	width: 27px !important;
	height: 27px !important;
	min-width: 27px !important;
	min-height: 27px !important;
}

@media (min-width: 981px) {
	.sitemap-grid .sitemap-card:nth-child(2) {
		grid-row: span 2;
	}

	.sitemap-grid .sitemap-card:nth-child(3) {
		grid-column: 1;
	}
}

@media (max-width: 980px) {
	.sitemap-hero .container,
	.sitemap-section .container {
		width: min(100% - 28px, 760px) !important;
	}

	.sitemap-grid {
		grid-template-columns: 1fr !important;
	}
}

@media (max-width: 760px) {
	.sitemap-hero .container,
	.sitemap-section .container {
		width: min(100% - 24px, 560px) !important;
	}

	.sitemap-hero {
		padding-top: 46px !important;
		padding-bottom: 28px !important;
	}

	.sitemap-section {
		padding-top: 28px !important;
	}

	.sitemap-links a {
		font-size: 0.82rem !important;
	}
}
</style>