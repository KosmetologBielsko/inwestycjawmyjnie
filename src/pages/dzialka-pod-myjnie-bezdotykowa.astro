<script is:inline>
	const landCarousels = document.querySelectorAll('[data-land-carousel]');

	landCarousels.forEach((carousel) => {
		const track = carousel.querySelector('[data-land-track]');
		const prev = carousel.querySelector('[data-land-prev]');
		const next = carousel.querySelector('[data-land-next]');

		if (!track || !prev || !next) return;

		const getStep = () => {
			const firstCard = track.querySelector('.land-slide');
			if (!firstCard) return 360;
			const styles = window.getComputedStyle(track);
			const gap = parseFloat(styles.columnGap || styles.gap || '18');
			return firstCard.getBoundingClientRect().width + gap;
		};

		prev.addEventListener('click', () => {
			track.scrollBy({ left: -getStep(), behavior: 'smooth' });
		});

		next.addEventListener('click', () => {
			track.scrollBy({ left: getStep(), behavior: 'smooth' });
		});
	});
</script>
