---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/poradnik/',
	title: 'Poradnik inwestora myjni bezdotykowej | Koszty, działka, budowa i oferty',
	description:
		'Poradnik inwestora myjni bezdotykowej: koszt budowy, opłacalność, działka, porównanie ofert, proces inwestycji krok po kroku i najczęstsze błędy.'
};

const guideCards = [
	{
		number: '01',
		kicker: 'Koszt inwestycji',
		title: 'Ile kosztuje myjnia bezdotykowa?',
		text: 'Orientacyjne ceny myjni 2, 3, 4, 5 i 6 stanowisk oraz elementy, które wpływają na budżet inwestora.',
		href: '/ile-kosztuje-myjnia-bezdotykowa/'
	},
	{
		number: '02',
		kicker: 'Opłacalność',
		title: 'Ile zarabia myjnia bezdotykowa?',
		text: 'Przychód, koszty, zysk, zwrot z inwestycji, lokalizacja, technologia i czynniki wpływające na rentowność.',
		href: '/ile-zarabia-myjnia-bezdotykowa/'
	},
	{
		number: '03',
		kicker: 'Lokalizacja',
		title: 'Działka pod myjnię bezdotykową',
		text: 'Jak sprawdzić działkę formalnie, technicznie i ekonomicznie przed zakupem, dzierżawą albo projektem.',
		href: '/dzialka-pod-myjnie-bezdotykowa/'
	},
	{
		number: '04',
		kicker: 'Dostawcy',
		title: 'Jak porównać oferty producentów?',
		text: 'Nie tylko cena. Zakres, technologia, posadzka, dokumentacja, umowa, gwarancja, serwis i koszty eksploatacji.',
		href: '/jak-porownac-oferty-myjni-bezdotykowej/'
	},
	{
		number: '05',
		kicker: 'Budżet budowy',
		title: 'Koszt budowy myjni bezdotykowej',
		text: 'Co doliczyć poza ceną technologii: projekt, PZT, formalności, media, roboty ziemne, kostkę, separatory i rezerwę.',
		href: '/koszt-budowy-myjni-bezdotykowej/'
	},
	{
		number: '06',
		kicker: 'Proces',
		title: 'Budowa myjni krok po kroku',
		text: 'Od analizy działki i MPZP/WZ przez dokumentację, pozwolenie, produkcję, przygotowanie terenu, montaż i odbiory.',
		href: '/budowa-myjni-bezdotykowej-krok-po-kroku/'
	},
	{
		number: '07',
		kicker: 'Ryzyka',
		title: 'Najczęstsze błędy przy budowie myjni',
		text: 'Działka bez analizy, porównywanie tylko ceny, zła liczba stanowisk, brak rezerwy, słaba umowa i brak myślenia o serwisie.',
		href: '/najczestsze-bledy-przy-budowie-myjni/'
	}
];

const pathways = [
	{
		title: 'Jestem na początku',
		text: 'Zacznij od kosztów, działki i opłacalności. Najpierw sprawdź, czy temat ma sens w Twojej lokalizacji i budżecie.',
		links: [
			['Ile kosztuje myjnia?', '/ile-kosztuje-myjnia-bezdotykowa/'],
			['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
			['Ile zarabia myjnia?', '/ile-zarabia-myjnia-bezdotykowa/']
		]
	},
	{
		title: 'Mam działkę',
		text: 'Przejdź przez formalności, PZT, media, koszt budowy i proces inwestycji. Działka musi przejść filtr formalny, techniczny i ekonomiczny.',
		links: [
			['Sprawdź działkę', '/dzialka-pod-myjnie-bezdotykowa/'],
			['Koszt budowy', '/koszt-budowy-myjni-bezdotykowej/'],
			['Budowa krok po kroku', '/budowa-myjni-bezdotykowej-krok-po-kroku/']
		]
	},
	{
		title: 'Mam ofertę producenta',
		text: 'Nie porównuj wyłącznie ceny. Sprawdź zakres, technologię, dokumentację, umowę, gwarancję, serwis i koszty eksploatacji.',
		links: [
			['Porównanie ofert', '/jak-porownac-oferty-myjni-bezdotykowej/'],
			['Błędy inwestora', '/najczestsze-bledy-przy-budowie-myjni/'],
			['Opłacalność', '/ile-zarabia-myjnia-bezdotykowa/']
		]
	}
];

const processSteps = [
	['01', 'Sprawdź działkę', 'Lokalizacja, MPZP/WZ, media, zjazd, sąsiedztwo, ruch i potencjał ekonomiczny.'],
	['02', 'Określ budżet', 'Technologia, projekt, roboty budowlane, rezerwa, leasing, podatki i koszty uruchomienia.'],
	['03', 'Porównaj oferty', 'Zakres, jakość komponentów, posadzka, dokumentacja, serwis, umowa i gwarancja.'],
	['04', 'Zaplanuj proces', 'Projekt, pozwolenie, produkcja, przygotowanie terenu, montaż, uruchomienie i odbiory.']
];

const keyRules = [
	{
		title: 'Nie zaczynaj od ceny',
		text: 'Cena ma sens dopiero wtedy, gdy znasz działkę, zakres, technologię, koszt budowy i model finansowania.'
	},
	{
		title: 'Działka decyduje o potencjale',
		text: 'Dobra lokalizacja może obronić inwestycję. Zła działka potrafi zablokować projekt formalnie, technicznie albo ekonomicznie.'
	},
	{
		title: 'Jakość wpływa na wynik przez lata',
		text: 'W myjni różnicę robią elementy niewidoczne: technologia, zużycie mediów, serwis, żywotność komponentów i czas przestoju.'
	},
	{
		title: 'PZT porządkuje budowę',
		text: 'Plan zagospodarowania terenu pozwala przełożyć pomysł na układ stanowisk, media, strefę mokrą, strefę suchą i realny zakres robót.'
	}
];

const faqItems = [
	{
		question: 'Od czego zacząć inwestycję w myjnię bezdotykową?',
		answer:
			'Najlepiej zacząć od analizy działki, budżetu i potencjału przychodu. Dopiero później warto porównywać oferty producentów i wybierać technologię.'
	},
	{
		question: 'Czy cena producenta pokazuje cały koszt inwestycji?',
		answer:
			'Nie. Cena producenta zwykle pokazuje tylko część zakresu. Do pełnego budżetu trzeba doliczyć projekt, formalności, roboty ziemne, przyłącza, odwodnienie, nawierzchnie, PZT, zjazd, rezerwę i elementy zależne od działki.'
	},
	{
		question: 'Czy lepiej najpierw szukać działki, czy producenta?',
		answer:
			'Najlepiej równolegle analizować działkę i rozmawiać z partnerem technologicznym. Działka decyduje o potencjale, ale technologia, PZT i doświadczenie producenta pomagają ocenić, co realnie można na niej zbudować.'
	},
	{
		question: 'Czy najtańsza oferta może być dobra?',
		answer:
			'Może, ale tylko wtedy, gdy zakres, technologia, dokumentacja, gwarancja i serwis są porównywalne. W praktyce najniższa cena często wynika z mniejszego zakresu, słabszych komponentów albo przerzucenia części kosztów na inwestora.'
	},
	{
		question: 'Kiedy warto przesłać działkę albo ofertę do analizy?',
		answer:
			'Najlepiej przed zakupem działki, podpisaniem dzierżawy albo umowy z producentem. Wtedy łatwiej uniknąć błędów formalnych, technicznych, komunikacyjnych i kosztowych.'
	}
];

const itemListSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	name: 'Poradnik inwestora myjni bezdotykowej',
	itemListElement: guideCards.map((item, index) => ({
		'@type': 'ListItem',
		position: index + 1,
		name: item.title,
		url: item.href
	}))
};

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};
---

<Layout title={page.title} description={page.description} canonicalPath={page.canonicalPath}>
	<Header />

	<main class="hub-page">
		<section class="hub-hero" aria-labelledby="page-title">
			<div class="container hub-hero-grid">
				<div class="hub-hero-copy">
					<p class="eyebrow">
						<span></span>
						Centrum wiedzy inwestora
					</p>

					<h1 id="page-title">
						Poradnik inwestora myjni bezdotykowej — od pomysłu do
						<strong>bezpiecznej decyzji.</strong>
					</h1>

					<p class="hub-lead">
						Zanim kupisz technologię, wydzierżawisz działkę albo podpiszesz umowę,
						sprawdź koszty, opłacalność, lokalizację, dokumentację, proces budowy
						i najczęstsze błędy inwestorów.
					</p>

					<div class="hub-actions">
						<a class="hub-button-green" href="/#kontakt">
							Prześlij działkę lub ofertę
							<span aria-hidden="true">→</span>
						</a>
						<a class="hub-button-light" href="#tematy">
							Zobacz tematy poradnika
							<span aria-hidden="true">↓</span>
						</a>
					</div>

					<div class="hub-chips" aria-label="Najważniejsze tematy poradnika">
						<span>koszt</span>
						<span>opłacalność</span>
						<span>działka</span>
						<span>oferty</span>
						<span>budowa</span>
						<span>błędy</span>
					</div>
				</div>

				<aside class="hub-hero-panel" aria-label="Najważniejszy wniosek">
					<div class="hub-panel-logo">inwestycjawmyjnie.pl</div>
					<p>Najważniejsza zasada</p>
					<h2>Nie zaczynaj inwestycji od samej ceny.</h2>
					<span>
						Najpierw sprawdź działkę, potencjał, formalności, budżet i technologię.
						Cena ma sens dopiero wtedy, gdy znasz realny zakres inwestycji.
					</span>
					<div class="hub-mini-grid">
						<b>działka</b>
						<b>budżet</b>
						<b>technologia</b>
						<b>serwis</b>
					</div>
				</aside>
			</div>
		</section>

		<section class="hub-section" id="tematy" aria-labelledby="topics-title">
			<div class="container">
				<div class="hub-split">
					<div>
						<p class="eyebrow"><span></span>Główne tematy</p>
						<h2 id="topics-title">
							Najważniejsze decyzje przed budową <strong>myjni bezdotykowej</strong>
						</h2>
					</div>
					<p>
						Ten poradnik porządkuje inwestycję etapami: od pierwszego pytania o koszt,
						przez analizę działki, po porównanie ofert, proces budowy i błędy, których
						warto uniknąć przed podpisaniem umowy.
					</p>
				</div>

				<div class="guide-card-grid">
					{guideCards.map((card) => (
						<a class="guide-topic-card" href={card.href}>
							<span class="guide-topic-number">{card.number}</span>
							<div>
								<small>{card.kicker}</small>
								<h3>{card.title}</h3>
								<p>{card.text}</p>
							</div>
							<b aria-hidden="true">→</b>
						</a>
					))}
				</div>
			</div>
		</section>

		<section class="hub-section hub-path-section" aria-labelledby="path-title">
			<div class="container">
				<div class="hub-split">
					<div>
						<p class="eyebrow"><span></span>Jak korzystać?</p>
						<h2 id="path-title">
							Wybierz ścieżkę według tego, <strong>na jakim jesteś etapie</strong>
						</h2>
					</div>
					<p>
						Inaczej czyta poradnik osoba, która dopiero szuka działki, inaczej inwestor
						z konkretną lokalizacją, a inaczej ktoś, kto ma już ofertę producenta.
					</p>
				</div>

				<div class="path-grid">
					{pathways.map((path) => (
						<article class="path-card">
							<h3>{path.title}</h3>
							<p>{path.text}</p>
							<div>
								{path.links.map((link) => (
									<a href={link[1]}>{link[0]} <span>→</span></a>
								))}
							</div>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="hub-section" aria-labelledby="process-title">
			<div class="container process-panel">
				<div class="process-head">
					<p class="eyebrow light"><span></span>Prosty model decyzji</p>
					<h2 id="process-title">
						Od pomysłu do decyzji: <strong>cztery kroki, które porządkują inwestycję</strong>
					</h2>
					<p>
						Myjnia bezdotykowa nie powinna zaczynać się od przypadkowego porównania cen.
						Najpierw trzeba ustalić, czy lokalizacja i budżet mają sens, a dopiero potem
						wybierać technologię oraz zakres.
					</p>
				</div>

				<div class="process-grid">
					{processSteps.map((step) => (
						<article>
							<span>{step[0]}</span>
							<h3>{step[1]}</h3>
							<p>{step[2]}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="hub-section" aria-labelledby="rules-title">
			<div class="container">
				<div class="hub-split">
					<div>
						<p class="eyebrow"><span></span>Zasady inwestora</p>
						<h2 id="rules-title">
							Najważniejsze wnioski, które powtarzają się <strong>w każdej dobrej analizie</strong>
						</h2>
					</div>
					<p>
						Te zasady spajają cały poradnik. Pomagają odróżnić realną analizę inwestycji
						od szybkiej decyzji opartej tylko na cenie albo ładnej wizualizacji.
					</p>
				</div>

				<div class="rule-grid">
					{keyRules.map((rule, index) => (
						<article class="rule-card">
							<span>{String(index + 1).padStart(2, '0')}</span>
							<h3>{rule.title}</h3>
							<p>{rule.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="hub-section" aria-labelledby="analysis-title">
			<div class="container">
				<div class="analysis-cta">
					<div>
						<p class="eyebrow light"><span></span>Wstępna analiza</p>
						<h2 id="analysis-title">
							Masz działkę, ofertę albo pomysł? <strong>Zacznij od uporządkowania danych.</strong>
						</h2>
						<p>
							Prześlij miejscowość, link do mapy, numer działki, wstępną ofertę albo opis
							pomysłu. Na początku nie chodzi o sprzedaż, tylko o ocenę, czy temat ma sens
							formalnie, technicznie i ekonomicznie.
						</p>
					</div>
					<a class="hub-button-green" href="/#kontakt">
						Prześlij do analizy
						<span aria-hidden="true">→</span>
					</a>
				</div>
			</div>
		</section>

		<section class="hub-section" aria-labelledby="faq-title">
			<div class="container">
				<div class="hub-split">
					<div>
						<p class="eyebrow"><span></span>FAQ</p>
						<h2 id="faq-title">
							Najczęstsze pytania przed inwestycją <strong>w myjnię bezdotykową</strong>
						</h2>
					</div>
					<p>
						Krótko i konkretnie: co sprawdzić, zanim zaczniesz kupować technologię,
						porównywać oferty albo podpisywać umowę dzierżawy działki.
					</p>
				</div>

				<div class="hub-faq-list">
					{faqItems.map((item, index) => (
						<details class="hub-faq-item" open={index === 0}>
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>
	</main>

	<Footer />
	<script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>

<style>
	.hub-page {
		width: 100%;
		max-width: 100%;
		overflow-x: hidden;
		background: #fff;
	}

	.hub-hero {
		position: relative;
		overflow: hidden;
		padding: clamp(84px, 8vw, 132px) 0 clamp(70px, 7vw, 110px);
		background:
			radial-gradient(circle at 80% 12%, rgba(18, 104, 255, 0.09), transparent 34%),
			radial-gradient(circle at 18% 28%, rgba(114, 240, 105, 0.11), transparent 30%),
			linear-gradient(180deg, #ffffff 0%, #f8f9fb 100%);
	}

	.hub-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(380px, 0.66fr);
		gap: clamp(34px, 5vw, 74px);
		align-items: center;
	}

	.hub-hero h1,
	.hub-split h2,
	.process-head h2,
	.analysis-cta h2 {
		margin: 0;
		color: var(--ink);
		font-weight: 950;
		letter-spacing: -0.078em;
		line-height: 0.94;
	}

	.hub-hero h1 {
		max-width: 1060px;
		font-size: clamp(3.25rem, 6.45vw, 7.05rem);
	}

	.hub-hero h1 strong,
	.hub-split h2 strong,
	.process-head h2 strong,
	.analysis-cta h2 strong {
		background: linear-gradient(90deg, #0756d8 0%, #1268ff 38%, #4fa3ff 72%, #9ed7ff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		font-weight: inherit;
	}

	.hub-lead {
		max-width: 820px;
		margin: 28px 0 0;
		color: #667085;
		font-size: clamp(1.05rem, 1.35vw, 1.28rem);
		font-weight: 560;
		line-height: 1.68;
		letter-spacing: -0.012em;
	}

	.hub-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.hub-button-green,
	.hub-button-light {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		min-height: 58px;
		padding: 0 24px;
		border-radius: 999px;
		font-weight: 950;
		letter-spacing: -0.03em;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease, filter 0.2s ease;
	}

	.hub-button-green {
		color: #06110a;
		background: linear-gradient(90deg, #7cff4a 0%, #51f05e 45%, #28dc73 100%);
		border: 1px solid rgba(114, 240, 105, 0.34);
		box-shadow: 0 18px 44px rgba(76, 244, 89, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.56);
	}

	.hub-button-light {
		color: var(--ink);
		background: rgba(255, 255, 255, 0.9);
		border: 1px solid rgba(8, 16, 32, 0.1);
		box-shadow: 0 12px 34px rgba(8, 16, 32, 0.06);
	}

	.hub-button-green:hover,
	.hub-button-light:hover {
		transform: translateY(-2px);
	}

	.hub-chips {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 26px;
	}

	.hub-chips span {
		display: inline-flex;
		align-items: center;
		min-height: 38px;
		padding: 8px 14px;
		border: 1px solid rgba(8, 16, 32, 0.09);
		border-radius: 999px;
		background: #fff;
		color: #344054;
		font-size: 0.9rem;
		font-weight: 820;
		box-shadow: 0 10px 26px rgba(8, 16, 32, 0.045);
	}

	.hub-hero-panel {
		position: relative;
		min-height: 520px;
		padding: 32px;
		border-radius: 48px;
		background:
			radial-gradient(circle at 70% 18%, rgba(18, 104, 255, 0.28), transparent 32%),
			radial-gradient(circle at 22% 78%, rgba(114, 240, 105, 0.24), transparent 32%),
			linear-gradient(145deg, #05070d, #121a29 58%, #05070d);
		border: 1px solid rgba(255, 255, 255, 0.12);
		box-shadow: 0 34px 96px rgba(8, 16, 32, 0.22);
		overflow: hidden;
		color: #fff;
	}

	.hub-hero-panel::before {
		content: '';
		position: absolute;
		inset: 48px;
		border-radius: 34px;
		border: 1px solid rgba(255, 255, 255, 0.1);
		background:
			linear-gradient(90deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px),
			linear-gradient(180deg, rgba(255, 255, 255, 0.06) 1px, transparent 1px);
		background-size: 48px 48px;
		mask-image: linear-gradient(180deg, black, transparent 90%);
	}

	.hub-panel-logo,
	.hub-hero-panel p,
	.hub-hero-panel h2,
	.hub-hero-panel span,
	.hub-mini-grid {
		position: relative;
		z-index: 1;
	}

