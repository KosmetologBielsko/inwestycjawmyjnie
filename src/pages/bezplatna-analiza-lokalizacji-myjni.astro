---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';

const page = {
	canonicalPath: '/bezplatna-analiza-lokalizacji-myjni/',
	title: 'Bezpłatna analiza lokalizacji pod myjnię bezdotykową',
	description:
		'Masz działkę lub lokalizację pod myjnię bezdotykową? Prześlij miejscowość, link do mapy lub numer działki i sprawdź wstępnie potencjał inwestycji.'
};

const checkCards = [
	{
		number: '01',
		title: 'Potencjał ekonomiczny',
		text: 'Sprawdzamy otoczenie działki, ruch, widoczność, generatory klientów, konkurencję, typ miejscowości i realny sens budowy myjni w danym miejscu.'
	},
	{
		number: '02',
		title: 'Układ komunikacyjny',
		text: 'Oceniamy, czy kierowca może łatwo wjechać, wyjechać, zawrócić, poczekać w kolejce i korzystać z myjni bez stresu oraz blokowania ruchu.'
	},
	{
		number: '03',
		title: 'Formalności i ryzyka',
		text: 'Wstępnie porządkujemy temat MPZP, WZ, przeznaczenia działki, zjazdu, sąsiedztwa, mediów i elementów, które trzeba sprawdzić z projektantem.'
	},
	{
		number: '04',
		title: 'Skala inwestycji',
		text: 'Pomagamy określić, czy lokalizacja bardziej pasuje do 2, 3, 4 czy większej liczby stanowisk oraz czy warto planować urządzenia dodatkowe.'
	}
];

const processSteps = [
	['01', 'Wysyłasz lokalizację', 'Podajesz miejscowość, link do mapy, numer działki albo krótki opis miejsca.'],
	['02', 'Wstępnie porządkujemy temat', 'Patrzymy na lokalizację, otoczenie, możliwe ryzyka i pytania, które trzeba zadać przed inwestycją.'],
	['03', 'Wskazujemy dalszy kierunek', 'Dostajesz informację, czy warto rozwijać temat, co sprawdzić dalej i jakie dane przygotować do projektu.']
];

const faqItems = [
	{
		question: 'Czy analiza lokalizacji jest bezpłatna?',
		answer:
			'Tak. Wstępna analiza lokalizacji jest bezpłatna i służy sprawdzeniu, czy temat warto rozwijać dalej. Nie zastępuje projektu, decyzji urzędowych ani szczegółowej analizy technicznej wykonanej przez projektanta.'
	},
	{
		question: 'Co najlepiej przesłać do analizy?',
		answer:
			'Najlepiej podać miejscowość, link do mapy, numer działki, województwo, informację czy działka jest własna czy do dzierżawy oraz krótki opis planowanej inwestycji.'
	},
	{
		question: 'Czy wystarczy sama miejscowość?',
		answer:
			'Na bardzo wstępny kontakt wystarczy, ale im dokładniejsza lokalizacja, tym lepiej można ocenić dojazd, otoczenie, konkurencję, widoczność i potencjalne ryzyka.'
	},
	{
		question: 'Czy sprawdzacie MPZP albo WZ?',
		answer:
			'Na początku można wskazać, że temat wymaga sprawdzenia planistycznego. Docelowo MPZP, WZ, warunki przyłączy i zjazd powinny zostać zweryfikowane z projektantem oraz właściwym urzędem.'
	}
];

const relatedLinks = [
	['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Koszt budowy myjni', '/koszt-budowy-myjni-bezdotykowej/'],
	['Ile zarabia myjnia?', '/ile-zarabia-myjnia-bezdotykowa/'],
	['Poradnik inwestora', '/poradnik/']
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};
---

<Layout title={page.title} description={page.description} canonicalPath={page.canonicalPath}>
	<Header />

	<main class="lead-page lead-location-page">
		<section class="lead-hero" aria-labelledby="page-title">
			<div class="container lead-hero-grid">
				<div class="lead-hero-copy">
					<p class="eyebrow"><span></span>Bezpłatna analiza lokalizacji</p>
					<h1 id="page-title">
						Masz działkę albo lokalizację? <strong>Sprawdź potencjał pod myjnię.</strong>
					</h1>
					<p class="lead-main-text">
						Prześlij miejscowość, link do mapy, numer działki albo krótki opis miejsca.
						Na tym etapie nie chodzi o sprzedaż, tylko o spokojną ocenę, czy lokalizacja
						ma sens pod budowę myjni bezdotykowej.
					</p>
					<div class="lead-hero-actions">
						<a class="lead-button-green" href="#formularz">Wypełnij formularz <span aria-hidden="true">↓</span></a>
						<a class="lead-button-light" href="/dzialka-pod-myjnie-bezdotykowa/">Jak ocenić działkę? <span aria-hidden="true">→</span></a>
					</div>
					<div class="lead-tags" aria-label="Typy lokalizacji">
						<span>działka przy drodze</span>
						<span>teren przy markecie</span>
						<span>stacja paliw</span>
						<span>lokalizacja usługowa</span>
					</div>
				</div>

				<aside class="lead-form-card" id="formularz" aria-label="Formularz analizy lokalizacji">
					<div class="lead-form-head">
						<p>Formularz</p>
						<h2>Bezpłatna analiza lokalizacji</h2>
						<span>Wypełnij najważniejsze dane. Pola opisowe pomagają lepiej zakwalifikować temat.</span>
					</div>

					<form class="smart-form" data-lead-form>
						<input type="hidden" name="typ_zapytania" value="Bezpłatna analiza lokalizacji" />

						<label>
							Imię i nazwisko
							<input type="text" name="name" placeholder="Twoje imię i nazwisko" autocomplete="name" />
						</label>

						<label>
							Telefon
							<input type="tel" name="phone" placeholder="Numer telefonu" autocomplete="tel" />
						</label>

						<label>
							E-mail
							<input type="email" name="email" placeholder="Twój adres e-mail" autocomplete="email" />
						</label>

						<label>
							Województwo
							<select name="voivodeship">
								<option value="">Wybierz województwo</option>
								<option>dolnośląskie</option>
								<option>kujawsko-pomorskie</option>
								<option>lubelskie</option>
								<option>lubuskie</option>
								<option>łódzkie</option>
								<option>małopolskie</option>
								<option>mazowieckie</option>
								<option>opolskie</option>
								<option>podkarpackie</option>
								<option>podlaskie</option>
								<option>pomorskie</option>
								<option>śląskie</option>
								<option>świętokrzyskie</option>
								<option>warmińsko-mazurskie</option>
								<option>wielkopolskie</option>
								<option>zachodniopomorskie</option>
							</select>
						</label>

						<label>
							Miasto / miejscowość
							<input type="text" name="city" placeholder="Np. Bielsko-Biała, Rzeszów, okolice..." />
						</label>

						<label>
							Status działki
							<select name="plot_status">
								<option value="">Wybierz</option>
								<option>Mam własną działkę</option>
								<option>Mam działkę do dzierżawy</option>
								<option>Dopiero szukam działki</option>
								<option>Nie wiem / chcę porozmawiać</option>
							</select>
						</label>

						<label>
							Planowana liczba stanowisk
							<select name="stations">
								<option value="">Nie wiem / do ustalenia</option>
								<option>2 stanowiska</option>
								<option>3 stanowiska</option>
								<option>4 stanowiska</option>
								<option>5 stanowisk</option>
								<option>6 stanowisk</option>
							</select>
						</label>

						<label class="full">
							Link do mapy / numer działki
							<input type="text" name="map_or_plot" placeholder="Wklej link do Google Maps, Geoportalu albo numer działki" />
						</label>

						<label class="full">
							Opis lokalizacji
							<textarea name="message" rows="5" placeholder="Napisz krótko, co wiesz o działce: dojazd, media, sąsiedztwo, planowana inwestycja..."></textarea>
						</label>

						<div class="form-consents full">
							<label class="checkbox-label">
								<input type="checkbox" name="contact_consent" />
								<span>Wyrażam zgodę na kontakt w sprawie przesłanej lokalizacji.</span>
							</label>
							<label class="checkbox-label">
								<input type="checkbox" name="privacy_consent" />
								<span>Akceptuję kontakt i przetwarzanie danych w celu obsługi zapytania.</span>
							</label>
						</div>

						<button type="button" class="form-submit">Wyślij do analizy <span aria-hidden="true">→</span></button>

						<small class="form-note full">
							Formularz jest przygotowany wizualnie. Wysyłkę podłączymy później pod {siteConfig.email}.
						</small>
					</form>
				</aside>
			</div>
		</section>

		<section class="lead-section" aria-labelledby="checks-title">
			<div class="container">
				<div class="lead-split">
					<div>
						<p class="eyebrow"><span></span>Co sprawdzamy?</p>
						<h2 id="checks-title">Działka musi przejść <strong>kilka filtrów</strong></h2>
					</div>
					<p>
						Sama powierzchnia nie wystarczy. Dobra lokalizacja pod myjnię musi mieć sens
						formalny, techniczny, komunikacyjny i ekonomiczny. Dopiero wtedy warto rozwijać temat.
					</p>
				</div>

				<div class="lead-card-grid">
					{checkCards.map((card) => (
						<article class="lead-info-card">
							<span>{card.number}</span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="lead-section process-band" aria-labelledby="process-title">
			<div class="container process-panel">
				<div>
					<p class="eyebrow light"><span></span>Jak to działa?</p>
					<h2 id="process-title">Prosty start bez chaosu i bez przypadkowych ofert</h2>
				</div>
				<div class="process-steps">
					{processSteps.map((step) => (
						<article>
							<span>{step[0]}</span>
							<h3>{step[1]}</h3>
							<p>{step[2]}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="lead-section" aria-labelledby="faq-title">
			<div class="container">
				<div class="lead-split">
					<div>
						<p class="eyebrow"><span></span>FAQ</p>
						<h2 id="faq-title">Najczęstsze pytania o <strong>analizę lokalizacji</strong></h2>
					</div>
					<p>Krótko i konkretnie — co warto wiedzieć przed wysłaniem działki do wstępnej oceny.</p>
				</div>
				<div class="lead-faq-list">
					{faqItems.map((item, index) => (
						<details class="lead-faq-item" open={index === 0}>
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					))}
				</div>
			</div>
		</section>

		<section class="lead-section related-section" aria-labelledby="related-title">
			<div class="container">
				<p class="eyebrow"><span></span>Dalej w poradniku</p>
				<h2 id="related-title">Powiązane tematy <strong>dla inwestora</strong></h2>
				<div class="related-grid">
					{relatedLinks.map((link) => (
						<a class="related-card" href={link[1]}>{link[0]} <span>→</span></a>
					))}
				</div>
			</div>
		</section>
	</main>

	<Footer />
	<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
</Layout>

<style>
	.lead-page {
		width: 100%;
		max-width: 100%;
		overflow-x: hidden;
		background: #fff;
	}

	.lead-hero {
		position: relative;
		overflow: hidden;
		padding: clamp(76px, 7vw, 118px) 0 clamp(72px, 7vw, 108px);
		background:
			radial-gradient(circle at 82% 12%, rgba(18, 104, 255, 0.09), transparent 34%),
			radial-gradient(circle at 18% 28%, rgba(114, 240, 105, 0.12), transparent 30%),
			linear-gradient(180deg, #ffffff 0%, #f8f9fb 100%);
	}

	.lead-hero-grid {
		display: grid;
		grid-template-columns: minmax(0, 0.92fr) minmax(420px, 0.74fr);
		gap: clamp(34px, 5vw, 74px);
		align-items: start;
	}

	.lead-hero h1,
	.lead-split h2,
	.process-panel h2,
	.related-section h2 {
		margin: 0;
		color: var(--ink);
		font-weight: 950;
		letter-spacing: -0.078em;
		line-height: 0.94;
	}

	.lead-hero h1 {
		font-size: clamp(3.15rem, 6vw, 6.7rem);
		max-width: 1000px;
	}

	.lead-hero h1 strong,
	.lead-split h2 strong,
	.related-section h2 strong {
		background: linear-gradient(90deg, #0756d8 0%, #1268ff 38%, #4fa3ff 72%, #9ed7ff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		font-weight: inherit;
	}

	.lead-main-text {
		max-width: 780px;
		margin: 28px 0 0;
		color: #667085;
		font-size: clamp(1.05rem, 1.35vw, 1.28rem);
		font-weight: 560;
		line-height: 1.68;
		letter-spacing: -0.012em;
	}

	.lead-hero-actions {
		display: flex;
		flex-wrap: wrap;
		gap: 14px;
		margin-top: 34px;
	}

	.lead-button-green,
	.lead-button-light,
	.form-submit {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		min-height: 58px;
		padding: 0 24px;
		border-radius: 999px;
		font-weight: 950;
		letter-spacing: -0.03em;
		text-decoration: none;
		transition: transform 0.2s ease, box-shadow 0.2s ease;
	}

	.lead-button-green,
	.form-submit {
		color: #06110a;
		background: linear-gradient(90deg, #7cff4a 0%, #51f05e 45%, #28dc73 100%);
		border: 1px solid rgba(114, 240, 105, 0.34);
		box-shadow: 0 18px 44px rgba(76, 244, 89, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.56);
		cursor: pointer;
	}

	.lead-button-light {
		color: var(--ink);
		background: rgba(255, 255, 255, 0.9);
		border: 1px solid rgba(8, 16, 32, 0.1);
		box-shadow: 0 12px 34px rgba(8, 16, 32, 0.06);
	}

	.lead-button-green:hover,
	.lead-button-light:hover,
	.form-submit:hover {
		transform: translateY(-2px);
	}

	.lead-tags {
		display: flex;
		flex-wrap: wrap;
		gap: 10px;
		margin-top: 26px;
	}

	.lead-tags span {
		display: inline-flex;
		align-items: center;
		min-height: 38px;
		padding: 8px 14px;
		border: 1px solid rgba(8, 16, 32, 0.09);
		border-radius: 999px;
		background: #fff;
		color: #344054;
		font-size: 0.9rem;
		font-weight: 820;
		box-shadow: 0 10px 26px rgba(8, 16, 32, 0.045);
	}

	.lead-form-card {
		position: relative;
		padding: clamp(24px, 3vw, 34px);
		border-radius: 42px;
		background:
			radial-gradient(circle at 92% 6%, rgba(114, 240, 105, 0.16), transparent 30%),
			linear-gradient(145deg, #05070d, #101723 58%, #05070d);
		border: 1px solid rgba(255, 255, 255, 0.12);
		box-shadow: 0 34px 96px rgba(8, 16, 32, 0.22);
		color: #fff;
	}

	.lead-form-head p {
		margin: 0;
		color: #72f069;
		font-size: 0.78rem;
		font-weight: 950;
		letter-spacing: 0.13em;
		text-transform: uppercase;
	}

	.lead-form-head h2 {
		margin: 10px 0 0;
		font-size: clamp(1.9rem, 3vw, 3rem);
		font-weight: 950;
		letter-spacing: -0.065em;
		line-height: 0.98;
	}

	.lead-form-head span {
		display: block;
		margin-top: 12px;
		color: rgba(255, 255, 255, 0.72);
		font-weight: 560;
		line-height: 1.55;
	}

	.smart-form {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 14px;
		margin-top: 24px;
	}

	.smart-form label {
		display: grid;
		gap: 8px;
		color: rgba(255, 255, 255, 0.86);
		font-size: 0.88rem;
		font-weight: 850;
		letter-spacing: -0.02em;
	}

	.smart-form .full,
	.form-submit {
		grid-column: 1 / -1;
	}

	.smart-form input,
	.smart-form select,
	.smart-form textarea {
		width: 100%;
		min-height: 52px;
		border: 1px solid rgba(255, 255, 255, 0.14);
		border-radius: 18px;
		background: rgba(255, 255, 255, 0.94);
		color: #081020;
		font: inherit;
		font-weight: 720;
		padding: 14px 16px;
		outline: none;
	}

	.smart-form textarea {
		min-height: 132px;
		resize: vertical;
	}

	.form-consents {
		display: grid;
		gap: 10px;
	}

	.checkbox-label {
		display: flex !important;
		grid-template-columns: none !important;
		align-items: flex-start;
		gap: 10px !important;
		font-size: 0.84rem !important;
		font-weight: 650 !important;
		line-height: 1.45;
	}

	.checkbox-label input {
		width: 18px;
		min-height: 18px;
		margin-top: 2px;
		padding: 0;
		border-radius: 5px;
		flex: 0 0 auto;
	}

	.form-note {
		color: rgba(255, 255, 255, 0.6);
		font-size: 0.82rem;
		font-weight: 560;
		line-height: 1.5;
	}

	.lead-section {
		padding: clamp(72px, 7vw, 110px) 0;
	}

	.lead-split {
		display: grid;
		grid-template-columns: minmax(0, 0.95fr) minmax(320px, 0.52fr);
		gap: clamp(30px, 4vw, 56px);
		align-items: end;
		margin-bottom: 42px;
	}

	.lead-split h2,
	.process-panel h2,
	.related-section h2 {
		font-size: clamp(2.55rem, 4.6vw, 5.1rem);
	}

	.lead-split > p {
		margin: 0;
		color: #667085;
		font-size: clamp(1rem, 1.18vw, 1.14rem);
		font-weight: 560;
		line-height: 1.66;
	}

	.lead-card-grid,
	.related-grid {
		display: grid;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 20px;
	}

	.lead-info-card,
	.related-card {
		position: relative;
		overflow: hidden;
		min-height: 280px;
		padding: 28px;
		border-radius: 34px;
		background: linear-gradient(145deg, #ffffff, #f8f9fb);
		border: 1px solid rgba(8, 16, 32, 0.08);
		box-shadow: 0 22px 64px rgba(8, 16, 32, 0.07);
	}

	.lead-info-card span {
		display: block;
		color: rgba(8, 16, 32, 0.12);
		font-size: clamp(4rem, 5vw, 6.2rem);
		font-weight: 950;
		letter-spacing: -0.09em;
		line-height: 0.82;
	}

	.lead-info-card h3 {
		margin: 42px 0 0;
		color: var(--ink);
		font-size: clamp(1.32rem, 1.85vw, 1.9rem);
		font-weight: 950;
		letter-spacing: -0.06em;
		line-height: 1.02;
	}

	.lead-info-card p {
		margin: 14px 0 0;
		color: #667085;
		font-weight: 560;
		line-height: 1.62;
	}

	.process-band {
		padding-top: 0;
	}

	.process-panel {
		padding: clamp(34px, 5vw, 58px);
		border-radius: 48px;
		background:
			radial-gradient(circle at 12% 18%, rgba(18, 104, 255, 0.24), transparent 34%),
			radial-gradient(circle at 88% 8%, rgba(114, 240, 105, 0.2), transparent 30%),
			linear-gradient(135deg, #05070d 0%, #101723 48%, #05070d 100%);
		box-shadow: 0 34px 100px rgba(8, 16, 32, 0.24);
		color: #fff;
	}

	.process-panel h2 {
		max-width: 940px;
		color: #fff;
	}

	.process-steps {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
		margin-top: 34px;
	}

	.process-steps article {
		padding: 24px;
		border-radius: 28px;
		background: rgba(255, 255, 255, 0.1);
		border: 1px solid rgba(255, 255, 255, 0.14);
	}

