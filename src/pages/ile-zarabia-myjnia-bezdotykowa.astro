---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/ile-zarabia-myjnia-bezdotykowa/',
	title: 'Ile zarabia myjnia bezdotykowa? Przychody, koszty i realny zwrot',
	description:
		'Ile zarabia myjnia bezdotykowa? Sprawdź, od czego zależy przychód, zysk, koszt utrzymania, rentowność i zwrot z inwestycji w myjnię.'
};

const revenueModel = [
	{
		label: 'Przychód',
		title: 'Ile klienci realnie zostawiają na myjni?',
		text: 'To suma myć, programów, czasu korzystania, płatności i usług dodatkowych. Przychód zależy głównie od lokalizacji, widoczności, wygody wjazdu, jakości mycia i liczby klientów.'
	},
	{
		label: 'Koszty',
		title: 'Ile kosztuje wykonanie usługi i utrzymanie obiektu?',
		text: 'Wynik myjni zależy od zużycia wody, ścieków, energii, chemii, ogrzewania, serwisu, prowizji płatniczych, obsługi, dzierżawy, leasingu i kosztów okresowych.'
	},
	{
		label: 'Wynik',
		title: 'Co zostaje inwestorowi przed podatkiem i po finansowaniu?',
		text: 'Zysk nie jest tym samym co obrót. Dopiero po odjęciu kosztów, finansowania, podatków i rezerw można ocenić realną opłacalność inwestycji.'
	}
];

const revenueFactors = [
	{
		number: '01',
		title: 'Lokalizacja i ruch',
		text: 'Ruch samochodowy, widoczność, wygodny wjazd, brak trudnego manewrowania, sąsiedztwo usług i codzienne trasy kierowców decydują, czy myjnia ma naturalny dopływ klientów.'
	},
	{
		number: '02',
		title: 'Liczba stanowisk',
		text: 'Myjnia powinna mieć tyle stanowisk, ile lokalizacja jest w stanie realnie wykorzystać. Za mały obiekt może tworzyć kolejki, a za duży niepotrzebnie podnosi koszt inwestycji.'
	},
	{
		number: '03',
		title: 'Projekt ruchu na obiekcie',
		text: 'Dobry układ stanowisk, odkurzaczy, urządzeń dodatkowych, wjazdu i wyjazdu wpływa na komfort kierowcy. Im prostsza komunikacja, tym większa szansa na powtarzalne wizyty.'
	},
	{
		number: '04',
		title: 'Jakość technologii',
		text: 'Technologia wpływa na jakość mycia, stabilność pracy, zużycie mediów, awaryjność i koszty serwisu. To jeden z kluczowych czynników rentowności w perspektywie kilku lat.'
	},
	{
		number: '05',
		title: 'Standard wizualny',
		text: 'Czysty, widoczny, dobrze oświetlony i nowoczesny obiekt przyciąga kierowców. Wygląd myjni nie jest dodatkiem — wpływa na pierwszą decyzję klienta.'
	},
	{
		number: '06',
		title: 'Usługi dodatkowe',
		text: 'Odkurzacze, rozmieniarki, pranie dywaników, dyspensery, ozonator, płyny i inne urządzenia mogą zwiększać średni koszyk oraz wydłużać kontakt klienta z obiektem.'
	}
];

const costGroups = [
	{
		title: 'Koszty zmienne',
		text: 'Rosną razem z liczbą myć i intensywnością korzystania z obiektu.',
		points: ['woda i ścieki', 'energia elektryczna', 'ogrzewanie wody', 'detergenty i chemia', 'prowizje płatnicze', 'elementy eksploatacyjne']
	},
	{
		title: 'Koszty stałe i organizacyjne',
		text: 'Pojawiają się niezależnie od tego, czy dany miesiąc jest mocny czy słabszy.',
		points: ['dzierżawa albo czynsz', 'księgowość i obsługa prawna', 'internet, telefon, monitoring', 'ubezpieczenie', 'podatek od nieruchomości', 'marketing lokalny']
	},
	{
		title: 'Koszty finansowania',
		text: 'W wielu inwestycjach to element, który mocno zmienia przepływ gotówki.',
		points: ['leasing', 'kredyt', 'wkład własny', 'odsetki', 'zabezpieczenia', 'harmonogram spłat']
	},
	{
		title: 'Koszty okresowe',
		text: 'Nie występują codziennie, ale trzeba je uwzględnić w modelu rocznym.',
		points: ['czyszczenie separatora', 'przeglądy', 'serwis i naprawy', 'odśnieżanie', 'wymiany części', 'modernizacje']
	}
];

const efficiencySlides = [
	{
		kicker: 'Media',
		title: 'Woda, ścieki i energia mogą zmienić wynik',
		text: 'Różnice w technologii, odzysku wody, źródłach ciepła, cenach mediów i sposobie eksploatacji mogą znacząco zmieniać koszt jednego mycia.'
	},
	{
		kicker: 'Czas mycia',
		title: 'Jedna złotówka musi mieć ekonomiczny sens',
		text: 'Na rynku często spotyka się czasy mycia w okolicach 20–32 sekund za 1 zł, zależnie od lokalizacji i ustawień. Zbyt długi czas może obniżać rentowność.'
	},
	{
		kicker: 'Serwis',
		title: 'Przestój to utracony przychód',
		text: 'Łatwy dostęp do komponentów, sprawny serwis, dobra konstrukcja serca myjni i szybka diagnostyka pomagają ograniczać czas, w którym obiekt nie zarabia.'
	},
	{
		kicker: 'Technologia',
		title: 'Droższy wariant może obniżać koszt w czasie',
		text: 'Wyższy koszt początkowy może mieć sens, jeśli technologia zmniejsza zużycie mediów, poprawia trwałość komponentów i stabilność pracy obiektu.'
	}
];

const returnScenarios = [
	{
		label: 'Bardzo mocna lokalizacja',
		value: 'poniżej 36 miesięcy',
		text: 'Możliwe w lokalizacjach o wysokim ruchu, dobrej widoczności, wygodnym układzie i wysokim wykorzystaniu stanowisk. To scenariusz ambitny, nie standard.'
	},
	{
		label: 'Dobra, stabilna lokalizacja',
		value: 'około 5 lat',
		text: 'Często przyjmowany punkt odniesienia do spokojnej kalkulacji inwestora, pod warunkiem właściwego kosztu budowy i kontroli kosztów prowadzenia.'
	},
	{
		label: 'Spokojniejsza lokalizacja',
		value: 'około 7 lat lub dłużej',
		text: 'Wymaga ostrożniejszej konfiguracji, rozsądnej liczby stanowisk i bardzo dokładnego pilnowania kosztów stałych oraz finansowania.'
	}
];

const profitNotes = [
	{
		title: 'Model 50/50',
		text: 'W dobrze przygotowanym obiekcie często analizuje się scenariusz, w którym koszty i wynik przed podatkiem mogą układać się orientacyjnie w okolicach połowy przychodu. To model poglądowy, nie gwarancja.'
	},
	{
		title: 'Model z wysokimi kosztami',
		text: 'Przy drogim finansowaniu, wysokiej dzierżawie, dużej obsłudze, słabszej technologii albo wysokich mediach udział kosztów może być dużo wyższy.'
	},
	{
		title: 'Model zoptymalizowany',
		text: 'Własny grunt, dobra technologia, odzysk wody, fotowoltaika, korzystne media, studnia lub przemyślana eksploatacja mogą poprawiać rentowność, ale wymagają indywidualnej kalkulacji.'
	}
];

const faqItems = [
	{
		question: 'Ile zarabia myjnia bezdotykowa miesięcznie?',
		answer:
			'Nie ma jednej uczciwej kwoty. Wynik zależy od lokalizacji, liczby stanowisk, liczby myć, średniego koszyka, kosztów mediów, chemii, serwisu, finansowania i organizacji pracy. Najpierw trzeba policzyć przychód, koszty i realny wynik inwestora.'
	},
	{
		question: 'Ile może zarabiać jedno stanowisko myjni?',
		answer:
			'W dobrej lokalizacji jedno stanowisko może generować wysoki miesięczny obrót, nawet około 20 000 zł brutto. To jednak przykład potencjału, a nie gwarancja. W słabszej lokalizacji wynik może być dużo niższy.'
	},
	{
		question: 'Czy przychód z myjni to zysk?',
		answer:
			'Nie. Przychód to obrót z myć i usług dodatkowych. Zysk pojawia się dopiero po odjęciu kosztów zmiennych, kosztów stałych, kosztów finansowania, podatków, serwisu i rezerw.'
	},
	{
		question: 'Jakie koszty najbardziej wpływają na rentowność myjni?',
		answer:
			'Największe znaczenie mają zwykle media, ścieki, energia, ogrzewanie, chemia, serwis, dzierżawa, leasing, prowizje płatnicze, obsługa, podatek od nieruchomości, separator, ubezpieczenie i koszty okresowe.'
	},
	{
		question: 'Czy myjnia bezdotykowa się opłaca?',
		answer:
			'Może być opłacalną inwestycją, ale tylko wtedy, gdy lokalizacja, koszt budowy, technologia, liczba stanowisk, koszty prowadzenia i model finansowania są dobrze dopasowane. Sama budowa myjni nie gwarantuje zysku.'
	},
	{
		question: 'Po ilu latach zwraca się myjnia bezdotykowa?',
		answer:
			'W bardzo mocnych lokalizacjach zwrot może nastąpić poniżej 36 miesięcy, w stabilnych lokalizacjach często analizuje się około 5 lat, a w spokojniejszych lokalizacjach około 7 lat lub dłużej. Każdy przypadek wymaga indywidualnej kalkulacji.'
	},
	{
		question: 'Czy technologia wpływa na zysk myjni?',
		answer:
			'Tak. Technologia wpływa na zużycie wody, ścieków, energii, chemii, awaryjność, łatwość serwisu, jakość mycia i przestoje. Dlatego dostawcę trzeba oceniać nie tylko po cenie zakupu.'
	},
	{
		question: 'Czy leasing obniża zysk myjni?',
		answer:
			'Leasing wpływa na przepływ gotówki i wynik finansowy inwestora. Może ułatwić uruchomienie inwestycji, ale zwiększa miesięczne obciążenia. Warto go analizować z księgową, doradcą podatkowym i leasingodawcą.'
	}
];

const relatedLinks = [
	['Koszt budowy myjni', '/ile-kosztuje-myjnia-bezdotykowa/'],
	['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Jak porównać oferty?', '/jak-porownac-oferty-myjni-bezdotykowej/'],
	['Budowa krok po kroku', '/budowa-myjni-bezdotykowej-krok-po-kroku/'],
	['Błędy inwestora', '/najczestsze-bledy-przy-budowie-myjni/'],
	['Poradnik inwestora', '/poradnik/']
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};
---

<Layout title={page.title} description={page.description} canonicalPath={page.canonicalPath}>
	<Header />

	<main class="profit-page">
		<section class="profit-hero" aria-labelledby="page-title">
			<div class="container profit-hero-grid">
				<div class="profit-hero-copy">
					<p class="eyebrow">
						<span></span>
						Opłacalność myjni
					</p>

					<h1 id="page-title">
						Ile zarabia myjnia bezdotykowa i od czego zależy
						<strong>realny zwrot?</strong>
					</h1>

					<p class="profit-lead">
						Zarobek myjni nie wynika wyłącznie z liczby stanowisk. Najpierw trzeba
						policzyć przychód, koszty, finansowanie, podatki i realny potencjał
						lokalizacji.
					</p>

					<div class="profit-actions">
						<a class="profit-button-green" href="/#kontakt">
							Prześlij lokalizację
							<span aria-hidden="true">→</span>
						</a>
						<a class="profit-button-light" href="#model-wyniku">
							Zobacz model wyniku
							<span aria-hidden="true">↓</span>
						</a>
					</div>

					<div class="profit-chips" aria-label="Najważniejsze tematy strony">
						<span>przychód</span>
						<span>koszty</span>
						<span>zysk</span>
						<span>zwrot</span>
						<span>lokalizacja</span>
					</div>
				</div>

				<aside class="profit-hero-panel" aria-label="Najważniejszy wniosek">
					<div class="profit-panel-logo">inwestycjawmyjnie.pl</div>
					<p>Najważniejsza zasada</p>
					<h2>Obrót nie jest jeszcze zyskiem.</h2>
					<span>
						Dopiero po odjęciu kosztów mediów, chemii, serwisu, finansowania, podatków
						i rezerw widać realny wynik inwestora.
					</span>
					<div class="profit-mini-grid">
						<b>przychód</b>
						<b>koszty</b>
						<b>cash flow</b>
						<b>zwrot</b>
					</div>
				</aside>
			</div>
		</section>

		<section class="profit-section" id="model-wyniku" aria-labelledby="model-title">
			<div class="container">
				<div class="profit-split">
					<div>
						<p class="eyebrow"><span></span>Krótka odpowiedź</p>
						<h2 id="model-title">
							Myjnię trzeba liczyć jako <strong>model przychodu i kosztów</strong>
						</h2>
					</div>
					<p>
						Pytanie „ile zarabia myjnia?” ma sens dopiero wtedy, gdy oddzielimy
						przychód od zysku. Inwestor powinien patrzeć na obrót, koszty operacyjne,
						finansowanie, podatki i rezerwę na serwis.
					</p>
				</div>

				<div class="profit-model-grid">
					{revenueModel.map((item, index) => (
						<article class="profit-model-card">
							<span>{String(index + 1).padStart(2, '0')}</span>
							<p>{item.label}</p>
							<h3>{item.title}</h3>
							<b>{item.text}</b>
						</article>
					))}
				</div>

				<p class="profit-disclaimer">
					W dobrej lokalizacji jedno stanowisko może generować nawet około 20 000 zł brutto
					miesięcznie, ale to przykład potencjału, nie obietnica wyniku. Każdą lokalizację
					trzeba policzyć osobno.
				</p>
			</div>
		</section>

		<section class="profit-section profit-text-section" aria-labelledby="revenue-title">
			<div class="container profit-article-grid">
				<div class="profit-sticky-title">
					<p class="eyebrow"><span></span>Przychód</p>
					<h2 id="revenue-title">
						Najpierw trzeba zrozumieć, <strong>skąd bierze się obrót</strong>
					</h2>
				</div>

				<div class="profit-article-copy profit-article-card">
					<p>
						Przychód z myjni powstaje wtedy, gdy lokalizacja regularnie przyciąga kierowców,
						a obiekt jest wygodny, widoczny, dobrze zaprojektowany i technicznie przygotowany
						do obsługi ruchu.
					</p>

					<p>
						Kluczowe znaczenie ma nie tylko liczba stanowisk, ale też ich wykorzystanie.
						Za mała myjnia w mocnej lokalizacji może tworzyć kolejki, a zbyt duża myjnia
						w spokojnym miejscu może nie wykorzystywać swojego potencjału.
					</p>

					<p>
						Dlatego przychód trzeba analizować razem z działką, układem komunikacyjnym,
						widocznością, ruchem samochodowym, konkurencją, standardem wizualnym, jakością
						mycia i urządzeniami dodatkowymi.
					</p>

					<div class="profit-quote">
						<strong>Celem nie jest samo zbudowanie myjni.</strong>
						<span>Celem jest przygotowanie obiektu, który potrafi regularnie generować przychód.</span>
					</div>
				</div>
			</div>
		</section>

		<section class="profit-section" aria-labelledby="factors-title">
			<div class="container">
				<div class="profit-split">
					<div>
						<p class="eyebrow"><span></span>Źródła przychodu</p>
						<h2 id="factors-title">
							Co wpływa na <strong>wynik myjni?</strong>
						</h2>
					</div>
					<p>
						Ten sam obiekt może mieć zupełnie inny wynik w zależności od lokalizacji,
						standardu, projektu ruchu, technologii i sposobu prowadzenia.
					</p>
				</div>

				<div class="profit-factor-grid">
					{revenueFactors.map((factor) => (
						<article class="profit-factor-card">
							<span>{factor.number}</span>
							<h3>{factor.title}</h3>
							<p>{factor.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="profit-section" aria-labelledby="costs-title">
			<div class="container">
				<div class="profit-split">
					<div>
						<p class="eyebrow"><span></span>Koszty prowadzenia</p>
						<h2 id="costs-title">
							Koszty decydują, ile z przychodu <strong>zostaje inwestorowi</strong>
						</h2>
					</div>
					<p>
						W myjni trzeba oddzielić koszty zmienne, stałe, finansowe i okresowe.
						Dopiero ich suma pokazuje realną rentowność.
					</p>
				</div>

				<div class="profit-cost-grid">
					{costGroups.map((group) => (
						<article class="profit-cost-card">
							<h3>{group.title}</h3>
							<p>{group.text}</p>
							<ul>
								{group.points.map((point) => <li>{point}</li>)}
							</ul>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="profit-section" aria-labelledby="technology-title">
			<div class="container">
				<div class="profit-carousel" data-profit-carousel>
					<div class="profit-carousel-head">
						<div>
							<p class="eyebrow light"><span></span>Technologia i rentowność</p>
							<h2 id="technology-title">
								Dostawca wpływa nie tylko na cenę, ale też <strong>na późniejszy zysk</strong>
							</h2>
						</div>
						<div class="profit-carousel-nav" aria-label="Nawigacja slajdera">
							<button type="button" data-profit-prev aria-label="Poprzedni element">←</button>
							<button type="button" data-profit-next aria-label="Następny element">→</button>
						</div>
					</div>

					<div class="profit-carousel-track" data-profit-track>
						{efficiencySlides.map((slide) => (
							<article class="profit-slide">
								<span>{slide.kicker}</span>
								<h3>{slide.title}</h3>
								<p>{slide.text}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="profit-section" aria-labelledby="return-title">
			<div class="container">
				<div class="profit-split">
					<div>
						<p class="eyebrow"><span></span>Zwrot z inwestycji</p>
						<h2 id="return-title">
							Realny zwrot zależy od scenariusza <strong>lokalizacji i kosztów</strong>
						</h2>
					</div>
					<p>
						Nie da się uczciwie wyliczyć jednej statystyki dla każdej myjni. Można jednak
						przygotować scenariusze i sprawdzić, czy inwestycja mieści się w akceptowalnym
						horyzoncie zwrotu.
					</p>
				</div>

				<div class="profit-return-grid">
					{returnScenarios.map((scenario) => (
						<article class="profit-return-card">
							<p>{scenario.label}</p>
							<strong>{scenario.value}</strong>
							<span>{scenario.text}</span>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="profit-section profit-profitability-section" aria-labelledby="profitability-title">
			<div class="container">
				<div class="profitability-panel">
					<div>
						<p class="eyebrow light"><span></span>Rentowność</p>
						<h2 id="profitability-title">
							Na wynik wpływa nie tylko obrót, ale też <strong>konfiguracja kosztów</strong>
						</h2>
						<p>
							W praktyce model kosztów może wyglądać bardzo różnie. Własny grunt, leasing,
							dzierżawa, odzysk wody, źródło ciepła, fotowoltaika, serwis i sposób obsługi
							mogą całkowicie zmienić wynik inwestora.
						</p>
					</div>

					<div class="profit-note-grid">
						{profitNotes.map((note) => (
							<article>
								<h3>{note.title}</h3>
								<p>{note.text}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="profit-section" aria-labelledby="analysis-title">
			<div class="container">
				<div class="profit-analysis-cta">
					<div>
						<p class="eyebrow light"><span></span>Analiza lokalizacji</p>
						<h2 id="analysis-title">
							Chcesz policzyć potencjał przychodu <strong>dla swojej działki?</strong>
						</h2>
						<p>
