---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/ile-kosztuje-myjnia-bezdotykowa/',
	title: 'Ile kosztuje myjnia bezdotykowa? Koszt budowy i budżet inwestora',
	description:
		'Ile kosztuje myjnia bezdotykowa? Sprawdź orientacyjny koszt budowy myjni 2, 3, 4, 5 i 6 stanowisk oraz elementy, które realnie wpływają na budżet inwestora.'
};

const costRows = [
	{
		stations: '2 stanowiska',
		amount: '500 000 zł netto',
		note: 'bezpieczna wartość kalkulacyjna dla prostego modelu inwestora'
	},
	{
		stations: '3 stanowiska',
		amount: '600 000 zł netto',
		note: 'wariant często wybierany jako pierwszy realny obiekt inwestycyjny'
	},
	{
		stations: '4 stanowiska',
		amount: '850 000 zł netto',
		note: 'większy potencjał, ale też większe znaczenie układu działki i zakresu prac'
	},
	{
		stations: '5 stanowisk',
		amount: '1 100 000 zł netto',
		note: 'wariant wymagający mocniejszej lokalizacji i przemyślanego ruchu na obiekcie'
	},
	{
		stations: '6 stanowisk',
		amount: '1 300 000 zł netto',
		note: 'większa inwestycja, zwykle wymagająca dokładniejszej analizy potencjału'
	}
];

const keyFactors = [
	{
		number: '01',
		title: 'Działka i lokalizacja',
		text: 'To punkt wyjścia do rozmowy o cenie. Ten sam obiekt może mieć podobny koszt budowy w mieście i poza miastem, ale zupełnie inny potencjał przychodu.'
	},
	{
		number: '02',
		title: 'Liczba stanowisk',
		text: 'Więcej stanowisk to nie tylko większy obiekt. To także inny układ ruchu, większa technologia, większy zakres instalacji i inne wymagania wobec działki.'
	},
	{
		number: '03',
		title: 'Zakres dostawcy',
		text: 'Jedna oferta może obejmować głównie technologię, inna także kontener, konstrukcję, automatykę, montaż, serwis, szkolenie i szerszy pakiet uruchomienia.'
	},
	{
		number: '04',
		title: 'Prace budowlane',
		text: 'Przygotowanie terenu, instalacje, posadzka, odwodnienie, przyłącza, drogi manewrowe i zagospodarowanie mogą istotnie zmienić całkowity budżet.'
	},
	{
		number: '05',
		title: 'Technologia i wyposażenie',
		text: 'Pompy, sterowanie, programy, chemia, płatności, filtracja, zabezpieczenia, urządzenia dodatkowe i rozwiązania eksploatacyjne wpływają na cenę i późniejsze koszty.'
	},
	{
		number: '06',
		title: 'Finansowanie i podatki',
		text: 'Leasing, amortyzacja i rozliczenia podatkowe mogą zmienić sposób patrzenia na droższy lub tańszy wariant, ale trzeba je omówić z księgową albo doradcą.'
	}
];

const locationCards = [
	{
		title: 'Lokalizacja miejska',
		text: 'Zwykle większy potencjał ruchu, wyższa konkurencja, większe znaczenie widoczności, wygody wjazdu i dopasowania standardu obiektu do otoczenia.'
	},
	{
		title: 'Lokalizacja podmiejska',
		text: 'Często dobry kompromis między kosztem gruntu, ruchem lokalnym i możliwością budowy większego, wygodniejszego układu stanowisk.'
	},
	{
		title: 'Mniejsza miejscowość lub wieś',
		text: 'Koszt budowy może być podobny, ale model przychodu i sens rozbudowanej konfiguracji trzeba ocenić dużo ostrożniej.'
	}
];

const componentCards = [
	['01', 'Kontener lub moduł techniczny', 'Serce myjni: technologia, instalacje, sterowanie, chemia, zabezpieczenia i rozwiązania techniczne. Zakres tego elementu bardzo różni się między producentami.'],
	['02', 'Technologia mycia', 'Pompy, programy, system dozowania, płatności, automatyka, filtracja, zabezpieczenia i elementy odpowiedzialne za jakość oraz stabilność pracy.'],
	['03', 'Posadzka', 'Może być monolityczna albo prefabrykowana. Wybór zależy od projektu, organizacji budowy, czasu realizacji, gruntu i sposobu prowadzenia inwestycji.'],
	['04', 'Konstrukcja i zabudowa', 'Dach, słupy, attyka, panele, oświetlenie i wygląd obiektu. Często muszą pasować do wymagań planu miejscowego albo architektury otoczenia.'],
	['05', 'Urządzenia zewnętrzne SPA', 'Odkurzacze, rozmieniarki, dyspensery, pranie dywaników, ozonator, nalewak płynu i inne dodatki, które wpływają na przychód oraz koszt inwestycji.'],
	['06', 'Projekt, kierownik i formalności', 'Projektant, dokumentacja, uzgodnienia branżowe, warunki techniczne, kierownik budowy i formalne przygotowanie procesu inwestycyjnego.'],
	['07', 'Prace instalacyjno-budowlane', 'Roboty ziemne, fundamenty, instalacje podziemne, przyłącza, odwodnienie, drogi manewrowe, kanalizacja i przygotowanie terenu.'],
	['08', 'Serwis, gwarancja i szkolenie', 'Cena powinna być oceniana razem z opieką po zakupie, szkoleniem, dostępnością serwisu, części i odpowiedzialnością za całość rozwiązania.']
];

const comparisonSlides = [
	{
		kicker: 'Błąd inwestora',
		title: 'Zbieranie ofert bez analizy działki',
		text: 'Jeżeli nie wiadomo, co realnie można zbudować, porównywanie ofert staje się porównywaniem przypadkowych zakresów, a nie realnych rozwiązań.'
	},
	{
		kicker: 'Zakres oferty',
		title: 'Cena może oznaczać coś zupełnie innego',
		text: 'W jednej ofercie w cenie może być więcej elementów, w drugiej mniej. Dlatego najtańsza oferta nie zawsze oznacza najtańszą inwestycję.'
	},
	{
		kicker: 'Lokalizacja',
		title: 'Taki sam koszt, inna rentowność',
		text: 'Obiekt w mocnej lokalizacji i obiekt w słabej lokalizacji mogą kosztować podobnie, ale ich przychody i sens konfiguracji mogą być całkowicie różne.'
	},
	{
		kicker: 'Decyzja',
		title: 'Najpierw budżet, potem dostawca',
		text: 'Dostawcę warto wybierać po analizie lokalizacji, budżetu, zakresu inwestycji, jakości komponentów, serwisu i dopasowania do planu finansowego.'
	}
];

const faqItems = [
	{
		question: 'Ile kosztuje myjnia bezdotykowa?',
		answer:
			'Orientacyjnie do prostego kalkulatora inwestora można przyjąć około 500 000 zł netto dla 2 stanowisk, 600 000 zł netto dla 3 stanowisk, 850 000 zł netto dla 4 stanowisk, 1 100 000 zł netto dla 5 stanowisk i 1 300 000 zł netto dla 6 stanowisk. To wartości kalkulacyjne, a nie gotowe oferty.'
	},
	{
		question: 'Dlaczego nie da się rzetelnie podać jednej ceny myjni?',
		answer:
			'Bo cena zależy od działki, liczby stanowisk, technologii, zakresu dostawcy, konstrukcji, posadzki, kontenera, przyłączy, prac budowlanych, projektu, urządzeń dodatkowych, transportu, montażu, serwisu i lokalnych warunków formalnych.'
	},
	{
		question: 'Czy warto zbierać oferty od wszystkich producentów myjni?',
		answer:
			'Samo zbieranie ofert bez analizy działki często prowadzi do chaosu. Najpierw warto sprawdzić potencjał lokalizacji, możliwy układ obiektu, media i budżet, a dopiero później porównywać oferty według tego samego zakresu.'
	},
	{
		question: 'Czy lokalizacja wpływa na koszt myjni?',
		answer:
			'Lokalizacja wpływa nie tylko na koszt, ale przede wszystkim na sens konfiguracji. Myjnia w mieście, przy trasie, na przedmieściach albo w małej miejscowości może wymagać innego zakresu, innej liczby stanowisk i innego poziomu wyposażenia.'
	},
	{
		question: 'Co można zrobić metodą gospodarczą?',
		answer:
			'Część inwestorów wykonuje we własnym zakresie prace instalacyjno-budowlane, posadzkę w uzgodnieniu z projektem, konstrukcję, zabudowę wizualną albo zakup urządzeń dodatkowych. Trzeba jednak sprawdzić wpływ takiego modelu na gwarancję, odpowiedzialność, bezpieczeństwo i spójność całego projektu.'
	},
	{
		question: 'Czy myjnię można finansować leasingiem?',
		answer:
			'W praktyce elementy technologiczne i wyposażenie mogą być przedmiotem finansowania, ale szczegóły zależą od struktury inwestycji, dostawcy, formy prawnej, zabezpieczeń i decyzji instytucji finansującej. Warto omówić to z leasingodawcą oraz księgową przed wyborem wariantu.'
	},
	{
		question: 'Czy myjnię można amortyzować?',
		answer:
			'Amortyzacja zależy od klasyfikacji poszczególnych elementów inwestycji, sposobu ich nabycia, rodzaju środka trwałego i przyjętych zasad podatkowych. Nie należy zakładać jednej stawki dla całej inwestycji bez konsultacji z księgową albo doradcą podatkowym.'
	},
	{
		question: 'Czy najtańsza oferta na myjnię jest najlepsza?',
		answer:
			'Nie zawsze. Niższa cena może oznaczać mniejszy zakres, słabsze komponenty, mniej zabezpieczeń, ograniczony serwis albo koszty, które pojawią się dopiero po podpisaniu umowy lub na etapie budowy.'
	}
];

const relatedLinks = [
	['Opłacalność myjni', '/ile-zarabia-myjnia-bezdotykowa/'],
	['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Jak porównać oferty?', '/jak-porownac-oferty-myjni-bezdotykowej/'],
	['Budowa krok po kroku', '/budowa-myjni-bezdotykowej-krok-po-kroku/'],
	['Błędy inwestora', '/najczestsze-bledy-przy-budowie-myjni/'],
	['Poradnik inwestora', '/poradnik/']
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};
---

<Layout title={page.title} description={page.description} canonicalPath={page.canonicalPath}>
	<Header />

	<main class="cost-page">
		<section class="cost-hero" aria-labelledby="page-title">
			<div class="container cost-hero-grid">
				<div class="cost-hero-copy">
					<p class="eyebrow">
						<span></span>
						Koszt budowy myjni
					</p>

					<h1 id="page-title">
						Ile kosztuje myjnia bezdotykowa i dlaczego sama
						<strong>oferta producenta to za mało?</strong>
					</h1>

					<p class="cost-lead">
						Cena myjni nie zaczyna się od rabatu. Zaczyna się od działki,
						lokalizacji, potencjału przychodu, zakresu inwestycji, technologii,
						sposobu budowy i finansowania.
					</p>

					<div class="cost-actions">
						<a class="cost-button-green" href="/#kontakt">
							Prześlij lokalizację
							<span aria-hidden="true">→</span>
						</a>
						<a class="cost-button-light" href="#orientacyjne-koszty">
							Zobacz widełki kosztów
							<span aria-hidden="true">↓</span>
						</a>
					</div>

					<div class="cost-chips" aria-label="Najważniejsze tematy strony">
						<span>działka</span>
						<span>liczba stanowisk</span>
						<span>technologia</span>
						<span>budowa</span>
						<span>leasing</span>
					</div>
				</div>

				<aside class="cost-hero-panel" aria-label="Najważniejszy wniosek">
					<div class="cost-panel-logo">inwestycjawmyjnie.pl</div>
					<p>Najważniejsza zasada</p>
					<h2>Nie porównuj ceny, dopóki nie znasz zakresu.</h2>
					<span>
						Dwie oferty mogą mieć podobną kwotę, ale zupełnie inny zakres technologii,
						budowy, serwisu, gwarancji i odpowiedzialności.
					</span>
					<div class="cost-mini-grid">
						<b>działka</b>
						<b>budżet</b>
						<b>zakres</b>
						<b>finansowanie</b>
					</div>
				</aside>
			</div>
		</section>

		<section class="cost-section" id="orientacyjne-koszty" aria-labelledby="cost-table-title">
			<div class="container">
				<div class="cost-split">
					<div>
						<p class="eyebrow"><span></span>Krótka odpowiedź</p>
						<h2 id="cost-table-title">
							Orientacyjny koszt myjni <strong>w kalkulatorze inwestora</strong>
						</h2>
					</div>
					<p>
						Poniższe wartości traktuj jako bezpieczne założenia do wstępnej rozmowy,
						a nie jako gotową ofertę. Cena może być niższa albo wyższa w zależności
						od zakresu, działki, producenta i prac dodatkowych.
					</p>
				</div>

				<div class="cost-table-panel">
					{costRows.map((row) => (
						<article class="cost-row">
							<div>
								<strong>{row.stations}</strong>
								<p>{row.note}</p>
							</div>
							<b>{row.amount}</b>
						</article>
					))}
				</div>

				<p class="cost-disclaimer">
					To są wartości kalkulacyjne netto na 2026 rok. Ostateczna cena zależy od
					konfiguracji, technologii, konstrukcji, posadzki, kontenera, urządzeń SPA,
					przyłączy, projektu, montażu, transportu, prac budowlanych oraz warunków
					konkretnej lokalizacji.
				</p>
			</div>
		</section>

		<section class="cost-section cost-text-section" aria-labelledby="why-title">
	<div class="container cost-article-grid">
		<div class="cost-sticky-title">
			<p class="eyebrow"><span></span>Błąd na starcie</p>
			<h2 id="why-title">
				Dlaczego samo zbieranie ofert <strong>może wprowadzić w błąd?</strong>
			</h2>
		</div>

		<div class="cost-article-copy cost-article-card">
			<p>
				Najważniejsze pytanie inwestora brzmi: <strong>ile kosztuje myjnia bezdotykowa?</strong>
				To naturalne, bo inwestor chce wiedzieć, czy budżet jest realny i czy temat
				warto rozwijać. Problem zaczyna się wtedy, gdy cała decyzja sprowadza się
				do zebrania ofert od producentów i negocjowania najniższej ceny.
			</p>

			<p>
				Wielu inwestorów porównuje oferty bez wiedzy, co faktycznie znajduje się
				w zakresie, czego nie ma, jaki jest standard technologii, jak wygląda serwis,
				jakie będą koszty po zakupie i czy proponowana konfiguracja pasuje do
				konkretnej działki.
			</p>

			<p>
				Dodatkowo część osób szuka odpowiedzi na grupach myjniowych, forach albo
				w mediach społecznościowych. To może być pomocne informacyjnie, ale nie może
				zastąpić analizy konkretnej lokalizacji. Myjnia jest inwestycją bardzo
				indywidualną, a cudze doświadczenie może dotyczyć zupełnie innej działki,
				innego rynku, innej technologii i innego modelu finansowania.
			</p>

			<div class="cost-quote">
				<strong>Najpierw trzeba ustalić, co warto zbudować.</strong>
				<span>Dopiero potem ma sens pytanie, kto zrobi to najlepiej i za jaką cenę.</span>
			</div>
		</div>
	</div>
</section>

		<section class="cost-section" aria-labelledby="location-title">
			<div class="container">
				<div class="cost-split">
					<div>
						<p class="eyebrow"><span></span>Najpierw działka</p>
						<h2 id="location-title">
							Lokalizacja decyduje, czy dana cena <strong>ma sens</strong>
						</h2>
					</div>
					<p>
						Myjnia o podobnym koszcie może działać w centrum miasta, na przedmieściach
						albo w małej miejscowości. Ale jej potencjał przychodu, rentowność i sens
						wyposażenia mogą być diametralnie różne.
					</p>
				</div>

				<div class="location-card-grid">
					{locationCards.map((card, index) => (
						<article class="location-context-card">
							<span>{String(index + 1).padStart(2, '0')}</span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="cost-section" aria-labelledby="factors-title">
			<div class="container">
				<div class="cost-split">
					<div>
						<p class="eyebrow"><span></span>Co wpływa na koszt?</p>
						<h2 id="factors-title">
							Cena myjni składa się z wielu <strong>warstw decyzji</strong>
						</h2>
					</div>
					<p>
						Dopiero suma tych elementów pokazuje, czy oferta jest tania, droga,
						kompletna, niepełna, bezpieczna albo ryzykowna.
					</p>
				</div>

				<div class="factor-grid">
					{keyFactors.map((factor) => (
						<article class="factor-card">
							<span>{factor.number}</span>
							<h3>{factor.title}</h3>
							<p>{factor.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="cost-section" aria-labelledby="components-title">
			<div class="container">
				<div class="cost-split">
					<div>
						<p class="eyebrow"><span></span>Składniki budżetu</p>
						<h2 id="components-title">
							Co realnie wchodzi <strong>w koszt myjni?</strong>
						</h2>
					</div>
					<p>
						Przy porównaniu ofert trzeba oddzielić cenę technologii od całkowitego
						kosztu inwestycji. To dwie różne rzeczy.
					</p>
				</div>

				<div class="component-grid">
					{componentCards.map((card) => (
						<article class="component-card">
							<span>{card[0]}</span>
							<h3>{card[1]}</h3>
							<p>{card[2]}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="cost-section" aria-labelledby="offers-title">
			<div class="container">
				<div class="cost-carousel" data-cost-carousel>
					<div class="cost-carousel-head">
						<div>
							<p class="eyebrow light"><span></span>Porównanie ofert</p>
							<h2 id="offers-title">
								Nie każda cena oznacza <strong>ten sam zakres</strong>
							</h2>
						</div>
						<div class="cost-carousel-nav" aria-label="Nawigacja slajdera">
							<button type="button" data-cost-prev aria-label="Poprzedni element">←</button>
							<button type="button" data-cost-next aria-label="Następny element">→</button>
						</div>
					</div>

					<div class="cost-carousel-track" data-cost-track>
						{comparisonSlides.map((slide) => (
							<article class="cost-slide">
								<span>{slide.kicker}</span>
								<h3>{slide.title}</h3>
								<p>{slide.text}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="cost-section model-section" aria-labelledby="model-title">
	<div class="container model-grid">
		<div class="model-intro">
			<p class="eyebrow"><span></span>Zakres realizacji</p>

			<h2 id="model-title">
				Metoda gospodarcza czy <strong>kompleksowa realizacja?</strong>
			</h2>

			<p class="model-lead">
				Część elementów można wykonać we własnym zakresie, ale trzeba sprawdzić,
				jak wpływa to na gwarancję, odpowiedzialność, bezpieczeństwo i spójność projektu.
			</p>
		</div>

		<div class="model-cards">
			<article>
				<h3>Elementy, które inwestor czasem wykonuje sam</h3>
				<ul>
					<li>prace instalacyjno-budowlane</li>
					<li>posadzka w uzgodnieniu z projektem</li>
					<li>konstrukcja i zabudowa wizualna</li>
					<li>zakup wybranych urządzeń SPA na wolnym rynku</li>
					<li>część zagospodarowania terenu</li>
				</ul>
			</article>

			<article>
				<h3>Pytania, które trzeba zadać przed taką decyzją</h3>
				<ul>
					<li>kto odpowiada za całość projektu?</li>
					<li>co dzieje się z gwarancją?</li>
					<li>czy elementy są zgodne z technologią?</li>
