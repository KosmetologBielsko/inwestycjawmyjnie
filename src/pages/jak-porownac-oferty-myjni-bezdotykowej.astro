---

import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/jak-porownac-oferty-myjni-bezdotykowej/',
	title: 'Jak porównać oferty myjni bezdotykowej? Cena, zakres i technologia',
	description:
		'Jak porównać oferty producentów myjni bezdotykowych? Sprawdź zakres, technologię, posadzkę, konstrukcję, dokumentację, umowę, serwis, gwarancję i koszty eksploatacji.'
};

const heroChips = [
	'zakres oferty',
	'technologia',
	'posadzka',
	'dokumentacja',
	'umowa',
	'serwis'
];

const decisionCards = [
	{
		number: '01',
		title: 'Cena nie pokazuje zakresu',
		text: 'Dwie oferty mogą mieć podobną kwotę, ale obejmować zupełnie inne elementy: kontener, moduł, posadzkę, konstrukcję, dokumentację, montaż, szkolenie albo serwis.'
	},
	{
		number: '02',
		title: 'Technologia pracuje codziennie',
		text: 'Najważniejsze elementy są często niewidoczne: pompy, zawory, automatyka, dozowanie, uzdatnianie wody, ogrzewanie, zabezpieczenia zimowe i dostęp serwisowy.'
	},
	{
		number: '03',
		title: 'Oferta musi bronić się po latach',
		text: 'Myjnia jest inwestycją długoterminową. Niższa cena początkowa może oznaczać wyższe koszty mediów, dłuższe przestoje albo trudniejszy serwis.'
	}
];

const criteriaCards = [
	['01', 'Zakres oferty', 'Co dokładnie obejmuje cena: technologia, kontener, moduł, posadzka, konstrukcja, zabudowa, montaż, dokumentacja, szkolenie, serwis i uruchomienie?'],
	['02', 'Kontener czy moduł', 'Jak wygląda przestrzeń techniczna, dostęp do serwisu, wentylacja, izolacja, ergonomia pracy i możliwość przyszłej rozbudowy?'],
	['03', 'Rodzaj chemii', 'Czy system działa na chemii płynnej, proszkowej albo mieszanej? Jak wpływa to na dozowanie, logistykę, jakość mycia, serwis i koszt pracy?'],
	['04', 'Posadzka', 'Czy oferta obejmuje płytę monolityczną, prefabrykowaną albo inny system? Jak rozwiązano odpływy, ogrzewanie, instalacje i ryzyko pęknięć?'],
	['05', 'Konstrukcja', 'Czy konstrukcja jest dopasowana do projektu, zapisów MPZP, działki, obciążeń, liczby stanowisk i sposobu montażu technologii?'],
	['06', 'Zabudowa wizualna', 'Jakie materiały, attyka, słupy, panele, oświetlenie i detale wpływają na odbiór obiektu oraz późniejszą trwałość wizualną?'],
	['07', 'Technologia mycia', 'Pompy, programy, ciśnienie, piana, osmoza, uzdatnianie wody, dozowanie, ogrzewanie i zabezpieczenia zimowe decydują o pracy obiektu.'],
	['08', 'Komponenty', 'Jakie zastosowano zawory, przewody, mocowania, szafy, sterowanie, izolację, wentylację, manometry, systemy bezpieczeństwa i elementy robocze?'],
	['09', 'Koszty eksploatacji', 'Porównuj zużycie wody, ścieków, energii, chemii, ogrzewania, części, serwisu oraz wpływ technologii na czas mycia za 1 zł.'],
	['10', 'Serwis i gwarancja', 'Sprawdź czas reakcji, zasady zgłoszeń, warunki gwarancji, wyłączenia, przeglądy, części, wsparcie i opiekę po uruchomieniu.'],
	['11', 'Dokumentacja', 'Czy producent daje tylko dokumentację do pozwolenia na budowę, czy również pełniejszy projekt techniczny z instalacjami i konstrukcją?'],
	['12', 'Umowa i odpowiedzialność', 'Czy deklaracje handlowe są wpisane w umowę? Kto odpowiada za zakres, terminy, odbiory, płatności, zmiany i ewentualne problemy?']
];

const hiddenCostSlides = [
	{
		kicker: 'Cena końcowa',
		title: 'Nie mówi, co realnie kupujesz',
		text: 'Niższa cena może wynikać z mniejszego zakresu, słabszych komponentów, braku dokumentacji, krótszej gwarancji albo przerzucenia części prac na inwestora.'
	},
	{
		kicker: 'Budowa technologii',
		title: 'Wpływa na czas serwisu',
		text: 'Jeżeli dostęp do pomp, zaworów, dozowania albo sterowania jest utrudniony, każda awaria może oznaczać dłuższy postój i realną utratę przychodu.'
	},
	{
		kicker: 'Umowa',
		title: 'Musi potwierdzać rozmowę handlową',
		text: 'Warto sprawdzić, czy obietnice z prezentacji znajdują się w projekcie umowy: zakres, terminy, gwarancja, serwis, odbiory i odpowiedzialność producenta.'
	},
	{
		kicker: 'Jakość',
		title: 'Może być droższa, ale bezpieczniejsza',
		text: 'W tej branży nie szukasz wyłącznie najniższej ceny. Szukasz rozwiązania, które ogranicza ryzyko błędów, przestojów i kosztownych poprawek.'
	}
];

const systemCards = [
	{
		title: 'Kontener technologiczny',
		text: 'Pełniejsza przestrzeń techniczna może ułatwiać wentylację, izolację, serwis, dostęp do urządzeń, rozbudowę i uporządkowanie instalacji. Warto porównać nie tylko cenę, ale też ergonomię pracy w środku.'
	},
	{
		title: 'Moduł technologiczny',
		text: 'Mniejszy moduł może być atrakcyjny kosztowo i przestrzennie, ale trzeba sprawdzić dostęp do podzespołów, chłodzenie, obsługę serwisową, możliwość modernizacji i czas naprawy.'
	},
	{
		title: 'Chemia płynna / proszkowa',
		text: 'Rodzaj chemii wpływa na logistykę, dozowanie, koszty, jakość programu, serwis i powtarzalność efektu mycia. Nie chodzi o slogan, tylko o stabilny wynik na stanowisku.'
	}
];

const floorCards = [
	{
		title: 'Płyta monolityczna',
		text: 'Wymaga bardzo dobrej kontroli wykonania, betonu, zbrojenia, dylatacji, instalacji i ochrony ogrzewania. Błędy wykonawcze mogą powodować pęknięcia, przeróbki i kosztowne naprawy.'
	},
	{
		title: 'Posadzka prefabrykowana',
		text: 'Może dawać większą powtarzalność, precyzję instalacji i szybszą organizację budowy, ale powinna być częścią systemu technologicznego, a nie tylko gotowym elementem betonowym.'
	},
	{
		title: 'Instalacje w posadzce',
		text: 'Odpływy, ogrzewanie, arot, sterowanie, rury, odwodnienie i punkty montażowe muszą pasować do technologii, konstrukcji i rzeczywistego układu stanowisk.'
	}
];

const technologyPoints = [
	['Pompy i ciśnienie', 'Sprawdź nie tylko deklarowane ciśnienie, ale też stabilność pracy, drgania, żywotność i dostęp serwisowy.'],
	['Dozowanie chemii', 'Ważna jest niezależność stanowisk, powtarzalność dozowania i możliwość regulacji pod lokalne warunki.'],
	['Uzdatnianie wody', 'Filtracja, osmoza, jakość wody i ochrona membran wpływają na efekt mycia oraz koszty pracy.'],
	['Zabezpieczenie zimowe', 'Ogrzewanie posadzki, anti-freeze, obiegi i sterowanie muszą być oceniane pod polskie warunki zimowe.'],
	['Oszczędność mediów', 'Zużycie wody, ścieków, energii i chemii może mocno różnić się między technologiami. To wpływa na zysk przez lata.'],
	['Gotowość do modernizacji', 'Dobra technologia powinna umożliwiać późniejsze aktualizacje, serwis, wymianę elementów i rozwój programów.']
];

const documentationCards = [
	{
		number: '01',
		title: 'Projekt architektoniczno-budowlany',
		text: 'Służy głównie przejściu procedury pozwolenia na budowę. Pokazuje formalny zakres inwestycji, ale nie zawsze daje inwestorowi pełny obraz techniczny instalacji i konstrukcji.'
	},
	{
		number: '02',
		title: 'Projekt techniczny',
		text: 'To praktyczna dokumentacja branżowa: instalacje, konstrukcja, technologia i rozwiązania potrzebne do realizacji oraz późniejszych odbiorów po wybudowaniu obiektu.'
	},
	{
		number: '03',
		title: 'Wartość dodatkowa',
		text: 'Pełniejsza dokumentacja ogranicza chaos na budowie, ułatwia odbiory, porządkuje odpowiedzialność i pomaga inwestorowi po zakończeniu montażu.'
	}
];

const contractCards = [
	['Draft umowy', 'Czy to, co mówi handlowiec, znajduje się w zapisach umownych? Sprawdź terminy, zakres, płatności, odbiory, odpowiedzialność i procedurę zmian.'],
	['Warunki gwarancji', 'Na co dokładnie jest gwarancja, na jak długo, jakie są wyłączenia, czy wymagane są płatne przeglądy i jakie obowiązki ma inwestor?'],
	['Szkolenie inwestora', 'Czy producent uczy obsługi systemu, programów, chemii, ustawień, podstaw serwisu, kontroli kosztów i reakcji na typowe sytuacje?'],
	['Dostęp do części i chemii', 'Czy inwestor ma zapewniony dostęp do kompatybilnych części, akcesoriów, materiałów eksploatacyjnych i chemii po uruchomieniu myjni?']
];

const questionGroups = [
	{
		title: 'Zakres i odpowiedzialność',
		items: [
			'Co dokładnie obejmuje cena, a czego nie obejmuje?',
			'Kto odpowiada za technologię, montaż, uruchomienie i koordynację?',
			'Czy zakres handlowy jest później potwierdzony w umowie?',
			'Jakie elementy inwestor musi zorganizować samodzielnie?'
		]
	},
	{
		title: 'Technologia i serwis',
		items: [
			'Jak wygląda dostęp do pomp, zaworów, sterowania i dozowania?',
			'Ile trwa typowa interwencja serwisowa i czy wymaga rozbierania modułów?',
			'Czy awaria jednego programu zatrzymuje całe stanowisko albo całą myjnię?',
			'Czy technologia jest przygotowana do modernizacji po kilku latach?'
		]
	},
	{
		title: 'Dokumentacja i formalności',
		items: [
			'Czy oferta obejmuje projekt techniczny, czy tylko dokumentację do pozwolenia?',
			'Czy dokumentacja obejmuje instalacje, konstrukcję i rozwiązania branżowe?',
			'Czy producent pomaga projektantowi w prawidłowym ułożeniu technologii na działce?',
			'Czy inwestor otrzymuje dokumenty potrzebne do dalszych procedur po budowie?'
		]
	}
];

const faqItems = [
	{
		question: 'Jak porównać oferty na myjnię bezdotykową?',
		answer:
			'Nie porównuj wyłącznie ceny końcowej. Porównuj zakres, technologię, posadzkę, konstrukcję, zabudowę, komponenty, dokumentację, umowę, gwarancję, serwis, dostęp do części i koszty eksploatacji.'
	},
	{
		question: 'Dlaczego najtańsza oferta może być ryzykowna?',
		answer:
			'Niższa cena może oznaczać mniejszy zakres, słabsze komponenty, mniej dokumentacji, trudniejszy serwis, krótszą gwarancję albo koszty, które pojawią się dopiero na budowie lub po uruchomieniu myjni.'
	},
	{
		question: 'Czym różni się myjnia kontenerowa od modułowej?',
		answer:
			'Różnica dotyczy przede wszystkim przestrzeni technologicznej, ergonomii serwisowej, izolacji, wentylacji, możliwości rozbudowy i dostępu do urządzeń. Nie zawsze większy element jest automatycznie lepszy, ale trzeba sprawdzić realny komfort eksploatacji.'
	},
	{
		question: 'Czy posadzka ma duże znaczenie przy porównaniu ofert?',
		answer:
			'Tak. Posadzka w myjni to nie tylko beton. To element, w którym znajdują się odpływy, ogrzewanie, instalacje i punkty techniczne. Błędy w posadzce mogą generować kosztowne przeróbki i awarie.'
	},
	{
		question: 'Czy projekt techniczny jest ważny dla inwestora?',
		answer:
			'Tak. Projekt architektoniczno-budowlany służy głównie do pozwolenia na budowę, natomiast projekt techniczny porządkuje instalacje, konstrukcję i rozwiązania branżowe. To duża wartość przy realizacji oraz późniejszych procedurach po wybudowaniu.'
	},
	{
		question: 'Co sprawdzić w warunkach gwarancji?',
		answer:
			'Trzeba sprawdzić zakres gwarancji, czas jej trwania, wyłączenia, obowiązkowe przeglądy, procedurę zgłoszeń, dostępność serwisu, czas reakcji i dostęp do części po okresie gwarancyjnym.'
	},
	{
		question: 'Jak technologia wpływa na zysk myjni?',
		answer:
			'Technologia wpływa na zużycie wody, ścieków, energii, chemii, awaryjność, czas serwisu i jakość mycia. To wszystko decyduje o kosztach eksploatacji i stabilności przychodu.'
	},
	{
		question: 'Czy warto wybrać droższą ofertę?',
		answer:
			'W wielu przypadkach tak, jeśli droższa oferta oznacza lepszą technologię, dokumentację, serwis, gwarancję, niższe koszty eksploatacji i mniejsze ryzyko przestojów. Celem nie jest najniższa cena, tylko bezpieczna inwestycja.'
	}
];

const relatedLinks = [
	['Koszt budowy myjni', '/ile-kosztuje-myjnia-bezdotykowa/'],
	['Ile zarabia myjnia?', '/ile-zarabia-myjnia-bezdotykowa/'],
	['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Budowa krok po kroku', '/budowa-myjni-bezdotykowej-krok-po-kroku/'],
	['Błędy inwestora', '/najczestsze-bledy-przy-budowie-myjni/'],
	['Poradnik inwestora', '/poradnik/']
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};
---

<Layout title={page.title} description={page.description} canonicalPath={page.canonicalPath}>
	<Header />

	<main class="offer-page">
		<section class="offer-hero" aria-labelledby="page-title">
			<div class="container offer-hero-grid">
				<div class="offer-hero-copy">
					<p class="eyebrow">
						<span></span>
						Porównanie ofert
					</p>

					<h1 id="page-title">
						Jak porównać oferty producentów myjni i nie wybrać
						<strong>pozornie najtańszego rozwiązania?</strong>
					</h1>

					<p class="offer-lead">
						Oferta na myjnię bezdotykową to nie tylko cena końcowa. To zakres technologii,
						posadzki, konstrukcji, dokumentacji, umowy, serwisu, gwarancji i odpowiedzialności
						producenta za inwestycję, która ma pracować przez lata.
					</p>

					<div class="offer-actions">
						<a class="offer-button-green" href="/#kontakt">
							Prześlij ofertę do analizy
							<span aria-hidden="true">→</span>
						</a>
						<a class="offer-button-light" href="#checklista">
							Zobacz checklistę
							<span aria-hidden="true">↓</span>
						</a>
					</div>

					<div class="offer-chips" aria-label="Najważniejsze tematy strony">
						{heroChips.map((item) => <span>{item}</span>)}
					</div>
				</div>

				<aside class="offer-hero-panel" aria-label="Najważniejszy wniosek">
					<div class="offer-panel-logo">inwestycjawmyjnie.pl</div>
					<p>Najważniejsza zasada</p>
					<h2>Cena jest początkiem rozmowy, nie decyzją.</h2>
					<span>
						Dwie oferty mogą wyglądać podobnie w PDF-ie, ale oznaczać zupełnie inną
						technologię, inne koszty eksploatacji i inny poziom bezpieczeństwa inwestora.
					</span>
					<div class="offer-mini-grid">
						<b>zakres</b>
						<b>jakość</b>
						<b>umowa</b>
						<b>serwis</b>
					</div>
				</aside>
			</div>
		</section>

		<section class="offer-section" aria-labelledby="decision-title">
			<div class="container">
				<div class="offer-split">
					<div>
						<p class="eyebrow"><span></span>Krótka odpowiedź</p>
						<h2 id="decision-title">
							Nie porównuj ceny. Porównuj <strong>to, co buduje inwestycję.</strong>
						</h2>
					</div>
					<p>
						Najniższa kwota nie zawsze oznacza najbezpieczniejszą decyzję. W branży myjni
						jakość może kosztować więcej, ale daje spokój, przewidywalność i mniejsze ryzyko
						przestojów, błędów wykonawczych oraz kosztownych poprawek.
					</p>
				</div>

				<div class="decision-grid">
					{decisionCards.map((card) => (
						<article class="decision-card">
							<span>{card.number}</span>
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="offer-section offer-text-section" aria-labelledby="why-title">
			<div class="container offer-article-grid">
				<div class="offer-sticky-title">
					<p class="eyebrow"><span></span>Dlaczego to trudne?</p>
					<h2 id="why-title">
						Dwie oferty mogą mieć podobną cenę, ale oznaczać <strong>zupełnie inną myjnię.</strong>
					</h2>
				</div>

				<div class="offer-article-copy offer-article-card">
					<p>
						Porównanie ofert na myjnię bezdotykową jest trudne, bo producenci inaczej
						opisują zakres. Jedna oferta może obejmować kontener, posadzkę, konstrukcję,
						dokumentację, montaż i szkolenie, a druga tylko część technologii z długą listą
						elementów po stronie inwestora.
					</p>

					<p>
						Różnice mogą zaczynać się już od podstaw: kontener technologiczny albo moduł,
						chemia płynna albo proszkowa, posadzka monolityczna albo prefabrykowana,
						inny standard konstrukcji, inna zabudowa, inne pompy, zawory, sterowanie,
						ogrzewanie, uzdatnianie wody, systemy zimowe, serwis i gwarancja.
					</p>

					<p>
						Oferta handlowa to dopiero pierwszy dokument. Równie ważne są draft umowy,
						warunki gwarancji, sposób odbioru, serwis, szkolenie, dostęp do części,
						akcesoriów i chemii oraz to, czy deklaracje handlowca są później zapisane
						w dokumentach.
					</p>

					<div class="offer-quote">
						<strong>W tej podstronie nie szukamy najniższej ceny.</strong>
						<span>Szukamy jakości, kompletności, odpowiedzialności i technologii, która ma zarabiać przez lata.</span>
					</div>
				</div>
			</div>
		</section>

		<section class="offer-section" id="checklista" aria-labelledby="criteria-title">
			<div class="container">
				<div class="offer-split">
					<div>
						<p class="eyebrow"><span></span>12 kryteriów</p>
						<h2 id="criteria-title">
							Co realnie porównać <strong>w ofertach producentów?</strong>
						</h2>
					</div>
					<p>
						Dobra oferta powinna być czytelna, kompletna i możliwa do sprawdzenia.
						Nie wystarczy porównać ceny końcowej. Trzeba wiedzieć, z czego ta cena wynika.
					</p>
				</div>

				<div class="criteria-grid">
					{criteriaCards.map((card) => (
						<article class="criteria-card">
							<span>{card[0]}</span>
							<h3>{card[1]}</h3>
							<p>{card[2]}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="offer-section" aria-labelledby="hidden-title">
			<div class="container">
				<div class="offer-carousel" data-offer-carousel>
					<div class="offer-carousel-head">
						<div>
							<p class="eyebrow light"><span></span>Czego nie widać w cenie?</p>
							<h2 id="hidden-title">
								Największe różnice pojawiają się <strong>po uruchomieniu myjni</strong>
							</h2>
						</div>
						<div class="offer-carousel-nav" aria-label="Nawigacja slajdera">
							<button type="button" data-offer-prev aria-label="Poprzedni element">←</button>
							<button type="button" data-offer-next aria-label="Następny element">→</button>
						</div>
					</div>

					<div class="offer-carousel-track" data-offer-track>
						{hiddenCostSlides.map((slide) => (
							<article class="offer-slide">
								<span>{slide.kicker}</span>
