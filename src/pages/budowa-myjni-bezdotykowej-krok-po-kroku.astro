---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const page = {
	canonicalPath: '/budowa-myjni-bezdotykowej-krok-po-kroku/',
	title: 'Budowa myjni bezdotykowej krok po kroku — od działki do uruchomienia',
	description:
		'Budowa myjni bezdotykowej krok po kroku: analiza działki, MPZP lub WZ, koncepcja, budżet, technologia, dokumentacja, pozwolenie, produkcja, montaż, uruchomienie i odbiory.'
};

const heroChips = [
	'analiza działki',
	'MPZP / WZ',
	'budżet',
	'technologia',
	'pozwolenie',
	'uruchomienie'
];

const processSteps = [
	{
		number: '01',
		title: 'Analiza działki',
		text: 'Najpierw trzeba sprawdzić, czy lokalizacja ma sens techniczny, formalny i ekonomiczny: wjazd, widoczność, media, ruch, konkurencję, sąsiedztwo i potencjał przychodu.'
	},
	{
		number: '02',
		title: 'MPZP albo WZ',
		text: 'Jeżeli działka ma miejscowy plan, analizuje się jego zapisy. Jeżeli planu nie ma, zwykle trzeba sprawdzić możliwość uzyskania decyzji o warunkach zabudowy.'
	},
	{
		number: '03',
		title: 'Koncepcja i PZT',
		text: 'Koncepcja pokazuje, co realnie zmieści się na działce. PZT porządkuje stanowiska, kontener lub moduł, strefę SPA, media, zjazd, ruch i odwodnienie.'
	},
	{
		number: '04',
		title: 'Budżet inwestycji',
		text: 'Budżet trzeba liczyć indywidualnie: technologia, projekt, formalności, prace budowlane, przyłącza, odwodnienie, finansowanie i rezerwa.'
	},
	{
		number: '05',
		title: 'Wybór technologii',
		text: 'Cena jest dopiero trzecim kryterium. W długofalowym biznesie ważniejsze są jakość, żywotność, serwis, zużycie mediów, patenty, automatyka i przyszłe koszty pracy.'
	},
	{
		number: '06',
		title: 'Dokumentacja',
		text: 'Projekt powinien uporządkować PZT, architekturę, branże, instalacje, konstrukcję, zjazd, media, operat wodnoprawny, jeśli jest wymagany, oraz przygotować inwestora do dalszych procedur.'
	},
	{
		number: '07',
		title: 'Pozwolenie na budowę',
		text: 'Pozwolenie jest formalnym punktem przełomowym. W praktyce bywa też potrzebne przy rozmowach z leasingiem albo instytucją finansującą inwestycję.'
	},
	{
		number: '08',
		title: 'Produkcja myjni',
		text: 'Produkcja zależy od producenta, umowy, konfiguracji, harmonogramu i płatności. Statystycznie proces może trwać od około 60 do 180 dni roboczych.'
	},
	{
		number: '09',
		title: 'Przygotowanie terenu',
		text: 'Na tym etapie kluczowy jest kierownik budowy, wykonawca robót oraz jasne wytyczne od producenta: podbudowa, media, odwodnienie, posadzka, strefy pracy i terminy.'
	},
	{
		number: '10',
		title: 'Montaż',
		text: 'Topowi producenci prefabrykują elementy wcześniej, dzięki czemu montaż na działce jest krótszy, bardziej przewidywalny i łatwiejszy do wpisania w harmonogram budowy.'
	},
	{
		number: '11',
		title: 'Uruchomienie i szkolenie',
		text: 'Po montażu i doprowadzeniu mediów następują testy, uruchomienie programów, sprawdzenie komponentów, regulacja ustawień oraz szkolenie inwestora z obsługi.'
	},
	{
		number: '12',
		title: 'Odbiory i użytkowanie',
		text: 'Po zakończeniu budowy trzeba zebrać protokoły, dokumentację, inwentaryzację i złożyć właściwe dokumenty do nadzoru budowlanego przed rozpoczęciem użytkowania.'
	}
];

const planningCards = [
	{
		title: 'MPZP — miejscowy plan',
		text: 'To uchwała gminy, która określa, co można budować na danym terenie. Dla myjni trzeba czytać nie tylko symbol terenu, ale też szczegółowe zapisy: usługi, obsługa pojazdów, komunikacja, powierzchnia biologicznie czynna, wysokość, reklamy, zjazd i ograniczenia środowiskowe.'
	},
	{
		title: 'WZ — warunki zabudowy',
		text: 'Decyzja WZ jest potrzebna wtedy, gdy nie ma MPZP. To osobna procedura, która może wydłużyć proces i wymaga sprawdzenia sąsiedztwa, dostępu do drogi publicznej, mediów oraz zgodności planowanej inwestycji z warunkami lokalnymi.'
	},
	{
		title: 'Jakich oznaczeń szukać?',
		text: 'Najczęściej analizuje się tereny usługowe lub mieszane, np. U, U/P, P/U, KS albo zapisy dopuszczające usługi, obsługę komunikacji lub obiekty związane z obsługą pojazdów. Ostatecznie decyduje treść uchwały, nie sama litera symbolu.'
	}
];

const budgetCards = [
	['Technologia myjni', 'Kontener lub moduł, pompy, programy, automatyka, panele, instalacje, system płatności, chemia, ogrzewanie, uzdatnianie wody i zabezpieczenia zimowe.'],
	['Projekt i formalności', 'Analiza działki, koncepcja, PZT, projekt architektoniczno-budowlany, projekt techniczny, uzgodnienia, operat wodnoprawny i wsparcie do pozwolenia.'],
	['Roboty budowlane', 'Prace ziemne, podbudowa, nawierzchnie, krawężniki, przyłącza, odwodnienie, separator, osadniki, strefa mokra i strefa sucha urządzeń dodatkowych.'],
	['Finansowanie i rezerwa', 'Leasing, kredyt, wkład własny, harmonogram płatności, kierownik budowy, nadzór, nieprzewidziane prace oraz bufor na zmiany po analizie terenu.']
];

const technologyCards = [
	{
		title: 'Jakość zamiast najniższej ceny',
		text: 'Myjnia pracuje codziennie w wodzie, mrozie, chemii i wysokim obciążeniu. Tańsza technologia może szybko stracić przewagę, jeśli generuje wyższe koszty mediów albo częstsze przestoje.'
	},
	{
		title: 'Rozwiązania z wyższej półki',
		text: 'Warto pytać o patenty, systemy ograniczające zużycie wody, ścieków i energii, jakość pomp, zaworów, automatyki, ogrzewania, uzdatniania wody oraz gotowość do modernizacji.'
	},
	{
		title: 'Serwis i żywotność',
		text: 'Dobra technologia powinna być skuteczna, ale też łatwa w obsłudze, logiczna w serwisowaniu i odporna na lata pracy. Czas naprawy ma bezpośredni wpływ na przychód.'
	}
];

const documentCards = [
	{
		number: '01',
		title: 'Projekt zagospodarowania terenu',
		text: 'Pokazuje układ inwestycji na działce: stanowiska, kontener lub moduł, zjazd, ruch, strefę mokrą, strefę suchą, media, odwodnienie, separację i nawierzchnie.'
	},
	{
		number: '02',
		title: 'Projekt architektoniczno-budowlany',
		text: 'Służy głównie procedurze pozwolenia na budowę. To formalna część dokumentacji, która nie zawsze zawiera cały praktyczny zakres techniczny potrzebny inwestorowi.'
	},
	{
		number: '03',
		title: 'Projekt techniczny',
		text: 'Obejmuje rozwiązania branżowe, instalacyjne i konstrukcyjne. Jest bardzo ważny po wybudowaniu obiektu oraz przy dokumentach związanych z zakończeniem budowy i użytkowaniem.'
	}
];

const timelineSlides = [
	{
		label: 'Przed decyzją',
		title: 'Najpierw działka, nie katalog',
		text: 'Bez analizy działki nie wiadomo, czy większa myjnia ma sens, jaki układ będzie wygodny i jakie prace budowlane trzeba wykonać.'
	},
	{
		label: 'Przed umową',
		title: 'Budżet i technologia muszą się spotkać',
		text: 'Wybór technologii powinien wynikać z lokalizacji, budżetu, oczekiwanego zwrotu i kosztów eksploatacji, a nie tylko z najniższej ceny.'
	},
	{
		label: 'Po pozwoleniu',
		title: 'Leasing potrzebuje porządku formalnego',
		text: 'Pozwolenie i dokumentacja porządkują inwestycję. W praktyce ułatwiają rozmowy z finansowaniem i uruchomienie kolejnych etapów.'
	},
	{
		label: 'Na budowie',
		title: 'Harmonogram chroni przed chaosem',
		text: 'Produkcja, przygotowanie terenu, media, montaż i uruchomienie muszą być spięte w czasie, inaczej inwestor płaci za opóźnienia.'
	}
];

const sitePrepCards = [
	['Kierownik budowy', 'Powinien nadzorować zgodność prac z projektem, kolejność robót, bezpieczeństwo i odbiory etapowe. Jego koszt trzeba uwzględnić w budżecie.'],
	['Wytyczne producenta', 'Producent powinien jasno określić, czego wymaga technologia: podbudowa, przyłącza, media, przepusty, odwodnienie, posadzka i punkty montażowe.'],
	['Koordynacja wykonawców', 'Roboty ziemne, instalacje, elektryka, gaz, woda, kanalizacja, deszczówka i nawierzchnie muszą być skoordynowane z terminem dostawy myjni.']
];

const finalCards = [
	{
		title: 'Protokół odbioru myjni',
		text: 'Po montażu inwestor powinien otrzymać dokument potwierdzający przekazanie, zakres uruchomienia, testy, uwagi, szkolenie i podstawowe zasady obsługi.'
	},
	{
		title: 'Dokumenty po budowie',
		text: 'Do nadzoru budowlanego składa się dokumenty związane z zakończeniem budowy albo pozwoleniem na użytkowanie, zależnie od decyzji i konkretnego obiektu.'
	},
	{
		title: 'Start użytkowania',
		text: 'Myjnię można uruchamiać biznesowo dopiero po uporządkowaniu wymaganych formalności, mediów, odbiorów, ustawień, płatności i zasad serwisowych.'
	}
];

const faqItems = [
	{
		question: 'Od czego zacząć budowę myjni bezdotykowej?',
		answer:
			'Najpierw od analizy działki. Trzeba sprawdzić MPZP albo WZ, media, zjazd, potencjał ekonomiczny, konkurencję, ruch samochodowy i możliwość wygodnego rozplanowania stanowisk.'
	},
	{
		question: 'Czym różni się MPZP od WZ?',
		answer:
			'MPZP to miejscowy plan zagospodarowania przestrzennego, czyli uchwała gminy określająca przeznaczenie terenu. WZ to decyzja o warunkach zabudowy, potrzebna zwykle wtedy, gdy dla działki nie ma planu miejscowego.'
	},
	{
		question: 'Jakie oznaczenie działki jest dobre pod myjnię?',
		answer:
			'Najczęściej szuka się funkcji usługowej albo mieszanej, np. U, U/P, P/U, KS lub zapisów dopuszczających usługi związane z obsługą pojazdów. Symbole różnią się między planami, dlatego zawsze trzeba czytać treść uchwały MPZP.'
	},
	{
		question: 'Czy pozwolenie na budowę jest potrzebne do leasingu?',
		answer:
			'W praktyce instytucje finansujące często oczekują uporządkowanej dokumentacji, budżetu i decyzji formalnych przed uruchomieniem finansowania albo kolejnymi transzami. Konkretne wymagania zależą od leasingodawcy i struktury inwestycji.'
	},
	{
		question: 'Ile trwa produkcja myjni?',
		answer:
			'Zależy od producenta, zakresu, konfiguracji, umowy, płatności i sezonu. Orientacyjnie można przyjąć od około 60 do nawet 180 dni roboczych, ale termin zawsze powinien wynikać z umowy i harmonogramu.'
	},
	{
		question: 'Czy cena technologii powinna decydować o wyborze producenta?',
		answer:
			'Nie. Cena jest ważna, ale przy myjni liczy się długofalowy biznes: jakość mycia, żywotność komponentów, zużycie mediów, serwis, dostęp do części, dokumentacja i możliwość modernizacji.'
	},
	{
		question: 'Co dzieje się po montażu myjni?',
		answer:
			'Po montażu następuje uruchomienie, testy, regulacja programów, szkolenie inwestora, protokół odbioru i zebranie dokumentów potrzebnych do zakończenia budowy albo pozwolenia na użytkowanie.'
	},
	{
		question: 'Gdzie składa się dokumenty po zakończeniu budowy?',
		answer:
			'Co do zasady sprawy zakończenia budowy albo pozwolenia na użytkowanie prowadzi właściwy organ nadzoru budowlanego, najczęściej powiatowy inspektor nadzoru budowlanego. Zakres zależy od konkretnej decyzji i obiektu.'
	}
];

const relatedLinks = [
	['Koszt budowy myjni', '/koszt-budowy-myjni-bezdotykowej/'],
	['Działka pod myjnię', '/dzialka-pod-myjnie-bezdotykowa/'],
	['Jak porównać oferty?', '/jak-porownac-oferty-myjni-bezdotykowej/'],
	['Ile zarabia myjnia?', '/ile-zarabia-myjnia-bezdotykowa/'],
	['Błędy inwestora', '/najczestsze-bledy-przy-budowie-myjni/'],
	['Poradnik inwestora', '/poradnik/']
];

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqItems.map((item) => ({
		'@type': 'Question',
		name: item.question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: item.answer
		}
	}))
};
---

<Layout title={page.title} description={page.description} canonicalPath={page.canonicalPath}>
	<Header />

	<main class="steps-page">
		<section class="steps-hero" aria-labelledby="page-title">
			<div class="container steps-hero-grid">
				<div class="steps-hero-copy">
					<p class="eyebrow">
						<span></span>
						Proces inwestycji
					</p>

					<h1 id="page-title">
						Budowa myjni bezdotykowej krok po kroku — od działki do
						<strong>uruchomienia biznesu</strong>
					</h1>

					<p class="steps-lead">
						Budowa myjni to proces, w którym analiza działki, MPZP lub WZ, koncepcja,
						budżet, technologia, dokumentacja, pozwolenie, produkcja, przygotowanie terenu,
						montaż, uruchomienie i odbiory muszą być ułożone w logiczną kolejność.
					</p>

					<div class="steps-actions">
						<a class="steps-button-green" href="/#kontakt">
							Prześlij działkę do analizy
							<span aria-hidden="true">→</span>
						</a>
						<a class="steps-button-light" href="#proces">
							Zobacz 12 etapów
							<span aria-hidden="true">↓</span>
						</a>
					</div>

					<div class="steps-chips" aria-label="Najważniejsze tematy strony">
						{heroChips.map((item) => <span>{item}</span>)}
					</div>
				</div>

				<aside class="steps-hero-panel" aria-label="Najważniejszy wniosek">
					<div class="steps-panel-logo">inwestycjawmyjnie.pl</div>
					<p>Najważniejsza zasada</p>
					<h2>Najpierw decyzje, potem budowa.</h2>
					<span>
						Dobrze ułożony proces ogranicza ryzyko opóźnień, błędów projektowych,
						niepełnego budżetu i wyboru technologii, która nie pasuje do lokalizacji.
					</span>
					<div class="steps-mini-grid">
						<b>działka</b>
						<b>plan</b>
						<b>budżet</b>
						<b>start</b>
					</div>
				</aside>
			</div>
		</section>

		<section class="steps-section" id="proces" aria-labelledby="process-title">
			<div class="container">
				<div class="steps-split">
					<div>
						<p class="eyebrow"><span></span>12 etapów</p>
						<h2 id="process-title">
							Proces budowy myjni <strong>musi mieć kolejność</strong>
						</h2>
					</div>
					<p>
						Największe problemy pojawiają się wtedy, gdy inwestor od razu pyta o cenę,
						a nie ma jeszcze sprawdzonej działki, koncepcji, budżetu, warunków formalnych
						i technologii dopasowanej do miejsca.
					</p>
				</div>

				<div class="process-grid">
					{processSteps.map((step) => (
						<article class="process-card">
							<span>{step.number}</span>
							<h3>{step.title}</h3>
							<p>{step.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="steps-section steps-text-section" aria-labelledby="start-title">
			<div class="container steps-article-grid">
				<div class="steps-sticky-title">
					<p class="eyebrow"><span></span>Start inwestycji</p>
					<h2 id="start-title">
						Nie zaczynaj od katalogu. Zacznij od <strong>działki i decyzji formalnych.</strong>
					</h2>
				</div>

				<div class="steps-article-copy steps-article-card">
					<p>
						Pierwszym etapem nie powinna być wycena wybranej liczby stanowisk. Najpierw trzeba
						sprawdzić, czy dana działka ma realny potencjał pod myjnię: czy jest widoczna,
						czy ma dobry wjazd, czy pozwala na wygodny układ ruchu i czy można ją przeprowadzić
						przez procedury formalne.
					</p>

					<p>
						Dopiero po analizie działki można sensownie rozmawiać o liczbie stanowisk,
						kontenerze lub module technicznym, strefie urządzeń dodatkowych, rodzaju posadzki,
						mediach, zjeździe, odwodnieniu, kosztach budowlanych i budżecie inwestora.
					</p>

					<p>
						Budowa myjni jest projektem etapowym. Każdy kolejny krok powinien zmniejszać ryzyko:
						najpierw lokalizacja, potem formalności, następnie koncepcja i budżet, dopiero później
						ostateczny wybór technologii, umowa, produkcja, budowa, montaż i uruchomienie.
					</p>

					<div class="steps-quote">
						<strong>Dobra myjnia nie zaczyna się od najniższej ceny.</strong>
						<span>Zaczyna się od sprawdzenia, czy konkretna lokalizacja może stać się rentownym, bezpiecznym i długofalowym biznesem.</span>
					</div>
				</div>
			</div>
		</section>

		<section class="steps-section" aria-labelledby="planning-title">
			<div class="container">
				<div class="steps-split">
					<div>
						<p class="eyebrow"><span></span>MPZP / WZ</p>
						<h2 id="planning-title">
							Plan miejscowy albo warunki zabudowy — <strong>tu zaczyna się formalna odpowiedź</strong>
						</h2>
					</div>
					<p>
						Działka może wyglądać idealnie, ale o możliwości budowy decydują dokumenty.
						Trzeba sprawdzić, czy teren dopuszcza usługi, obsługę pojazdów albo podobną funkcję
						oraz jakie ograniczenia wynikają z uchwały, sąsiedztwa i mediów.
					</p>
				</div>

				<div class="planning-grid">
					{planningCards.map((card) => (
						<article class="planning-card">
							<h3>{card.title}</h3>
							<p>{card.text}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="steps-section budget-section" aria-labelledby="budget-title">
			<div class="container budget-panel">
				<div>
					<p class="eyebrow light"><span></span>Budżet</p>
					<h2 id="budget-title">
						Budżet myjni to plan indywidualny, <strong>nie jedna uniwersalna kwota</strong>
					</h2>
					<p>
						Wstępne ceny technologii są potrzebne, ale pełny koszt inwestycji powstaje dopiero
						po połączeniu technologii, dokumentacji, prac budowlanych, mediów, finansowania
						i rezerwy na warunki konkretnej działki.
					</p>
				</div>

				<div class="budget-grid">
					{budgetCards.map((card) => (
						<article>
							<h3>{card[0]}</h3>
							<p>{card[1]}</p>
						</article>
					))}
				</div>
			</div>
		</section>

		<section class="steps-section" aria-labelledby="technology-title">
			<div class="container">
				<div class="steps-split">
					<div>
						<p class="eyebrow"><span></span>Wybór technologii</p>
						<h2 id="technology-title">
							Cena jest ważna, ale przy technologii <strong>nie może być pierwszym kryterium</strong>
						</h2>
					</div>
					<p>
						Myjnia to biznes długofalowy. Różnice technologiczne wpływają na jakość mycia,
						zużycie wody, ścieków, energii i chemii, czas serwisu, żywotność komponentów
