					<div class="steps-carousel-head">
						<div>
							<p class="eyebrow light"><span></span>Harmonogram</p>
							<h2 id="timeline-title">
								Od pozwolenia do startu — <strong>kolejność chroni budżet</strong>
							</h2>
						</div>
						<div class="steps-carousel-nav" aria-label="Nawigacja slajdera">
							<button type="button" data-steps-prev aria-label="Poprzedni element">←</button>
							<button type="button" data-steps-next aria-label="Następny element">→</button>
						</div>
					</div>

					<div class="steps-carousel-track" data-steps-track>
						{timelineSlides.map((slide) => (
							<article class="steps-slide">
								<span>{slide.label}</span>
								<h3>{slide.title}</h3>
								<p>{slide.text}</p>
							</article>
						))}
					</div>
				</div>
			</div>
		</section>

		<section class="steps-section" aria-labelledby="production-title">
