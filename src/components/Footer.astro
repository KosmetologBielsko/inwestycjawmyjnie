---
const currentYear = new Date().getFullYear();

const footerGroups = [
	{
		title: 'Poradnik inwestora',
		links: [
			{
				label: 'Koszt budowy myjni',
				href: '/ile-kosztuje-myjnia-bezdotykowa/'
			},
			{
				label: 'Ile zarabia myjnia?',
				href: '/ile-zarabia-myjnia-bezdotykowa/'
			},
			{
				label: 'Działka pod myjnię',
				href: '/dzialka-pod-myjnie-bezdotykowa/'
			},
			{
				label: 'Jak porównać oferty?',
				href: '/jak-porownac-oferty-myjni-bezdotykowej/'
			}
		]
	},
	{
		title: 'Decyzja inwestora',
		links: [
			{
				label: 'Bezpłatna analiza i porównanie ofert',
				href: '/bezplatne-porownanie-ofert-myjni/'
			},
			{
				label: 'Budowa krok po kroku',
				href: '/budowa-myjni-bezdotykowej-krok-po-kroku/'
			},
			{
				label: 'Błędy inwestora',
				href: '/najczestsze-bledy-przy-budowie-myjni/'
			},
			{
				label: 'Poradnik inwestora',
				href: '/poradnik/'
			}
		]
	},
	{
		title: 'Dokumenty',
		links: [
			{
				label: 'Polityka prywatności i RODO',
				href: '/polityka-prywatnosci/'
			},
			{
				label: 'Polityka cookies',
				href: '/polityka-cookies/'
			},
			{
				label: 'Zasady korzystania',
				href: '/zasady-korzystania/'
			},
			{
				label: 'Mapa strony',
				href: '/sitemap.xml'
			}
		]
	}
];
---

<footer class="iwm-footer">
	<div class="container">
		<div class="iwm-footer-shell">
			<div class="iwm-footer-main">
				<section class="iwm-footer-brand" aria-label="inwestycjawmyjnie.pl">
					<a class="iwm-footer-logo" href="/" aria-label="inwestycjawmyjnie.pl">
						<img
							src="/images/logo-inwestycjawmyjnie-poziome.webp"
							alt="inwestycjawmyjnie.pl"
							width="1899"
							height="422"
							loading="lazy"
							decoding="async"
						/>
					</a>

					<p class="iwm-footer-lead">
						Poradnik inwestora myjni bezdotykowej: koszty, opłacalność, działka,
						formalności i porównanie ofert producentów w jednym miejscu.
					</p>

					<p class="iwm-footer-copy">
						Zanim zaczniesz zbierać przypadkowe ceny, uporządkuj założenia.
						Bezpłatna analiza pomaga przygotować temat inwestycji tak, żeby łatwiej
						porównać zakres, technologię, serwis i realny budżet budowy myjni.
					</p>

					<a class="iwm-footer-cta" href="/bezplatne-porownanie-ofert-myjni/">
						Bezpłatna analiza i porównanie ofert
						<span aria-hidden="true">→</span>
					</a>
				</section>

				<div class="iwm-footer-columns">
					{
						footerGroups.map((group) => (
							<nav class="iwm-footer-nav" aria-label={group.title}>
								<h2>{group.title}</h2>
								<ul>
									{group.links.map((link) => (
										<li>
											<a href={link.href}>{link.label}</a>
										</li>
									))}
								</ul>
							</nav>
						))
					}
				</div>
			</div>

			<div class="iwm-footer-bottom">
				<p class="iwm-footer-copyright">
					© {currentYear} inwestycjaw<span>myjnie</span>.pl
				</p>

				<p class="iwm-footer-rights">
					Wszystkie zdjęcia, filmy i treści są chronione prawem autorskim.
					Kopiowanie i wykorzystywanie materiałów bez pisemnej zgody jest zabronione.
				</p>
			</div>
		</div>
	</div>
</footer>

<style>
	.iwm-footer {
		position: relative;
		padding: clamp(34px, 5vw, 66px) 0 clamp(30px, 4vw, 46px);
		overflow: hidden;
		background:
			radial-gradient(circle at 10% 12%, rgba(18, 104, 255, 0.08), transparent 28%),
			radial-gradient(circle at 88% 8%, rgba(114, 240, 105, 0.09), transparent 30%),
			linear-gradient(180deg, #f8fafc 0%, #eef3f8 100%);
	}

	.iwm-footer::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.72) 48%, transparent 100%);
		opacity: 0.65;
	}

	.iwm-footer .container {
		position: relative;
		z-index: 1;
	}

	.iwm-footer-shell {
		padding: clamp(22px, 3.5vw, 38px);
		border-radius: clamp(30px, 4vw, 46px);
		background:
			radial-gradient(circle at 8% 12%, rgba(18, 104, 255, 0.045), transparent 32%),
			radial-gradient(circle at 94% 8%, rgba(114, 240, 105, 0.06), transparent 34%),
			rgba(255, 255, 255, 0.9);
		border: 1px solid rgba(8, 16, 32, 0.075);
		box-shadow:
			0 24px 70px rgba(8, 16, 32, 0.075),
			inset 0 1px 0 rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(18px);
	}

	.iwm-footer-main {
		display: grid;
		grid-template-columns: minmax(420px, 0.9fr) minmax(620px, 1.18fr);
		gap: clamp(22px, 3vw, 34px);
		align-items: stretch;
	}

	.iwm-footer-brand,
	.iwm-footer-nav {
		border: 1px solid rgba(8, 16, 32, 0.07);
		background: rgba(255, 255, 255, 0.76);
		box-shadow: 0 14px 36px rgba(8, 16, 32, 0.045);
	}

	.iwm-footer-brand {
		display: grid;
		align-content: start;
		gap: 18px;
		padding: clamp(22px, 2.5vw, 30px);
		border-radius: 30px;
	}

	.iwm-footer-logo {
		display: inline-flex;
		width: min(420px, 100%);
	}

	.iwm-footer-logo img {
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
	}

	.iwm-footer-lead {
		max-width: 620px;
		margin: 8px 0 0;
		color: #0f172a;
		font-size: clamp(1.32rem, 1.7vw, 2rem);
		font-weight: 950;
		line-height: 1.08;
		letter-spacing: -0.055em;
	}

	.iwm-footer-copy {
		max-width: 620px;
		margin: 0;
		color: #5f6f86;
		font-size: clamp(1rem, 1vw, 1.08rem);
		font-weight: 590;
		line-height: 1.72;
		letter-spacing: -0.015em;
	}

	.iwm-footer-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		width: fit-content;
		min-height: 56px;
		margin-top: 6px;
		padding: 0 22px;
		border-radius: 999px;
		color: #041109;
		background: linear-gradient(90deg, #7cff4a 0%, #51f05e 45%, #28dc73 100%);
		border: 1px solid rgba(114, 240, 105, 0.34);
		box-shadow:
			0 18px 44px rgba(76, 244, 89, 0.22),
			inset 0 1px 0 rgba(255, 255, 255, 0.58);
		font-weight: 950;
		letter-spacing: -0.03em;
		text-decoration: none;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			filter 0.2s ease;
	}

	.iwm-footer-cta:hover {
		transform: translateY(-2px);
	}

	.iwm-footer-columns {
		display: grid;
		grid-template-columns: repeat(3, minmax(0, 1fr));
		gap: 16px;
	}

	.iwm-footer-nav {
		position: relative;
		overflow: hidden;
		display: grid;
		align-content: start;
		gap: 18px;
		min-height: 100%;
		padding: clamp(22px, 2.2vw, 28px);
		border-radius: 28px;
	}

	.iwm-footer-nav::before {
		content: '';
		position: absolute;
		inset: 0 0 auto 0;
		height: 4px;
		background: linear-gradient(90deg, rgba(18, 104, 255, 0.85), rgba(114, 240, 105, 0.9));
		opacity: 0.9;
	}

	.iwm-footer-nav h2 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(1.16rem, 1.2vw, 1.34rem);
		font-weight: 950;
		letter-spacing: -0.055em;
		line-height: 1.05;
	}

	.iwm-footer-nav ul {
		display: grid;
		gap: 11px;
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.iwm-footer-nav a {
		display: inline-flex;
		color: #344054;
		font-size: clamp(0.95rem, 0.98vw, 1.02rem);
		font-weight: 680;
		line-height: 1.34;
		letter-spacing: -0.02em;
		text-decoration: none;
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.iwm-footer-nav a:hover {
		color: #1268ff;
		transform: translateX(2px);
	}

	.iwm-footer-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 22px;
		margin-top: 22px;
		padding-top: 22px;
		border-top: 1px solid rgba(8, 16, 32, 0.08);
	}

	.iwm-footer-bottom p {
		margin: 0;
	}

	.iwm-footer-copyright {
		color: #081020;
		font-size: clamp(1rem, 1.1vw, 1.14rem);
		font-weight: 950;
		letter-spacing: -0.035em;
		white-space: nowrap;
	}

	.iwm-footer-copyright span {
		color: #1268ff;
	}

	.iwm-footer-rights {
		max-width: 920px;
		color: #667085;
		font-size: clamp(0.92rem, 0.95vw, 1rem);
		font-weight: 570;
		line-height: 1.6;
		letter-spacing: -0.012em;
		text-align: right;
	}

	@media (max-width: 1280px) {
		.iwm-footer-main {
			grid-template-columns: 1fr;
		}

		.iwm-footer-columns {
			grid-template-columns: repeat(3, minmax(0, 1fr));
		}
	}

	@media (max-width: 920px) {
		.iwm-footer-columns {
			grid-template-columns: 1fr;
		}

		.iwm-footer-bottom {
			align-items: flex-start;
			flex-direction: column;
		}

		.iwm-footer-rights {
			max-width: none;
			text-align: left;
		}
	}

	@media (max-width: 760px) {
		.iwm-footer {
			padding: 24px 0 34px;
		}

		.iwm-footer-shell {
			padding: 18px;
			border-radius: 30px;
		}

		.iwm-footer-brand,
		.iwm-footer-nav {
			padding: 20px;
			border-radius: 24px;
		}

		.iwm-footer-logo {
			width: min(330px, 100%);
		}

		.iwm-footer-cta {
			width: 100%;
			text-align: center;
		}

		.iwm-footer-copyright {
			white-space: normal;
		}
	}
</style>
