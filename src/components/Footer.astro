---
const currentYear = new Date().getFullYear();

const guideLinks = [
	{
		label: 'Koszt budowy myjni',
		href: '/ile-kosztuje-myjnia-bezdotykowa/'
	},
	{
		label: 'Ile zarabia myjnia?',
		href: '/ile-zarabia-myjnia-bezdotykowa/'
	},
	{
		label: 'Działka pod myjnię',
		href: '/dzialka-pod-myjnie-bezdotykowa/'
	},
	{
		label: 'Jak porównać oferty?',
		href: '/jak-porownac-oferty-myjni-bezdotykowej/'
	}
];

const decisionLinks = [
	{
		label: 'Bezpłatna analiza i porównanie ofert myjni',
		href: '/bezplatne-porownanie-ofert-myjni/'
	},
	{
		label: 'Budowa krok po kroku',
		href: '/budowa-myjni-bezdotykowej-krok-po-kroku/'
	},
	{
		label: 'Błędy inwestora',
		href: '/najczestsze-bledy-przy-budowie-myjni/'
	},
	{
		label: 'Poradnik inwestora',
		href: '/poradnik/'
	}
];

const documentLinks = [
	{
		label: 'Polityka prywatności i RODO',
		href: '/polityka-prywatnosci/'
	},
	{
	label: 'Polityka cookies',
	href: '/polityka-cookies/'
},
{
	label: 'Ustawienia cookies',
	href: '#ustawienia-cookies',
	cookieSettings: true
},
	{
		label: 'Zasady korzystania',
		href: '/zasady-korzystania/'
	},
	{
	label: 'Mapa strony',
	href: '/mapa-strony/'
}
];
---

<footer class="iwm-footer">
	<div class="container">
		<div class="iwm-footer-shell">
			<div class="iwm-footer-top">
				<section class="iwm-footer-brand-card" aria-label="inwestycjawmyjnie.pl">
					<a class="iwm-footer-logo" href="/" aria-label="inwestycjawmyjnie.pl">
						<img
							src="/images/logo-inwestycjawmyjnie-poziome.webp"
							alt="inwestycjawmyjnie.pl"
							width="1899"
							height="422"
							loading="lazy"
							decoding="async"
						/>
					</a>

					<p class="iwm-footer-lead">
						Poradnik inwestora myjni bezdotykowej: koszty, opłacalność, działka,
						formalności i porównanie ofert producentów.
					</p>

					<p class="iwm-footer-copy">
						Zanim zaczniesz zbierać przypadkowe ceny, uporządkuj założenia.
						Bezpłatna analiza pomaga porównać zakres, technologię, serwis i realny
						budżet budowy myjni.
					</p>

					<a class="iwm-footer-cta" href="/bezplatne-porownanie-ofert-myjni/">
						Bezpłatna analiza i porównanie ofert
						<span aria-hidden="true">→</span>
					</a>
				</section>

				<nav class="iwm-footer-card" aria-label="Poradnik inwestora">
					<h2>Poradnik inwestora</h2>

					<ul>
						{guideLinks.map((link) => (
							<li>
								<a href={link.href}>{link.label}</a>
							</li>
						))}
					</ul>
				</nav>

				<nav class="iwm-footer-card" aria-label="Decyzja inwestora">
					<h2>Decyzja inwestora</h2>

					<ul>
						{decisionLinks.map((link) => (
							<li>
								<a href={link.href}>{link.label}</a>
							</li>
						))}
					</ul>
				</nav>
			</div>

			<nav class="iwm-footer-docs" aria-label="Dokumenty">
				<h2>Dokumenty</h2>

				<ul>
					{documentLinks.map((link) => (
	<li>
		<a
			href={link.href}
			data-open-cookie-settings={link.cookieSettings ? true : undefined}
		>
			{link.label}
		</a>
	</li>
))}
				</ul>
			</nav>

			<div class="iwm-footer-bottom">
				<p class="iwm-footer-copyright">
					© {currentYear} inwestycjaw<span>myjnie</span>.pl
				</p>

				<p class="iwm-footer-rights">
					Wszystkie zdjęcia, filmy i treści są chronione prawem autorskim. Kopiowanie i wykorzystywanie materiałów bez pisemnej zgody jest zabronione.
				</p>
			</div>
		</div>
	</div>
</footer>

<style>
	.iwm-footer {
		position: relative;
		padding: clamp(34px, 4vw, 54px) 0 clamp(24px, 3vw, 38px);
		overflow: hidden;
		background:
			radial-gradient(circle at 10% 10%, rgba(18, 104, 255, 0.07), transparent 28%),
			radial-gradient(circle at 88% 6%, rgba(114, 240, 105, 0.08), transparent 30%),
			linear-gradient(180deg, #f8fafc 0%, #eef3f8 100%);
	}

	.iwm-footer::before {
		content: '';
		position: absolute;
		inset: 0;
		pointer-events: none;
		background: linear-gradient(
			90deg,
			transparent 0%,
			rgba(255, 255, 255, 0.66) 48%,
			transparent 100%
		);
		opacity: 0.58;
	}

	.iwm-footer .container {
		position: relative;
		z-index: 1;
	}

	.iwm-footer-shell {
		padding: clamp(18px, 2.6vw, 30px);
		border-radius: clamp(28px, 3.5vw, 42px);
		background:
			radial-gradient(circle at 8% 12%, rgba(18, 104, 255, 0.04), transparent 32%),
			radial-gradient(circle at 94% 8%, rgba(114, 240, 105, 0.055), transparent 34%),
			rgba(255, 255, 255, 0.92);
		border: 1px solid rgba(8, 16, 32, 0.07);
		box-shadow:
			0 22px 62px rgba(8, 16, 32, 0.07),
			inset 0 1px 0 rgba(255, 255, 255, 0.95);
		backdrop-filter: blur(18px);
	}

	.iwm-footer-top {
		display: grid;
		grid-template-columns: minmax(380px, 1.1fr) minmax(240px, 0.72fr) minmax(300px, 0.86fr);
		gap: 16px;
		align-items: stretch;
	}

	.iwm-footer-brand-card,
	.iwm-footer-card,
	.iwm-footer-docs {
		position: relative;
		overflow: hidden;
		border: 1px solid rgba(8, 16, 32, 0.07);
		background: rgba(255, 255, 255, 0.78);
		box-shadow: 0 14px 36px rgba(8, 16, 32, 0.045);
	}

	.iwm-footer-brand-card {
		display: grid;
		align-content: start;
		gap: 14px;
		padding: clamp(20px, 2.2vw, 28px);
		border-radius: 30px;
	}

	.iwm-footer-logo {
		display: inline-flex;
		width: min(360px, 100%);
	}

	.iwm-footer-logo img {
		display: block;
		width: 100%;
		height: auto;
		object-fit: contain;
	}

	.iwm-footer-lead {
		max-width: 680px;
		margin: 6px 0 0;
		color: #0f172a;
		font-size: clamp(1.1rem, 1.18vw, 1.42rem);
		font-weight: 950;
		line-height: 1.16;
		letter-spacing: -0.045em;
	}

	.iwm-footer-copy {
		max-width: 700px;
		margin: 0;
		color: #667085;
		font-size: clamp(0.92rem, 0.9vw, 1rem);
		font-weight: 590;
		line-height: 1.58;
		letter-spacing: -0.014em;
	}

	.iwm-footer-cta {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 10px;
		width: fit-content;
		min-height: 50px;
		margin-top: 4px;
		padding: 0 20px;
		border-radius: 999px;
		color: #041109;
		background: linear-gradient(90deg, #7cff4a 0%, #51f05e 45%, #28dc73 100%);
		border: 1px solid rgba(114, 240, 105, 0.34);
		box-shadow:
			0 16px 38px rgba(76, 244, 89, 0.2),
			inset 0 1px 0 rgba(255, 255, 255, 0.58);
		font-size: 0.94rem;
		font-weight: 950;
		letter-spacing: -0.03em;
		text-decoration: none;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			filter 0.2s ease;
	}

	.iwm-footer-cta:hover {
		transform: translateY(-2px);
		box-shadow:
			0 20px 46px rgba(76, 244, 89, 0.26),
			inset 0 1px 0 rgba(255, 255, 255, 0.66);
	}

	.iwm-footer-card {
		display: grid;
		align-content: start;
		gap: 18px;
		padding: clamp(20px, 2.2vw, 26px);
		border-radius: 28px;
	}

	.iwm-footer-card::before,
	.iwm-footer-docs::before {
		content: '';
		position: absolute;
		inset: 0 0 auto 0;
		height: 4px;
		background: linear-gradient(90deg, rgba(18, 104, 255, 0.85), rgba(114, 240, 105, 0.9));
		opacity: 0.92;
	}

	.iwm-footer-card h2,
	.iwm-footer-docs h2 {
		margin: 0;
		color: #0f172a;
		font-size: clamp(1rem, 1vw, 1.18rem);
		font-weight: 950;
		letter-spacing: 0.14em;
		line-height: 1.05;
		text-transform: uppercase;
	}

	.iwm-footer-card ul,
	.iwm-footer-docs ul {
		margin: 0;
		padding: 0;
		list-style: none;
	}

	.iwm-footer-card ul {
		display: grid;
		gap: 12px;
	}

	.iwm-footer-card a,
	.iwm-footer-docs a {
		color: #344054;
		font-weight: 830;
		line-height: 1.34;
		letter-spacing: -0.025em;
		text-decoration: none;
		transition:
			color 0.2s ease,
			transform 0.2s ease;
	}

	.iwm-footer-card a {
		display: inline-flex;
		font-size: clamp(0.98rem, 1vw, 1.08rem);
	}

	.iwm-footer-card a:hover,
	.iwm-footer-docs a:hover {
		color: #1268ff;
		transform: translateX(2px);
	}

	.iwm-footer-docs {
	display: flex;
	align-items: center;
	gap: 24px;
	margin-top: 16px;
	padding: 18px 22px;
	border-radius: 26px;
}

.iwm-footer-docs h2 {
	flex: 0 0 auto;
	margin: 0;
	white-space: nowrap;
}

.iwm-footer-docs ul {
	display: flex;
	flex: 1 1 auto;
	flex-wrap: nowrap;
	align-items: center;
	justify-content: space-between;
	gap: 0;
	min-width: 0;
}

.iwm-footer-docs li {
	display: inline-flex;
	align-items: center;
	white-space: nowrap;
}

.iwm-footer-docs li:not(:last-child)::after {
	content: '';
	display: inline-block;
	width: 5px;
	height: 5px;
	margin-left: 16px;
	margin-right: 16px;
	border-radius: 999px;
	background: rgba(18, 104, 255, 0.32);
	flex: 0 0 auto;
}

.iwm-footer-docs a {
	display: inline-flex;
	font-size: clamp(0.84rem, 0.88vw, 0.96rem);
	font-weight: 820;
	white-space: nowrap;
}

	.iwm-footer-bottom {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 22px;
		margin-top: 16px;
		padding-top: 16px;
		border-top: 1px solid rgba(8, 16, 32, 0.08);
	}

	.iwm-footer-bottom p {
		margin: 0;
	}

	.iwm-footer-copyright {
		color: #081020;
		font-size: clamp(0.92rem, 0.95vw, 1.04rem);
		font-weight: 950;
		letter-spacing: -0.03em;
		white-space: nowrap;
	}

	.iwm-footer-copyright span {
		color: #1268ff;
	}

	.iwm-footer-rights {
		color: #667085;
		font-size: clamp(0.82rem, 0.82vw, 0.92rem);
		font-weight: 590;
		line-height: 1.45;
		letter-spacing: -0.012em;
		text-align: right;
		white-space: nowrap;
	}

	@media (max-width: 1280px) {
		.iwm-footer-top {
			grid-template-columns: 1fr 1fr;
		}

		.iwm-footer-brand-card {
			grid-column: 1 / -1;
		}

		.iwm-footer-docs {
	display: grid;
	gap: 14px;
}

.iwm-footer-docs ul {
	flex-wrap: wrap;
	justify-content: flex-start;
	gap: 10px 0;
}

		.iwm-footer-bottom {
			align-items: flex-start;
			flex-direction: column;
		}

		.iwm-footer-rights {
			text-align: left;
			white-space: normal;
		}
	}

	@media (max-width: 760px) {
		.iwm-footer {
			padding: 24px 0 34px;
		}

		.iwm-footer-shell {
			padding: 16px;
			border-radius: 30px;
		}

		.iwm-footer-top {
			grid-template-columns: 1fr;
			gap: 12px;
		}

		.iwm-footer-brand-card,
		.iwm-footer-card,
		.iwm-footer-docs {
			border-radius: 24px;
		}

		.iwm-footer-brand-card,
		.iwm-footer-card {
			padding: 20px;
		}

		.iwm-footer-logo {
			width: min(320px, 100%);
		}

		.iwm-footer-lead {
			font-size: clamp(1.08rem, 5.5vw, 1.42rem);
			line-height: 1.14;
		}

		.iwm-footer-copy {
			font-size: 0.96rem;
			line-height: 1.6;
		}

		.iwm-footer-cta {
			width: 100%;
			min-height: 52px;
			padding: 0 18px;
			text-align: center;
		}

		.iwm-footer-docs {
	display: grid;
	margin-top: 12px;
	padding: 20px;
	gap: 12px;
}

.iwm-footer-docs ul {
	display: grid;
	gap: 12px;
}

.iwm-footer-docs li {
	display: flex;
	white-space: normal;
}

.iwm-footer-docs li:not(:last-child)::after {
	display: none;
}

.iwm-footer-docs a {
	white-space: normal;
}

		.iwm-footer-bottom {
			gap: 10px;
			margin-top: 14px;
			padding-top: 14px;
		}

		.iwm-footer-copyright {
			white-space: normal;
		}
	}
</style>