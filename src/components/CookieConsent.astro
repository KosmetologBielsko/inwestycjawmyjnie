<div class="iwm-cookie-consent" data-cookie-consent hidden>
	<div class="iwm-cookie-card" data-cookie-card>
		<div class="iwm-cookie-main" data-cookie-main>
			<div class="iwm-cookie-copy">
				<p>Cookies i zgody</p>
				<h2>Dbamy o prywatność i mierzenie skuteczności strony</h2>
				<span>
					Używamy cookies niezbędnych do działania strony. Cookies analityczne i marketingowe
					uruchomimy dopiero po Twojej zgodzie. Możesz zaakceptować wszystkie, odrzucić
					opcjonalne albo wybrać ustawienia.
				</span>
			</div>

			<div class="iwm-cookie-actions">
				<button type="button" class="iwm-cookie-primary" data-cookie-accept-all>
					Akceptuję wszystkie
				</button>

				<button type="button" class="iwm-cookie-secondary" data-cookie-reject-optional>
					Odrzuć opcjonalne
				</button>

				<button type="button" class="iwm-cookie-link" data-cookie-settings>
					Ustawienia
				</button>
			</div>
		</div>

		<div class="iwm-cookie-settings" data-cookie-settings-panel hidden>
			<div class="iwm-cookie-copy">
				<p>Ustawienia cookies</p>
				<h2>Wybierz zgody</h2>
				<span>
					Niezbędne cookies są wymagane do działania strony. Analityczne pomagają mierzyć ruch,
					a marketingowe pomagają mierzyć reklamy i działania remarketingowe.
				</span>
			</div>

			<div class="iwm-cookie-options">
				<label class="iwm-cookie-option is-disabled">
					<input type="checkbox" checked disabled />
					<span>
						<strong>Niezbędne</strong>
						<small>Wymagane do działania strony, formularza i podstawowych funkcji.</small>
					</span>
				</label>

				<label class="iwm-cookie-option">
					<input type="checkbox" data-consent-analytics />
					<span>
						<strong>Analityczne</strong>
						<small>Pomagają mierzyć ruch, źródła wejść i skuteczność podstron.</small>
					</span>
				</label>

				<label class="iwm-cookie-option">
					<input type="checkbox" data-consent-marketing />
					<span>
						<strong>Marketingowe</strong>
						<small>Pomagają mierzyć reklamy, konwersje i działania remarketingowe.</small>
					</span>
				</label>
			</div>

			<div class="iwm-cookie-actions iwm-cookie-actions-settings">
				<button type="button" class="iwm-cookie-primary" data-cookie-save>
					Zapisz wybór
				</button>

				<button type="button" class="iwm-cookie-secondary" data-cookie-back>
					Wróć
				</button>
			</div>
		</div>
	</div>
</div>

<script is:inline>
	(() => {
		const STORAGE_KEY = 'iwmCookieConsentV1';

		const root = document.querySelector('[data-cookie-consent]');
		const mainPanel = document.querySelector('[data-cookie-main]');
		const settingsPanel = document.querySelector('[data-cookie-settings-panel]');

		const acceptAllButton = document.querySelector('[data-cookie-accept-all]');
		const rejectOptionalButton = document.querySelector('[data-cookie-reject-optional]');
		const settingsButton = document.querySelector('[data-cookie-settings]');
		const saveButton = document.querySelector('[data-cookie-save]');
		const backButton = document.querySelector('[data-cookie-back]');
		const cookieSettingsLinks = document.querySelectorAll('[data-open-cookie-settings]');

		const analyticsInput = document.querySelector('[data-consent-analytics]');
		const marketingInput = document.querySelector('[data-consent-marketing]');

		if (!(root instanceof HTMLElement)) return;

		window.dataLayer = window.dataLayer || [];

		function gtag() {
			window.dataLayer.push(arguments);
		}

		window.gtag = window.gtag || gtag;

		window.gtag('consent', 'default', {
			analytics_storage: 'denied',
			ad_storage: 'denied',
			ad_user_data: 'denied',
			ad_personalization: 'denied',
			wait_for_update: 500
		});

		function readConsent() {
			try {
				const raw = window.localStorage.getItem(STORAGE_KEY);
				if (!raw) return null;

				const parsed = JSON.parse(raw);

				return {
					necessary: true,
					analytics: parsed.analytics === true,
					marketing: parsed.marketing === true,
					updatedAt: parsed.updatedAt || new Date().toISOString()
				};
			} catch {
				return null;
			}
		}

		function saveConsent(consent) {
			const finalConsent = {
				necessary: true,
				analytics: consent.analytics === true,
				marketing: consent.marketing === true,
				updatedAt: new Date().toISOString()
			};

			window.localStorage.setItem(STORAGE_KEY, JSON.stringify(finalConsent));
			applyConsent(finalConsent);
			hideBanner();
		}

		function applyConsent(consent) {
			window.iwmCookieConsent = consent;

			window.gtag('consent', 'update', {
				analytics_storage: consent.analytics ? 'granted' : 'denied',
				ad_storage: consent.marketing ? 'granted' : 'denied',
				ad_user_data: consent.marketing ? 'granted' : 'denied',
				ad_personalization: consent.marketing ? 'granted' : 'denied'
			});

			window.dispatchEvent(
				new CustomEvent('iwm:cookie-consent', {
					detail: consent
				})
			);

			if (consent.analytics) {
				loadAnalyticsTools();
			}

			if (consent.marketing) {
				loadMarketingTools();
			}
		}

		function loadAnalyticsTools() {
			if (window.__iwmAnalyticsLoaded) return;
			window.__iwmAnalyticsLoaded = true;

			/*
				Tutaj później wkleimy GA4 / Google Tag Manager.
				Na razie celowo nic nie ładujemy przed podaniem ID narzędzi.
			*/
		}

		function loadMarketingTools() {
			if (window.__iwmMarketingLoaded) return;
			window.__iwmMarketingLoaded = true;

			/*
				Tutaj później wkleimy Google Ads, remarketing, Meta Pixel itd.
				Na razie celowo nic nie ładujemy przed podaniem ID narzędzi.
			*/
		}

		function showBanner() {
			root.hidden = false;

			if (mainPanel instanceof HTMLElement) {
				mainPanel.hidden = false;
			}

			if (settingsPanel instanceof HTMLElement) {
				settingsPanel.hidden = true;
			}
		}

		function hideBanner() {
			root.hidden = true;
		}

		function showSettings() {
			const currentConsent = readConsent();

			if (analyticsInput instanceof HTMLInputElement) {
				analyticsInput.checked = currentConsent?.analytics === true;
			}

			if (marketingInput instanceof HTMLInputElement) {
				marketingInput.checked = currentConsent?.marketing === true;
			}

			if (mainPanel instanceof HTMLElement) {
				mainPanel.hidden = true;
			}

			if (settingsPanel instanceof HTMLElement) {
				settingsPanel.hidden = false;
			}

			root.hidden = false;
		}

		function showMain() {
			if (mainPanel instanceof HTMLElement) {
				mainPanel.hidden = false;
			}

			if (settingsPanel instanceof HTMLElement) {
				settingsPanel.hidden = true;
			}
		}

		acceptAllButton?.addEventListener('click', () => {
			saveConsent({
				analytics: true,
				marketing: true
			});
		});

		rejectOptionalButton?.addEventListener('click', () => {
			saveConsent({
				analytics: false,
				marketing: false
			});
		});

		settingsButton?.addEventListener('click', showSettings);
		backButton?.addEventListener('click', showMain);

		cookieSettingsLinks.forEach((link) => {
			link.addEventListener('click', (event) => {
				event.preventDefault();
				showSettings();
			});
		});

		saveButton?.addEventListener('click', () => {
			saveConsent({
				analytics: analyticsInput instanceof HTMLInputElement ? analyticsInput.checked : false,
				marketing: marketingInput instanceof HTMLInputElement ? marketingInput.checked : false
			});
		});

		const existingConsent = readConsent();

		if (existingConsent) {
			applyConsent(existingConsent);
			hideBanner();
		} else {
			showBanner();
		}
	})();
</script>

<style>
