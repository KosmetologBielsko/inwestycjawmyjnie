---
const guideLinks = [
	{
		label: 'Ile kosztuje myjnia?',
		href: '/ile-kosztuje-myjnia-bezdotykowa/'
	},
	{
		label: 'Koszt budowy myjni',
		href: '/koszt-budowy-myjni-bezdotykowej/'
	},
	{
		label: 'Ile zarabia myjnia?',
		href: '/ile-zarabia-myjnia-bezdotykowa/'
	},
	{
		label: 'Działka pod myjnię',
		href: '/dzialka-pod-myjnie-bezdotykowa/'
	},
	{
		label: 'Jak porównać oferty?',
		href: '/jak-porownac-oferty-myjni-bezdotykowej/'
	},
	{
		label: 'Budowa krok po kroku',
		href: '/budowa-myjni-bezdotykowej-krok-po-kroku/'
	},
	{
		label: 'Błędy inwestora',
		href: '/najczestsze-bledy-przy-budowie-myjni/'
	}
];
---

<div class="floating-guide" data-floating-guide>
	<button
		class="floating-guide-button"
		type="button"
		aria-label="Otwórz poradnik inwestora"
		aria-expanded="false"
		data-floating-guide-toggle
	>
		<span class="floating-guide-icon" aria-hidden="true">
	<img
		src="/images/logo-inwestycjawmyjnie-symbol.webp"
		alt=""
		width="512"
		height="512"
		loading="lazy"
		decoding="async"
	/>
</span>
		<span class="floating-guide-pulse" aria-hidden="true"></span>
	</button>

	<div class="floating-guide-panel" aria-label="Poradnik inwestora" data-floating-guide-panel>
		<div class="floating-guide-head">
			<div>
				<p>Start inwestora</p>
				<h2>Poradnik myjni bezdotykowej</h2>
			</div>

			<button
				class="floating-guide-close"
				type="button"
				aria-label="Zamknij poradnik inwestora"
				data-floating-guide-close
			>
				×
			</button>
		</div>

		<p class="floating-guide-lead">
			Najważniejsze tematy przed decyzją o budowie myjni: koszt, działka, opłacalność,
			technologia, porównanie ofert i błędy inwestora.
		</p>

		<nav class="floating-guide-links" aria-label="Szybkie linki poradnika inwestora">
			{guideLinks.map((link) => (
				<a href={link.href}>
					<span>{link.label}</span>
					<b aria-hidden="true">→</b>
				</a>
			))}
		</nav>

		<a class="floating-guide-cta" href="/bezplatne-porownanie-ofert-myjni/">
			Bezpłatna analiza i porównanie ofert
			<span aria-hidden="true">→</span>
		</a>
	</div>
</div>

<script is:inline>
	const floatingGuides = document.querySelectorAll('[data-floating-guide]');

	floatingGuides.forEach((guide) => {
		const toggle = guide.querySelector('[data-floating-guide-toggle]');
		const close = guide.querySelector('[data-floating-guide-close]');
		const panel = guide.querySelector('[data-floating-guide-panel]');

		if (!(toggle instanceof HTMLButtonElement) || !(panel instanceof HTMLElement)) return;

		const openGuide = () => {
			guide.classList.add('is-open');
			toggle.setAttribute('aria-expanded', 'true');
		};

		const closeGuide = () => {
			guide.classList.remove('is-open');
			toggle.setAttribute('aria-expanded', 'false');
		};

		toggle.addEventListener('click', () => {
			if (guide.classList.contains('is-open')) {
				closeGuide();
			} else {
				openGuide();
			}
		});

		close?.addEventListener('click', closeGuide);

		document.addEventListener('keydown', (event) => {
			if (event.key === 'Escape') {
				closeGuide();
			}
		});

		document.addEventListener('click', (event) => {
			if (!(event.target instanceof Node)) return;

			if (!guide.contains(event.target)) {
				closeGuide();
			}
		});
	});
</script>

<style>
	.floating-guide {
	position: fixed;
	right: 20px;
	bottom: 20px;
	z-index: 999;
	font-family: inherit;
}

	.floating-guide-button {
		position: relative;
		display: grid;
		place-items: center;
		width: 56px;
		height: 56px;
		border: 1px solid rgba(8, 16, 32, 0.1);
		border-radius: 999px;
		background:
			radial-gradient(circle at 78% 18%, rgba(114, 240, 105, 0.32), transparent 36%),
			linear-gradient(145deg, #ffffff, #f6f9fc);
		box-shadow:
			0 18px 48px rgba(8, 16, 32, 0.15),
			0 0 34px rgba(114, 240, 105, 0.2),
			inset 0 1px 0 rgba(255, 255, 255, 0.95);
		color: #081020;
		cursor: pointer;
		transition:
			transform 0.2s ease,
			box-shadow 0.2s ease,
			border-color 0.2s ease;
	}

	.floating-guide-button:hover {
		transform: translateY(-3px);
		border-color: rgba(114, 240, 105, 0.42);
		box-shadow:
			0 22px 60px rgba(8, 16, 32, 0.19),
			0 0 42px rgba(114, 240, 105, 0.28),
			inset 0 1px 0 rgba(255, 255, 255, 0.95);
	}

	.floating-guide-icon {
	display: grid;
	place-items: center;
	width: 43px;
	height: 43px;
	border-radius: 999px;
	overflow: hidden;
	background:
		radial-gradient(circle at 72% 18%, rgba(114, 240, 105, 0.22), transparent 38%),
		radial-gradient(circle at 18% 24%, rgba(18, 104, 255, 0.18), transparent 42%),
		rgba(255, 255, 255, 0.88);
	border: 1px solid rgba(18, 104, 255, 0.12);
	box-shadow:
		0 10px 26px rgba(18, 104, 255, 0.18),
		0 0 22px rgba(114, 240, 105, 0.2),
		inset 0 1px 0 rgba(255, 255, 255, 0.92);
}

.floating-guide-icon img {
	display: block;
	width: 82%;
	height: 82%;
	object-fit: contain;
	filter:
		drop-shadow(0 5px 10px rgba(18, 104, 255, 0.16))
		drop-shadow(0 0 10px rgba(114, 240, 105, 0.12));
}

	.floating-guide-pulse {
		position: absolute;
		right: 8px;
		top: 8px;
		width: 11px;
		height: 11px;
		border-radius: 999px;
		background: #72f069;
		box-shadow:
			0 0 0 5px rgba(114, 240, 105, 0.15),
			0 0 18px rgba(114, 240, 105, 0.42);
	}

	.floating-guide-panel {
	position: absolute;
	right: 0;
	bottom: 70px;
	width: min(330px, calc(100vw - 32px));
	max-height: min(470px, calc(100vh - 260px));
		overflow-y: auto;
		padding: 14px;
		border-radius: 26px;
		border: 1px solid rgba(8, 16, 32, 0.08);
		background:
			radial-gradient(circle at 95% 4%, rgba(114, 240, 105, 0.17), transparent 34%),
			radial-gradient(circle at 0% 0%, rgba(18, 104, 255, 0.11), transparent 36%),
			rgba(255, 255, 255, 0.95);
		box-shadow:
			0 24px 74px rgba(8, 16, 32, 0.18),
			0 0 54px rgba(114, 240, 105, 0.18),
			inset 0 1px 0 rgba(255, 255, 255, 0.96);
		backdrop-filter: blur(18px);
		opacity: 0;
		pointer-events: none;
		transform: translateY(12px) scale(0.98);
		transform-origin: right bottom;
		transition:
			opacity 0.2s ease,
			transform 0.2s ease;
		scrollbar-width: thin;
		scrollbar-color: rgba(18, 104, 255, 0.28) transparent;
	}

	.floating-guide-panel::-webkit-scrollbar {
		width: 6px;
	}

	.floating-guide-panel::-webkit-scrollbar-track {
		background: transparent;
	}

	.floating-guide-panel::-webkit-scrollbar-thumb {
		border-radius: 999px;
		background: rgba(18, 104, 255, 0.26);
	}

	.floating-guide.is-open .floating-guide-panel {
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0) scale(1);
	}

	.floating-guide-panel::before {
		content: '';
		position: absolute;
		inset: 0 0 auto 0;
		height: 4px;
		border-radius: 26px 26px 0 0;
		background: linear-gradient(90deg, #1268ff 0%, #4fa3ff 42%, #72f069 100%);
		pointer-events: none;
	}

	.floating-guide-head {
		display: flex;
		align-items: flex-start;
		justify-content: space-between;
		gap: 14px;
		padding-top: 4px;
	}

	.floating-guide-head p {
		margin: 0;
		color: #1268ff;
		font-size: 0.64rem;
		font-weight: 950;
		letter-spacing: 0.15em;
		line-height: 1;
		text-transform: uppercase;
	}

	.floating-guide-head h2 {
		margin: 7px 0 0;
		color: #081020;
		font-size: 1.22rem;
		font-weight: 950;
		line-height: 0.98;
		letter-spacing: -0.055em;
	}

	.floating-guide-close {
		display: grid;
		place-items: center;
		width: 31px;
		height: 31px;
		border: 1px solid rgba(8, 16, 32, 0.08);
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.86);
		color: #081020;
		font-size: 1.15rem;
		font-weight: 850;
		line-height: 1;
		cursor: pointer;
		box-shadow: 0 8px 22px rgba(8, 16, 32, 0.05);
	}

	.floating-guide-lead {
		margin: 10px 0 0;
		color: #667085;
		font-size: 0.82rem;
		font-weight: 610;
		line-height: 1.42;
		letter-spacing: -0.016em;
	}

	.floating-guide-links {
		display: grid;
		gap: 7px;
		margin-top: 12px;
	}

	.floating-guide-links a {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 12px;
		min-height: 38px;
		padding: 8px 9px 8px 12px;
		border-radius: 14px;
		border: 1px solid rgba(8, 16, 32, 0.06);
		background: rgba(255, 255, 255, 0.84);
		color: #243044;
		font-size: 0.82rem;
		font-weight: 830;
		letter-spacing: -0.024em;
		line-height: 1.18;
		text-decoration: none;
		transition:
			transform 0.2s ease,
			border-color 0.2s ease,
			box-shadow 0.2s ease,
			color 0.2s ease;
	}

	.floating-guide-links a:hover {
		transform: translateY(-1px);
		border-color: rgba(18, 104, 255, 0.16);
		box-shadow: 0 10px 26px rgba(8, 16, 32, 0.06);
		color: #1268ff;
	}

	.floating-guide-links b {
		display: grid;
		place-items: center;
		width: 25px;
		height: 25px;
		border-radius: 999px;
		background:
			radial-gradient(circle at 72% 18%, rgba(114, 240, 105, 0.22), transparent 38%),
			#f2f6fb;
		color: #081020;
		font-size: 0.82rem;
		font-weight: 950;
		flex: 0 0 auto;
	}

	.floating-guide-cta {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		min-height: 44px;
		margin-top: 11px;
		padding: 0 14px;
		border-radius: 999px;
		color: #06110a;
		background: linear-gradient(90deg, #7cff4a 0%, #51f05e 45%, #28dc73 100%);
		border: 1px solid rgba(114, 240, 105, 0.34);
		box-shadow:
			0 14px 34px rgba(76, 244, 89, 0.22),
			inset 0 1px 0 rgba(255, 255, 255, 0.58);
		font-size: 0.82rem;
		font-weight: 950;
		letter-spacing: -0.025em;
		line-height: 1.1;
		text-align: center;
		text-decoration: none;
	}
@media (max-width: 1180px) {
	.floating-guide-panel {
		max-height: min(430px, calc(100vh - 245px));
	}

	.floating-guide-lead {
		display: none;
	}
}
	@media (max-width: 760px) {
		.floating-guide {
			right: 14px;
			bottom: 14px;
		}

		.floating-guide-button {
			width: 54px;
			height: 54px;
		}

		.floating-guide-icon {
	width: 41px;
	height: 41px;
}

	.floating-guide-panel {
	position: fixed;
	right: 12px;
	bottom: 78px;
	left: 12px;
	width: auto;
	max-height: calc(100vh - 235px);
	padding: 13px;
	border-radius: 24px;
	transform-origin: center bottom;
}

		.floating-guide-head h2 {
			font-size: 1.08rem;
			letter-spacing: -0.05em;
		}

		.floating-guide-lead {
			display: none;
		}

		.floating-guide-links {
			gap: 6px;
			margin-top: 10px;
		}

		.floating-guide-links a {
			min-height: 37px;
			padding: 8px 9px 8px 11px;
			font-size: 0.8rem;
		}

		.floating-guide-links b {
			width: 24px;
			height: 24px;
			font-size: 0.78rem;
		}

		.floating-guide-cta {
			min-height: 42px;
			margin-top: 10px;
			font-size: 0.8rem;
		}
	}

	@media (max-width: 390px) {
	.floating-guide-panel {
		max-height: calc(100vh - 220px);
	}

	.floating-guide-links a {
		font-size: 0.76rem;
	}
}
</style>