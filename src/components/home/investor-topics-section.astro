---
const topicCards = [
	{
		title: 'Koszt inwestycji',
		image: '/images/temat-koszt-inwestycji-myjni.webp',
		alt: 'Ile kosztuje myjnia bezdotykowa — koszt inwestycji, budowa, technologia, przyłącza i posadzka.',
		href: '/ile-kosztuje-myjnia-bezdotykowa/'
	},
	{
		title: 'Opłacalność',
		image: '/images/temat-oplacalnosc-myjni.webp',
		alt: 'Ile może zarabiać myjnia bezdotykowa — przychody, sezonowość, koszty i zwrot z inwestycji.',
		href: '/ile-zarabia-myjnia-bezdotykowa/'
	},
	{
		title: 'Lokalizacja',
		image: '/images/temat-lokalizacja-dzialki-pod-myjnie.webp',
		alt: 'Czy działka nadaje się pod myjnię bezdotykową — wjazd, widoczność, media i potencjał lokalizacji.',
		href: '/dzialka-pod-myjnie-bezdotykowa/'
	},
	{
		title: 'Dostawcy',
		image: '/images/temat-porownanie-ofert-producentow.webp',
		alt: 'Jak porównać oferty producentów myjni — zakres, technologia, konstrukcja, serwis i gwarancja.',
		href: '/jak-porownac-oferty-myjni-bezdotykowej/'
	}
];
---

<section class="section investor-topics-section" aria-labelledby="investor-topics-title">
	<div class="investor-topics-shell">
		<div class="investor-topics-head">
			<p class="eyebrow">
				<span></span>
				4 decyzje inwestora
			</p>

			<h2 id="investor-topics-title">
				Najważniejsze tematy <strong>przed budową</strong> myjni
			</h2>
		</div>

		<div class="investor-topics-grid">
			{
				topicCards.map((card) => (
					<a class="investor-topic-card" href={card.href} aria-label={card.title}>
						<img src={card.image} alt={card.alt} loading="lazy" decoding="async" />
					</a>
				))
			}
		</div>
	</div>
</section>

<style>
	.investor-topics-section {
		padding: clamp(40px, 5vw, 72px) 0;
	}

	.investor-topics-shell {
		width: min(1360px, calc(100% - clamp(40px, 6vw, 96px)));
		margin: 0 auto;
	}

	.investor-topics-head {
		margin-bottom: clamp(22px, 3vw, 34px);
	}

	.investor-topics-head h2 {
		margin: 0;
		max-width: 980px;
		font-size: clamp(2.3rem, 5vw, 5.25rem);
		line-height: 0.94;
		letter-spacing: -0.045em;
		font-weight: 900;
		color: #050b18;
	}

	.investor-topics-head h2 strong {
		font-weight: 900;
		background: linear-gradient(90deg, #246bff 0%, #7fc3ff 100%);
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
	}

	.investor-topics-grid {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: clamp(20px, 2.2vw, 28px);
		align-items: stretch;
	}

	.investor-topic-card {
		display: block;
		border-radius: 34px;
		overflow: hidden;
		background: #ffffff;
		box-shadow:
			0 24px 60px rgba(10, 20, 35, 0.06),
			0 4px 16px rgba(10, 20, 35, 0.05);
		transition:
			transform 0.25s ease,
			box-shadow 0.25s ease;
	}

	.investor-topic-card:hover {
		transform: translateY(-4px);
		box-shadow:
			0 28px 70px rgba(10, 20, 35, 0.09),
			0 8px 20px rgba(10, 20, 35, 0.07);
	}

	.investor-topic-card img {
		display: block;
		width: 100%;
		height: auto;
		aspect-ratio: 1586 / 992;
		object-fit: cover;
		object-position: center center;
	}

	@media (max-width: 1100px) {
		.investor-topics-shell {
			width: min(100%, calc(100% - 40px));
		}

		.investor-topics-grid {
			grid-template-columns: 1fr;
		}
	}

	@media (max-width: 767px) {
		.investor-topics-section {
			padding: 32px 0;
		}

		.investor-topics-shell {
			width: min(100%, calc(100% - 24px));
		}

		.investor-topics-head {
			margin-bottom: 18px;
		}

		.investor-topics-head h2 {
			font-size: clamp(2rem, 9vw, 3.2rem);
			line-height: 0.95;
		}

		.investor-topics-grid {
			gap: 16px;
		}

		.investor-topic-card {
			border-radius: 24px;
		}
	}
</style>