---
const tiles = [
	{
		title: 'WWW',
		image: '/images/sections/www-wide.webp',
		alt: 'WWW — szybka strona internetowa'
	},
	{
		title: 'CONTENT',
		image: '/images/sections/content-wide.webp',
		alt: 'Content — treści, które wyjaśniają ofertę'
	},
	{
		title: 'SEO',
		image: '/images/sections/seo-wide.webp',
		alt: 'SEO — widoczność w Google'
	},
	{
		title: 'AI',
		image: '/images/sections/ai-wide.webp',
		alt: 'AI — gotowość na nowe wyszukiwanie'
	}
];
---

<section class="intro-tiles" id="intro-tiles">
	<div class="container intro-container">
		<p class="intro-eyebrow">WWW · CONTENT · SEO · AI</p>

		<h2 class="intro-title">
			Cztery filary,
			<span>które pracują razem.</span>
		</h2>

		<p class="intro-lead">
			Każdy obszar ma znaczenie. Razem tworzą stronę, która wygląda dobrze,
			jest widoczna i pozyskuje kontakt.
		</p>

		<div class="intro-wide-list" aria-label="Cztery filary SmartWeb AI">
			{tiles.map((tile) => (
				<article class="intro-wide-card">
					<img
						src={tile.image}
						alt={tile.alt}
						loading="lazy"
						decoding="async"
					/>
				</article>
			))}
		</div>
	</div>
</section>

<style>
	.intro-tiles {
		background: #ffffff;
		color: #05070d;
		padding: clamp(72px, 7vw, 112px) 0;
	}

	.intro-container {
		text-align: center;
	}

	.intro-eyebrow {
		margin: 0 0 20px;
		color: #05070d;
		font-size: 0.76rem;
		font-weight: 950;
		letter-spacing: 0.16em;
		text-transform: uppercase;
	}

	.intro-title {
		margin: 0 auto;
		max-width: 980px;
		color: #05070d;
		font-size: clamp(3.5rem, 6.6vw, 7.6rem);
		font-weight: 980;
		line-height: 0.92;
		letter-spacing: -0.085em;
	}

	.intro-title span {
		display: block;
		background: linear-gradient(
			90deg,
			var(--blue) 0%,
			#ffffff 22%,
			var(--pink) 42%,
			#ffffff 52%,
			var(--pink) 62%,
			var(--blue) 100%
		);
		background-size: 220% auto;
		-webkit-background-clip: text;
		background-clip: text;
		color: transparent;
		animation: introTextShine 14s ease-in-out infinite;
	}

	.intro-lead {
		max-width: 760px;
		margin: 30px auto 0;
		color: #05070d;
		font-size: clamp(1.08rem, 1.4vw, 1.32rem);
		font-weight: 700;
		line-height: 1.58;
	}

	.intro-wide-list {
		width: min(680px, 100%);
		margin: clamp(42px, 5vw, 70px) auto 0;
		display: grid;
		gap: clamp(18px, 2.4vw, 28px);
		background: #ffffff;
	}

	.intro-wide-card {
		margin: 0;
		padding: 0;
		background: #ffffff;
		border: 0;
		border-radius: 0;
		box-shadow: none;
		overflow: visible;
	}

	.intro-wide-card img {
		display: block;
		width: 100%;
		height: auto;
		background: #ffffff;
		border: 0;
		border-radius: 0;
		box-shadow: none;
		filter: none;
	}

	@keyframes introTextShine {
		0% {
			background-position: 0% 50%;
		}

		50% {
			background-position: 100% 50%;
		}

		100% {
			background-position: 0% 50%;
		}
	}

	@media (max-width: 1180px) {
		.intro-wide-list {
			width: min(620px, 100%);
		}
	}

	@media (max-width: 760px) {
		.intro-tiles {
			padding: 64px 0;
		}

		.intro-container {
			text-align: left;
		}

		.intro-title {
			font-size: clamp(3rem, 14vw, 4.25rem);
			line-height: 0.96;
		}

		.intro-lead {
			margin-top: 24px;
			font-size: 1rem;
		}

		.intro-wide-list {
			width: 100%;
			margin-top: 34px;
			gap: 18px;
		}
	}
</style>
